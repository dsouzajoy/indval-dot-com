---
import { en } from '@/i18n/locales/en';

const { offices } = en.contact;

const locations = [
  {
    city: 'Bangalore HQ',
    address: 'Indval Technologies Pvt Ltd #181, 3rd floor, Outer Ring Road, opposite to Nagarbhavi BDA Complex, 2nd Stage, 2nd Block, Nagarbhavi, Bengaluru — 560072',
  },
  {
    city: 'USA',
    address: 'Austin, Texas',
  },
  {
    city: 'Germany',
    address: 'Pestalozzistrasse 16, 64297 Darmstadt',
  },
];
---

<section class="max-w-7xl mx-auto px-8 pb-24" aria-label="Global engineering centers">
  <div class="bg-primary p-12 relative overflow-hidden flex flex-col md:flex-row items-start justify-between gap-12">


    <!-- Left: heading + description -->
    <div class="relative z-10 max-w-xl">
      <h2
        class="text-3xl font-headline font-bold text-white mb-4"
        data-i18n="contact.offices.heading"
      >{offices.heading}</h2>
      <p
        class="text-white text-lg leading-relaxed"
        data-i18n="contact.offices.body"
      >{offices.body}</p>
    </div>

    <!-- Right: office list -->
    <div class="relative z-10 flex flex-col gap-6 md:min-w-[340px]">
      {locations.map(({ city, address }) => (
        <div class="flex items-start gap-4">
          <!-- Icon: white on primary-container (lighter blue) square -->
          <div class="bg-primary-container p-3 rounded text-white shrink-0">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">location_on</span>
          </div>
          <div>
            <p class="text-white font-bold mb-1">{city}</p>
            <p class="text-white text-sm leading-relaxed">{address}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
