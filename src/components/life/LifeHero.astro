---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden blueprint-bg py-20">
  <!-- Background image with gradient overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.pexels.com/photos/3862135/pexels-photo-3862135.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover opacity-60 scale-105"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-on-surface/80 via-on-surface/60 to-on-surface/40"></div>
  </div>

  <div class="container mx-auto px-6 md:px-8 relative z-10 max-w-7xl">
    <!-- Content -->
    <div class="max-w-3xl space-y-8">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 rounded">
        <span class="material-symbols-outlined text-white text-sm" aria-hidden="true">engineering</span>
        <span
          class="font-label text-xs uppercase tracking-[0.2em] text-white font-bold"
          data-i18n="life.hero.eyebrow"
        >{en.life.hero.eyebrow}</span>
      </div>

      <!-- Heading -->
      <h1
        class="font-headline font-black text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl text-white leading-[0.9] tracking-tight"
        data-i18n="life.hero.heading"
      >
        {en.life.hero.heading}
      </h1>

      <!-- Body text with orange left border -->
      <p
        class="text-white/80 text-xl leading-relaxed max-w-xl border-l-4 border-secondary pl-6"
        data-i18n="life.hero.body"
      >
        {en.life.hero.body}
      </p>

      <!-- CTA -->
      <div class="pt-4">
        <a
          href={withBase('/careers')}
          class="inline-block bg-gradient-to-r from-primary to-primary-container text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-widest hover:shadow-ambient-lg active:scale-95 transition-all duration-200 shadow-lg"
          data-i18n="life.hero.cta"
        >
          {en.life.hero.cta}
        </a>
      </div>
    </div>
  </div>
</section>
