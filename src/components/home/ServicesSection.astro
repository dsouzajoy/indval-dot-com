---
---
<section id="services" class="py-20 md:py-24 px-4 sm:px-6 lg:px-8" aria-label="Services">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="mb-20 max-w-2xl">
      <h2 class="font-sans font-black text-4xl text-primary mb-4 leading-tight">
        Multidisciplinary Engineering Ecosystem
      </h2>
      <p class="font-sans text-base text-on-surface-variant leading-relaxed">
        End-to-end solutions designed for high-stakes environments where failure is not an option.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Aerospace & Defense — 8 cols -->
      <div class="md:col-span-8 group relative h-96 overflow-hidden rounded-xl bg-surface-container-high hover:shadow-2xl transition-all duration-500">
        <img
          src="/images/service-aerospace.jpg"
          alt="Aerospace engine component"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/40 to-transparent p-12 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded-lg">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">flight</span>
          </div>
          <h3 class="font-sans font-bold text-3xl text-white mb-2">Aerospace &amp; Defense</h3>
          <p class="font-sans text-white/80 text-sm leading-relaxed max-w-lg">
            Precision structural optimization, fatigue analysis, and propulsion system integration for mission-critical avionics.
          </p>
        </div>
      </div>

      <!-- Automotive Systems — 4 cols -->
      <div class="md:col-span-4 group relative h-96 overflow-hidden rounded-xl bg-surface-container-high hover:shadow-2xl transition-all duration-500">
        <img
          src="/images/service-automotive.png"
          alt="Automotive engineering"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-10 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded-lg">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">directions_car</span>
          </div>
          <h3 class="font-sans font-bold text-2xl text-white mb-2">Automotive Systems</h3>
          <p class="font-sans text-white/80 text-sm leading-relaxed">
            EV chassis development, advanced thermal management, and ADAS sensor integration frameworks.
          </p>
        </div>
      </div>

      <!-- Locomotive — 4 cols -->
      <div class="md:col-span-4 group relative h-96 overflow-hidden rounded-xl bg-surface-container-lowest border border-outline-variant/10 hover:shadow-2xl transition-all duration-500">
        <img
          src="/images/service-locomotive.png"
          alt="Locomotive engineering"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent p-10 flex flex-col justify-end">
          <h3 class="font-sans font-bold text-2xl text-white mb-2">Locomotive</h3>
          <p class="font-sans text-white/80 text-sm leading-relaxed">
            High-speed rail design and freight locomotive engine assembly optimization.
          </p>
        </div>
      </div>

      <!-- Off Highway — 4 cols -->
      <div class="md:col-span-4 group relative h-96 overflow-hidden rounded-xl bg-surface-container-high hover:shadow-2xl transition-all duration-500">
        <img
          src="/images/service-off-highway.png"
          alt="Off highway machinery"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/90 to-transparent p-10 flex flex-col justify-end">
          <h3 class="font-sans font-bold text-2xl text-white mb-2">Off Highway</h3>
          <p class="font-sans text-white/80 text-sm leading-relaxed">
            Robust hydraulic systems and chassis engineering for heavy construction &amp; agriculture.
          </p>
        </div>
      </div>

      <!-- General Engineering — 4 cols -->
      <div class="md:col-span-4 group relative h-96 overflow-hidden rounded-xl bg-primary-container hover:shadow-2xl transition-all duration-500">
        <img
          src="/images/service-general.png"
          alt="General engineering"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-secondary/90 to-transparent p-10 flex flex-col justify-end">
          <h3 class="font-sans font-bold text-2xl text-white mb-2">General Engineering</h3>
          <p class="font-sans text-white/80 text-sm leading-relaxed">
            Multidisciplinary technical solutions for advanced manufacturing and complex assembly lines.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
