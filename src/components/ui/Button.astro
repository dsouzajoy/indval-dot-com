---
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost';
  type?: 'button' | 'submit';
  class?: string;
}

const { href, variant = 'primary', type = 'button', class: className } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-8 py-4 rounded font-label font-bold text-sm uppercase tracking-wider transition-all duration-200 cursor-pointer';

const variants = {
  primary: 'bg-primary text-white hover:bg-primary-container active:scale-95',
  ghost: 'border border-outline-variant/30 text-primary bg-transparent hover:bg-surface-container-low active:scale-95',
};

const classes = [base, variants[variant], className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
