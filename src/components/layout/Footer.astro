---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';

const solutions = [
  { label: en.footer.solutions.aerospace,  href: '/404', i18nKey: 'footer.solutions.aerospace'  },
  { label: en.footer.solutions.automotive, href: '/404', i18nKey: 'footer.solutions.automotive' },
  { label: en.footer.solutions.automation, href: '/404', i18nKey: 'footer.solutions.automation' },
  { label: en.footer.solutions.qa,         href: '/404', i18nKey: 'footer.solutions.qa'         },
];

const company = [
  { label: en.footer.company.pedigree, href: '/404', i18nKey: 'footer.company.pedigree' },
  { label: en.footer.company.papers,   href: '/404', i18nKey: 'footer.company.papers'   },
  { label: en.footer.company.privacy,  href: '/404', i18nKey: 'footer.company.privacy'  },
  { label: en.footer.company.terms,    href: '/404', i18nKey: 'footer.company.terms'    },
];

const year = new Date().getFullYear();
---
<footer role="contentinfo" class="bg-primary text-white">

  <!-- Main grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <img src={withBase('/images/logo.png')} alt="Indvaltech" class="h-14 w-auto mb-4 bg-white rounded-xl p-1.5" />
        <p class="text-slate-400 text-sm leading-relaxed max-w-xs" data-i18n="footer.brand">
          {en.footer.brand}
        </p>
      </div>

      <!-- Solutions -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.solutionsHeading">
          {en.footer.solutionsHeading}
        </h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {solutions.map(({ label, href, i18nKey }) => (
            <li>
              <a href={withBase(href)} data-i18n={i18nKey} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.companyHeading">
          {en.footer.companyHeading}
        </h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {company.map(({ label, href, i18nKey }) => (
            <li>
              <a href={withBase(href)} data-i18n={i18nKey} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.newsletterHeading">
          {en.footer.newsletterHeading}
        </h3>
        <p class="text-sm text-slate-400 mb-4 leading-relaxed" data-i18n="footer.newsletterDesc">
          {en.footer.newsletterDesc}
        </p>
        <form onsubmit="return false;">
          <!-- TODO: wire to email service (Formspree / ConvertKit / etc.) -->
          <div class="flex">
            <input
              type="email"
              placeholder={en.footer.emailPlaceholder}
              autocomplete="email"
              data-i18n-attr="placeholder:footer.emailPlaceholder"
              class="flex-1 min-w-0 px-4 py-3 text-sm bg-white/10 text-white placeholder-white/40
                     border-0 rounded-l-xl focus:outline-none focus:ring-1 focus:ring-secondary/60
                     transition-colors duration-200"
            />
            <button
              type="submit"
              class="px-4 py-3 bg-secondary rounded-r-xl hover:bg-secondary/90 active:scale-95 transition-all duration-200"
              aria-label={en.footer.subscribeLabel}
              data-i18n-attr="aria-label:footer.subscribeLabel"
            >
              <span class="material-symbols-outlined text-white text-xl">send</span>
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p
        class="font-label text-[10px] uppercase tracking-widest text-slate-400"
        data-i18n="footer.copyright"
        data-i18n-vars={`{"year":"${year}"}`}
      >
        © {year} Indvaltech Engineering. Precision Guaranteed.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" aria-label="Share" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">share</span>
        </a>
        <a href="#" aria-label="LinkedIn" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">hub</span>
        </a>
        <a href="#" aria-label="Website" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">public</span>
        </a>
      </div>
    </div>
  </div>

</footer>
