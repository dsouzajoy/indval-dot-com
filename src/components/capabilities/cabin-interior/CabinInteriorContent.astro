  { component: 'Cargo Containers', scope: 'Certified aluminum or composite ULDs (ETSO-C90)' },
  { component: 'Standard Containers', scope: 'Lower and main deck contoured baggage/cargo units' },
  { component: 'Galley Trolleys', scope: 'Half-size and full-size ATLAS/KSSU meal and waste carts (ETSO-C175)' },
  { component: 'Pallets & Nets', scope: 'Heavy-duty restraint nets and aluminum bulk freight bases' },
  { component: 'Cabin Attendant Seats', scope: 'Folding jumpseats with integrated retraction and harness mechanisms' },
];

const retrofitSpecs = [
  { component: 'Overhead Stowage Bins', scope: 'High-capacity composite bins and assist handrails' },
  { component: 'Movable Class Dividers', scope: 'Track-mounted bulkheads and custom curtain headers' },
  { component: 'Seasonal & Regional Mods', scope: 'Quick-change seating, LOPA updates, and galley swaps' },
  { component: 'Full Cabin Conversions', scope: 'Complete interior strip-down and density reconfigurations' },
  { component: 'VIP Conversions', scope: 'Bespoke monuments, luxury finishes, and VIP seating' },
  { component: 'Cabin Lighting Upgrades', scope: 'Retrofit LED mood and reading light systems' },
  { component: 'Upholstery', scope: 'Ergonomic, fire-blocked bespoke upholstery' },
  { component: 'Linings', scope: 'Refurbished composites with updated laminates' },
  { component: 'Carpeting & Flooring', scope: 'Flame-retardant carpets and durable wet-area NTF' },
