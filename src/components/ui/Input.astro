---
interface Props {
  id?: string;
  type?: string;
  placeholder?: string;
  autocomplete?: string;
  class?: string;
  name?: string;
}

const { id, type = 'text', placeholder, autocomplete, name, class: className } = Astro.props;

const classes = [
  'w-full px-4 py-3 text-sm bg-surface-container-lowest text-on-surface placeholder-on-surface-variant/50',
  'border-0 border-b-2 border-outline-variant focus:border-primary focus:outline-none transition-colors duration-200',
  className,
].filter(Boolean).join(' ');
---
<input
  id={id}
  type={type as any}
  name={name}
  placeholder={placeholder}
  autocomplete={autocomplete}
  class={classes}
/>
