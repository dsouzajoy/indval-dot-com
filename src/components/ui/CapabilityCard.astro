---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { withBase } from '@/lib/utils';

interface Props {
  image: ImageMetadata;
  label: string;
  icon: string;
  description: string;
  href?: string;
  id?: string;
  /** i18n key paths — when set, the runtime swaps these nodes on locale change. */
  labelKey?: string;
  descriptionKey?: string;
}

const { image, label, icon, description, href, id, labelKey, descriptionKey } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  id={id}
  href={href ? withBase(href) : undefined}
  class:list={[
    'group bg-surface-container-low rounded flex flex-col overflow-hidden',
    'border border-outline-variant border-b-2',
    'hover:border-b-secondary hover:bg-surface-container-high',
    'transition-all duration-300',
    href && 'btn-press-card',
  ]}
>
  <div class="aspect-video overflow-hidden">
    <Image
      src={image}
      alt={label}
      format="avif"
      quality={100}
      width={800}
      height={450}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div class="p-8 flex flex-col flex-grow">
    <div class="flex items-center justify-between gap-4 mb-3">
      <h3 class="font-headline font-bold text-xl text-on-surface" data-i18n={labelKey}>{label}</h3>
      <span class="material-symbols-outlined text-primary text-4xl shrink-0" aria-hidden="true">{icon}</span>
    </div>
    <p class="text-on-surface-variant leading-relaxed text-sm flex-grow" data-i18n={descriptionKey}>{description}</p>
  </div>
</Tag>
