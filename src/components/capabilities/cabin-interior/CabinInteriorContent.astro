---

<!-- INTRO -->
<section id="intro" class="bg-surface">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">The capability</p>
      <h2 class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary">
        Full-lifecycle cabin interior engineering
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-on-surface-variant">
        Our multidisciplinary team supports OEMs, Tier-1 suppliers, airlines, completion centers, and MRO organizations across the entire interior program: concept development, detailed design, structural and stress analysis, certification support, manufacturing engineering, and cabin modernization.
      </p>
      <p class="mt-5 text-lg leading-relaxed text-on-surface-variant">
        The result: passenger-centric cabin environments that improve comfort, optimize space utilization, lift operational efficiency, and reinforce brand identity, all delivered to stringent aerospace standards.
      </p>
    </div>
    <div class="rounded overflow-hidden shadow-lg aspect-[4/3]">
      <Image
        src={introImg}
        alt="Aircraft cabin interior engineering"
        format="avif"
        quality={100}
        width={800}
        height={600}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</section>

<!-- SPECIALISATIONS -->
<section class="eng-spec-section bg-surface-container-low pt-24 lg:pt-32 pb-16 lg:pb-20 border-t border-outline-variant">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="flex flex-wrap items-end justify-between gap-x-10 gap-y-8">
      <div class="max-w-2xl">
        <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">ENGINEERING</p>
        <h2 class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary">
          Specialisations
        </h2>
      </div>
      <div class="eng-stat flex items-center gap-4">
        <span class="material-symbols-outlined text-secondary shrink-0" style="font-size: 36px; font-variation-settings: 'FILL' 1" aria-hidden="true">hub</span>
        <div>
          <span class="eng-stat-count font-headline font-black text-4xl text-primary tabular-nums" data-count="10">10</span>
          <p class="mt-0.5 font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant leading-tight">Engineering Disciplines</p>
        </div>
      </div>
    </div>

    <div class="mt-10 lg:mt-14 flex flex-col lg:flex-row lg:items-start gap-10 lg:gap-16">
      <div class="eng-spec-image lg:order-2 lg:w-[38%] lg:shrink-0 rounded overflow-hidden p-6 lg:p-8" style="background-image: radial-gradient(circle, rgba(0,49,108,0.12) 1px, transparent 1px); background-size: 28px 28px;">
        <Image
          src={specialisationsImg}
          alt="Cutaway illustration of an aircraft cabin interior showing seating, stowage, and systems integration"
          format="avif"
          quality={100}
          width={1000}
          height={1000}
          loading="lazy"
          class="w-full h-auto rounded"
        />
      </div>

      <dl class="lg:order-1 flex-1 grid grid-cols-1 sm:grid-cols-2 sm:gap-x-10 border-t border-outline-variant/70">
        {specialisations.map((row) => (
          <div class="eng-spec-row group py-4 sm:py-5 px-2 -mx-2 rounded border-b border-outline-variant/70 transition-colors duration-200 hover:bg-surface">
            <dt class="flex items-start gap-2.5">
              <span class="mt-2 w-1.5 h-1.5 rounded-full bg-secondary shrink-0 transition-transform duration-200 group-hover:scale-[1.8]" aria-hidden="true"></span>
              <span class="font-headline font-bold text-[0.95rem] text-primary leading-snug">{row.discipline}</span>
            </dt>
            <dd class="mt-1.5 pl-4 text-sm text-on-surface-variant leading-relaxed">{row.scope}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<!-- CABIN INTERIORS -->
<section class="eng-spec-section bg-surface-container-low pt-12 lg:pt-16 pb-16 lg:pb-20">
