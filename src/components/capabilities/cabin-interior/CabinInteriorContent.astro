    </div>

    <div class="mt-10 lg:mt-14 flex flex-col lg:flex-row lg:items-start gap-10 lg:gap-16">
      <div class="eng-spec-image lg:order-1 lg:w-[38%] lg:shrink-0 rounded overflow-hidden p-6 lg:p-8" style="background-image: radial-gradient(circle, rgba(0,49,108,0.12) 1px, transparent 1px); background-size: 28px 28px;">
        <Image
          src={cabinInteriorsImg}
          alt="Wide-angle symmetrical view of a modern aircraft cabin interior"
          format="avif"
          quality={100}
          width={1000}
          height={1000}
          loading="lazy"
          class="w-full h-auto rounded"
        />
      </div>

      <dl class="lg:order-2 flex-1 grid grid-cols-1 sm:grid-cols-2 sm:gap-x-10 border-t border-outline-variant/70">
