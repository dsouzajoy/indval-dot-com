const galleySpecs = [
  { component: 'Galley Complexes', scope: 'Nose, aft, and overwing' },
  { component: 'Composites', scope: 'Honeycomb construction' },
  { component: 'Insert Equipment', scope: 'Mounting frames and guide rails' },
