---
import { en } from '@/i18n/locales/en';
import HeroImage from '@/components/ui/HeroImage.astro';
import { getLQIP } from '@/lib/lqip';
import heroImg from '@/assets/images/general-hero.jpg';

const placeholder = await getLQIP('src/assets/images/general-hero.jpg');
---

<section
  class="relative min-h-screen flex items-center overflow-hidden"
  aria-label="General Engineering"
>
  <HeroImage src={heroImg} {placeholder} alt="" />
  <!-- Dark gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-on-surface/85 via-on-surface/65 to-on-surface/20 z-10"></div>

  <div class="container mx-auto px-8 lg:px-16 relative z-20 py-32">
    <div class="max-w-2xl space-y-8">

      <!-- Eyebrow -->
      <div
        class="inline-block px-4 py-1.5 bg-white/10 text-white/80 font-label text-xs tracking-[0.2em] uppercase rounded-full border border-white/20"
        data-i18n="general.hero.eyebrow"
      >
        {en.general.hero.eyebrow}
      </div>

      <!-- Heading -->
      <h1
        class="font-headline text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tighter text-white leading-tight"
        data-i18n="general.hero.heading"
      >
        {en.general.hero.heading}
      </h1>

      <!-- Description -->
      <p
        class="text-xl text-white/85 font-light leading-relaxed border-l-4 border-secondary pl-8 max-w-xl"
        data-i18n="general.hero.description"
      >
        {en.general.hero.description}
      </p>

      <!-- CTA -->
      <div class="pt-2">
        <a
          href="#what-we-do"
          id="general-hero-cta"
          class="inline-block bg-gradient-to-r from-secondary to-secondary/80 text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-widest btn-press"
          data-i18n="general.hero.cta"
        >
          {en.general.hero.cta}
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  document.getElementById('general-hero-cta')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('what-we-do')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
