const lavatorySpecs = [
  { component: 'Modules', scope: 'Composite structure with plumbing integration' },
  { component: 'Surface Materials', scope: 'FAR 25.853 fire, smoke, and toxicity compliance' },
  { component: 'Plumbing', scope: 'Vacuum flush mechanisms and gray water drainage' },
  { component: 'Retrofit Modules', scope: 'Designed for cabin conversion programmes' },
  { component: 'Certification', scope: 'Full STC documentation package available' },
  { component: 'Door Systems', scope: 'Space-saving bi-fold or blade doors' },
