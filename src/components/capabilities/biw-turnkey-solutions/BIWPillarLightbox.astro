---
---

<div
  id="biw-lightbox"
  class="hidden fixed inset-0 z-[9999] bg-black/[0.92] backdrop-blur-sm flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="Pillar image gallery"
>
  <!-- Top bar -->
  <div class="flex items-center gap-3 px-5 py-4 bg-black/60 shrink-0 border-b border-white/10">
    <span id="lb-icon" class="material-symbols-outlined text-secondary shrink-0" style="font-size: 1.5rem" aria-hidden="true"></span>
    <span id="lb-title" class="font-headline font-bold text-white text-base flex-1 truncate"></span>
    <span id="lb-counter" class="text-white/50 text-sm font-label tabular-nums mr-3 shrink-0"></span>
    <button
      id="lb-close"
      class="flex items-center justify-center w-9 h-9 text-white/70 hover:text-white hover:bg-white/10 rounded-full shrink-0 focus:outline-none focus:ring-2 focus:ring-white/30 btn-press-icon"
      aria-label="Close gallery"
    >
      <span class="material-symbols-outlined text-2xl" aria-hidden="true">close</span>
    </button>
  </div>

  <!-- Image area -->
  <div class="flex-1 relative flex items-center justify-center overflow-hidden min-h-0">
    <button
      id="lb-prev"
      class="absolute left-3 md:left-5 z-10 flex items-center justify-center w-11 h-11 bg-black/50 hover:bg-black/80 text-white rounded-full focus:outline-none focus:ring-2 focus:ring-white/30 disabled:opacity-30 disabled:pointer-events-none btn-press-icon"
      aria-label="Previous image"
    >
      <span class="material-symbols-outlined text-2xl" aria-hidden="true">chevron_left</span>
    </button>

    <div class="w-full h-full flex items-center justify-center px-16 md:px-24 py-6">
      <img
        id="lb-image"
        src=""
        alt=""
        class="max-h-full max-w-full object-contain"
        style="transition: opacity 200ms ease;"
      />
    </div>

    <button
      id="lb-next"
      class="absolute right-3 md:right-5 z-10 flex items-center justify-center w-11 h-11 bg-black/50 hover:bg-black/80 text-white rounded-full focus:outline-none focus:ring-2 focus:ring-white/30 disabled:opacity-30 disabled:pointer-events-none btn-press-icon"
      aria-label="Next image"
    >
      <span class="material-symbols-outlined text-2xl" aria-hidden="true">chevron_right</span>
    </button>
  </div>

  <!-- Bottom bar -->
  <div class="shrink-0 py-5 flex flex-col items-center">
    <div id="lb-dots" class="flex items-center gap-2"></div>
  </div>
</div>

<script>
  interface LbImage { src: string; }

  const lightbox  = document.getElementById('biw-lightbox')!;
  const lbIcon    = document.getElementById('lb-icon')!;
  const lbTitle   = document.getElementById('lb-title')!;
  const lbCounter = document.getElementById('lb-counter')!;
  const lbClose   = document.getElementById('lb-close') as HTMLButtonElement;
  const lbPrev    = document.getElementById('lb-prev') as HTMLButtonElement;
  const lbNext    = document.getElementById('lb-next') as HTMLButtonElement;
  const lbImage   = document.getElementById('lb-image') as HTMLImageElement;
  const lbDots    = document.getElementById('lb-dots')!;

  let images: LbImage[] = [];
  let currentIndex = 0;

  function syncDots() {
    lbDots.querySelectorAll('button').forEach((btn, i) => {
      btn.className = `w-2 h-2 rounded-full transition-all duration-200 focus:outline-none ${
        i === currentIndex
          ? 'bg-secondary scale-125'
          : 'bg-white/40 hover:bg-white/70'
      }`;
    });
  }

  function buildDots() {
    lbDots.innerHTML = '';
    images.forEach((_, i) => {
      const btn = document.createElement('button');
      btn.setAttribute('aria-label', `Go to image ${i + 1}`);
      btn.addEventListener('click', () => goTo(i));
      lbDots.appendChild(btn);
    });
    syncDots();
  }

  function updateUI() {
    lbCounter.textContent = `${currentIndex + 1} / ${images.length}`;
    lbPrev.disabled = currentIndex === 0;
    lbNext.disabled = currentIndex === images.length - 1;
    syncDots();
  }

  function goTo(index: number) {
    if (index < 0 || index >= images.length) return;
    lbImage.style.opacity = '0';
    setTimeout(() => {
      currentIndex = index;
      lbImage.src = images[index].src;
      lbImage.alt = '';
      lbImage.style.opacity = '1';
      updateUI();
    }, 200);
  }

  function openLightbox(title: string, icon: string, imgs: LbImage[]) {
    images = imgs;
    currentIndex = 0;
    lbIcon.textContent = icon;
    lbTitle.textContent = title;
    lbImage.src = imgs[0].src;
    lbImage.alt = '';
    lbImage.style.opacity = '1';
    buildDots();
    updateUI();
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.style.overflow = '';
  }

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => goTo(currentIndex - 1));
  lbNext.addEventListener('click', () => goTo(currentIndex + 1));

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') goTo(currentIndex - 1);
    if (e.key === 'ArrowRight') goTo(currentIndex + 1);
  });

  // Touch swipe
  let touchStartX = 0;
  lightbox.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lightbox.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) goTo(dx < 0 ? currentIndex + 1 : currentIndex - 1);
  }, { passive: true });

  // Wire up card clicks
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('[data-pillar-index]').forEach((card) => {
      card.addEventListener('click', () => {
        const title = card.dataset.pillarTitle ?? '';
        const icon  = card.dataset.pillarIcon  ?? '';
        const imgs: LbImage[] = JSON.parse(card.dataset.images ?? '[]');
        openLightbox(title, icon, imgs);
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
      });
    });
  });
</script>
