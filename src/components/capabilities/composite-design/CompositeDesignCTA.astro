---
import Button from '@/components/ui/Button.astro';
import { withBase } from '@/lib/utils';
---

<section class="bg-secondary">
  <div class="max-w-5xl mx-auto px-8 lg:px-16 py-16 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8">
    <div>
      <h2 class="font-headline text-3xl lg:text-4xl font-extrabold tracking-tighter text-white">
        Have a part or a Class A surface?
      </h2>
      <p class="text-lg text-white/85 mt-3">
        Send your data and we'll scope the tooling. Quote back in 24 hours.
      </p>
    </div>
    <div class="shrink-0">
      <Button href={withBase('/contact#contact-form')} variant="primary">Get in touch</Button>
    </div>
  </div>
</section>
