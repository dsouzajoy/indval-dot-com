import cabinInteriorsImg from '@/assets/images/cabin-interior/cabin-interiors.png';
import galleyDiagramImg from '@/assets/images/cabin-interior/galley-diagram.png';
import lavatoryDiagramImg from '@/assets/images/cabin-interior/lavatory-diagram.png';
import lruDiagramImg from '@/assets/images/cabin-interior/lru-diagram.png';
import retrofitDiagramImg from '@/assets/images/cabin-interior/retrofit-diagram.png';
import tabStructuresImg from '@/assets/images/cabin-interior/tab-structures.jpg';
import tabWaterWasteImg from '@/assets/images/cabin-interior/tab-water-waste.png';
import tabOxygenImg from '@/assets/images/cabin-interior/tab-oxygen.png';
import tabSeatingImg from '@/assets/images/cabin-interior/tab-seating.jpg';
import tabGalleyImg from '@/assets/images/cabin-interior/tab-galley.png';
import tabLightingImg from '@/assets/images/cabin-interior/tab-lighting.jpg';
