---
import { Image } from 'astro:assets';
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';

import introImg from '@/assets/images/secondary-structure-design/intro.jpg';
import bracketImg from '@/assets/images/secondary-structure-design/bracket-design.jpg';
import harnessImg from '@/assets/images/secondary-structure-design/harness-support.jpg';
import ecsImg from '@/assets/images/secondary-structure-design/ecs-structures.png';
import detailedEngineeringImg from '@/assets/images/secondary-structure-design/detailed-engineering.jpg';

const ssd = en.secondaryStructureDesign;

const capabilities = [
  { key: 'bracketDesign', image: bracketImg, imageAlt: 'Rows of precision sheet metal brackets ready for installation', data: ssd.capabilities.bracketDesign, imageSide: 'right' as const },
  { key: 'harnessSupport', image: harnessImg, imageAlt: 'Coiled aircraft-grade wiring harness bundles', data: ssd.capabilities.harnessSupport, imageSide: 'left' as const },
  { key: 'ecsStructures', image: ecsImg, imageAlt: 'Metal ducting and pipework supporting an environmental control system', data: ssd.capabilities.ecsStructures, imageSide: 'right' as const },
  { key: 'detailedEngineering', image: detailedEngineeringImg, imageAlt: 'Engineer drafting detailed technical drawings at a desk', data: ssd.capabilities.detailedEngineering, imageSide: 'left' as const },
];

const steps = [
  { key: 'requirementAnalysis', num: '01', data: ssd.process.requirementAnalysis },
  { key: 'dmuAssessment', num: '02', data: ssd.process.dmuAssessment },
  { key: 'conceptDevelopment', num: '03', data: ssd.process.conceptDevelopment },
  { key: 'detailedDesign', num: '04', data: ssd.process.detailedDesign },
  { key: 'verification', num: '05', data: ssd.process.verification },
  { key: 'documentation', num: '06', data: ssd.process.documentation },
];

const whyUs = [
  { key: 'aerospaceExpertise', icon: 'flight', label: ssd.whyUs.aerospaceExpertise },
  { key: 'lightweightDesigns', icon: 'balance', label: ssd.whyUs.lightweightDesigns },
  { key: 'integratedApproach', icon: 'hub', label: ssd.whyUs.integratedApproach },
  { key: 'endToEndSupport', icon: 'engineering', label: ssd.whyUs.endToEndSupport },
  { key: 'qualityAndCompliance', icon: 'verified', label: ssd.whyUs.qualityAndCompliance },
];
---

<!-- INTRO -->
<section class="bg-surface">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="secondaryStructureDesign.intro.eyebrow"
      >{ssd.intro.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary text-balance"
        data-i18n="secondaryStructureDesign.intro.heading"
      >{ssd.intro.heading}</h2>
      <p
        class="mt-6 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="secondaryStructureDesign.intro.para1"
      >{ssd.intro.para1}</p>
      <p
        class="mt-5 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="secondaryStructureDesign.intro.para2"
      >{ssd.intro.para2}</p>
      <ul class="mt-8 grid grid-cols-1 gap-y-3">
        {ssd.intro.examples.map((item, j) => (
          <li class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-secondary shrink-0 text-lg leading-relaxed" style="font-variation-settings: 'FILL' 1" aria-hidden="true">check_circle</span>
            <span class="text-lg text-on-surface-variant leading-relaxed" data-i18n={`secondaryStructureDesign.intro.examples.${j}`}>{item}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="rounded overflow-hidden shadow-lg aspect-[4/3]">
      <Image
        src={introImg}
        alt="Aerospace technician inspecting aircraft wing structure"
        format="avif"
        quality={100}
        width={800}
        height={600}
        loading="eager"
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section id="capabilities" class="bg-surface-container-low py-24 lg:py-30" style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <p
          class="font-label text-sm uppercase tracking-widest text-secondary mb-3"
          data-i18n="secondaryStructureDesign.capabilities.eyebrow"
        >{ssd.capabilities.eyebrow}</p>
        <h2
          class="font-headline text-4xl lg:text-5xl font-bold text-on-surface"
          data-i18n="secondaryStructureDesign.capabilities.heading"
        >{ssd.capabilities.heading}</h2>
      </div>
      <p
        class="text-sm text-on-surface-variant font-label max-w-xs md:text-right shrink-0 leading-relaxed"
        data-i18n="secondaryStructureDesign.capabilities.intro"
      >{ssd.capabilities.intro}</p>
    </div>

    <div class="space-y-20">
      {capabilities.map((cap) => (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class:list={['space-y-5', cap.imageSide === 'left' && 'lg:order-2']}>
            <h3
              class="font-headline text-2xl lg:text-3xl font-bold text-on-surface"
              data-i18n={`secondaryStructureDesign.capabilities.${cap.key}.heading`}
            >{cap.data.heading}</h3>
            <p
              class="text-base leading-relaxed text-on-surface-variant"
              data-i18n={`secondaryStructureDesign.capabilities.${cap.key}.description`}
            >{cap.data.description}</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 pt-2">
              {cap.data.items.map((item, j) => (
                <li class="flex gap-3 items-start">
                  <span class="material-symbols-outlined text-secondary shrink-0 text-xl leading-relaxed" style="font-variation-settings: 'FILL' 1" aria-hidden="true">check_circle</span>
                  <span class="text-sm text-on-surface-variant leading-relaxed" data-i18n={`secondaryStructureDesign.capabilities.${cap.key}.items.${j}`}>{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class:list={['rounded overflow-hidden shadow-lg aspect-[4/3]', cap.imageSide === 'left' && 'lg:order-1']}>
            <Image
              src={cap.image}
              alt={cap.imageAlt}
              format="avif"
              quality={100}
              width={800}
              height={600}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- PROCESS -->
<section class="bg-surface py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-14 max-w-2xl">
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="secondaryStructureDesign.process.eyebrow"
      >{ssd.process.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold tracking-tight text-primary"
        data-i18n="secondaryStructureDesign.process.heading"
      >{ssd.process.heading}</h2>
    </div>
    <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-12">
      {steps.map(({ key, num, data }) => (
        <li class="flex gap-5">
          <span class="font-headline text-4xl font-black leading-none tabular-nums text-secondary/90 shrink-0 pt-1">{num}</span>
          <div>
            <h3
              class="text-lg font-bold tracking-tight text-on-surface"
              data-i18n={`secondaryStructureDesign.process.${key}.title`}
            >{data.title}</h3>
            <p
              class="mt-2 text-sm leading-relaxed text-on-surface-variant"
              data-i18n={`secondaryStructureDesign.process.${key}.description`}
            >{data.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- WHY PARTNER WITH US -->
<section class="relative bg-on-surface overflow-hidden">
  <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.04) 1.5px, transparent 1.5px); background-size: 32px 32px;"></div>
  <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(0,49,108,0.15) 0%, rgba(11,28,48,0.4) 100%);"></div>
  <div class="relative max-w-7xl mx-auto px-8 lg:px-16 py-20">
    <div class="mb-11 max-w-2xl">
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="secondaryStructureDesign.whyUs.eyebrow"
      >{ssd.whyUs.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold tracking-tight text-white"
        data-i18n="secondaryStructureDesign.whyUs.heading"
      >{ssd.whyUs.heading}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {whyUs.map(({ key, icon, label }) => (
        <div class="flex items-start gap-4 bg-white/5 border border-white/10 rounded p-6">
          <span class="material-symbols-outlined text-secondary shrink-0" style="font-size: 28px; font-variation-settings: 'FILL' 1">{icon}</span>
          <p
            class="text-base font-semibold text-white leading-snug"
            data-i18n={`secondaryStructureDesign.whyUs.${key}`}
          >{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CLOSING BRAND STATEMENT + CTA -->
<section class="bg-on-surface py-20 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 text-center">
    <h2
      class="font-headline text-3xl lg:text-4xl font-bold text-white mb-4 max-w-3xl mx-auto text-balance"
      data-i18n="secondaryStructureDesign.cta.heading"
    >{ssd.cta.heading}</h2>
    <p
      class="text-white/80 text-base mb-10 max-w-2xl mx-auto leading-relaxed"
      data-i18n="secondaryStructureDesign.cta.body"
    >{ssd.cta.body}</p>
    <a
      href={withBase('/contact#contact-form')}
      class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-secondary/90 btn-press"
      data-i18n="secondaryStructureDesign.cta.button"
    >{ssd.cta.button}</a>
  </div>
</section>
