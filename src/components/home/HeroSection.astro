---
import { en } from '@/i18n/locales/en';
---
<section class="relative min-h-screen flex items-center overflow-hidden blueprint-bg px-8 py-20" aria-label="Hero" id="hero">
  <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

    <!-- Text column -->
    <div class="lg:col-span-7 z-10 flex flex-col">
      <span
        class="font-label text-secondary font-bold tracking-[0.2em] uppercase text-sm mb-6 block"
        data-i18n="hero.eyebrow"
      >
        {en.hero.eyebrow}
      </span>

      <h1 class="font-sans font-black text-5xl lg:text-7xl xl:text-8xl text-primary leading-[0.95] tracking-tight mb-8">
        <span data-i18n="hero.heading1">{en.hero.heading1}</span><br />
        <span class="text-on-surface-variant font-light" data-i18n="hero.heading2">{en.hero.heading2}</span>
      </h1>

      <p class="font-sans text-lg text-on-surface-variant leading-relaxed max-w-xl mb-10" data-i18n="hero.body">
        {en.hero.body}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/404"
          data-i18n="hero.ctaPrimary"
          class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-label font-bold text-sm uppercase tracking-wider text-white bg-primary hover:bg-primary-container active:scale-95 transition-all duration-200"
        >
          {en.hero.ctaPrimary}
        </a>
        <a
          href="/404"
          data-i18n="hero.ctaSecondary"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-label font-bold text-sm uppercase tracking-wider text-primary border border-outline-variant/30 hover:bg-surface-container-low active:scale-95 transition-all duration-200"
        >
          {en.hero.ctaSecondary}
          <span class="material-symbols-outlined text-sm" style="font-size: 16px;">arrow_forward</span>
        </a>
      </div>
    </div>

    <!-- Image column -->
    <div class="lg:col-span-5 relative flex justify-center mt-12 lg:mt-0">
      <div class="relative w-full max-w-sm lg:max-w-none aspect-square">
        <!-- Image frame — square with rounded corners -->
        <div class="relative w-full h-full rounded-2xl overflow-hidden shadow-2xl border-8 border-surface-container-lowest">
          <img
            src="/images/hero-turbine.jpg"
            alt={en.hero.imgAlt}
            data-i18n-attr="alt:hero.imgAlt"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Floating certification card -->
        <div class="absolute -bottom-4 -left-4 lg:-bottom-6 lg:-left-12 bg-surface-container-lowest p-4 lg:p-6 rounded-xl max-w-[220px] lg:max-w-xs border border-outline-variant/10"
          style="box-shadow: 0px 16px 40px rgba(11, 28, 48, 0.12);">
          <div class="flex items-center gap-2 lg:gap-3 mb-2">
            <span class="material-symbols-outlined text-green-700 text-base lg:text-xl" style="font-variation-settings: 'FILL' 1; color: #003c0b;">verified</span>
            <span class="font-label font-bold text-[10px] lg:text-xs uppercase tracking-tighter" data-i18n="hero.certLabel">{en.hero.certLabel}</span>
          </div>
          <p class="text-[10px] lg:text-xs text-on-surface-variant leading-relaxed">
            <span data-i18n="hero.certBodyPrefix">{en.hero.certBodyPrefix}</span> <span class="font-label font-bold">ISO 9001:2015</span>, <span class="font-label font-bold">TÜV</span>, <span class="font-label font-bold">DUN</span>, <span data-i18n="hero.certBodyConjunction">{en.hero.certBodyConjunction}</span> <span class="font-label font-bold">TiSAX</span> <span data-i18n="hero.certBodySuffix">{en.hero.certBodySuffix}</span>
          </p>
        </div>
      </div>
    </div>

  </div>
</section>
