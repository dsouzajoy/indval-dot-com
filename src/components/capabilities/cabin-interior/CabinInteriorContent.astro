  { component: 'Doors and Latches', scope: 'Secondary retention systems for turbulence' },
  { component: 'Cooking Appliances', scope: 'Convection and steam oven inserts' },
  { component: 'Beverage Stations', scope: 'Integrated coffee makers and water boilers' },
  { component: 'Task Lighting', scope: 'Low-power, high-yield LED strip integration' },
  { component: 'Ventilation and Exhaust', scope: 'Odor extraction and air circulation routing' },
  { component: 'Surface Finishes', scope: 'Fire-retardant laminates and Tedlar coatings' },
