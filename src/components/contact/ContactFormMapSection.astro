---
import { feature } from 'topojson-client';
import { geoEquirectangular, geoPath } from 'd3-geo';
import world from 'world-atlas/countries-110m.json';

const land = feature(world as any, (world as any).objects.land);
const projection = geoEquirectangular().scale(127.32).translate([400, 200]);
const pathGen = geoPath(projection);
const landPath = pathGen(land as any);

const phones = [
  { display: '+91 8088887220', tel: '+918088887220' },
  { display: '+48 717079133', tel: '+48717079133' },
  { display: '+1 6615513080', tel: '+16615513080' },
];
---

<section id="contact-form" class="flex flex-col md:flex-row" style="min-height: calc(100vh - 4rem);" aria-label="Contact form and global offices">

  <!-- LEFT: Form Panel -->
  <div class="w-full md:w-1/2 bg-surface-container-lowest flex flex-col justify-center px-8 md:px-16 py-12 md:py-16">

    <h2 class="font-headline font-black text-4xl md:text-5xl leading-tight mb-8 md:mb-12">
      <span class="text-primary">Let's Build </span><span class="text-secondary">Something.</span>
    </h2>

    <form
      id="contact-form-mail"
      class="flex flex-col gap-8"
    >
      <!-- Full Name -->
      <div class="flex flex-col gap-2">
        <label class="font-label text-xs uppercase tracking-[0.2em] text-primary font-bold">Full Name</label>
        <input
          id="contact-name"
          type="text"
          name="Full Name"
          placeholder="e.g. Jane Smith"
          class="border-b-2 border-outline-variant/30 focus:border-primary data-[invalid]:border-red-500 bg-transparent py-3 w-full outline-none transition-colors duration-200 text-on-surface placeholder:text-on-surface-variant/40 font-sans text-base"
        />
        <p id="contact-name-error" class="hidden text-xs text-red-500 font-label mt-1"></p>
      </div>

      <!-- Work Email -->
      <div class="flex flex-col gap-2">
        <label class="font-label text-xs uppercase tracking-[0.2em] text-primary font-bold">Work Email</label>
        <input
          id="contact-email"
          type="email"
          name="Work Email"
          placeholder="e.g. jane@company.com"
          class="border-b-2 border-outline-variant/30 focus:border-primary data-[invalid]:border-red-500 bg-transparent py-3 w-full outline-none transition-colors duration-200 text-on-surface placeholder:text-on-surface-variant/40 font-sans text-base"
        />
        <p id="contact-email-error" class="hidden text-xs text-red-500 font-label mt-1"></p>
      </div>

      <!-- Technical Specifications -->
      <div class="flex flex-col gap-2">
        <label class="font-label text-xs uppercase tracking-[0.2em] text-primary font-bold">Technical Specifications</label>
        <textarea
          id="contact-specs"
          name="Technical Specifications"
          placeholder="Scope of work or RFQ details…"
          rows="4"
          class="border-b-2 border-outline-variant/30 focus:border-primary data-[invalid]:border-red-500 bg-transparent py-3 w-full outline-none transition-colors duration-200 text-on-surface placeholder:text-on-surface-variant/40 font-sans text-base resize-none"
        ></textarea>
        <p id="contact-specs-error" class="hidden text-xs text-red-500 font-label mt-1"></p>
      </div>

      <!-- Submit -->
      <button
        id="contact-submit"
        type="submit"
        class="self-start inline-flex items-center justify-center gap-2 px-8 py-4 rounded text-sm bg-primary text-white font-label font-bold uppercase tracking-wider cursor-pointer hover:bg-primary-container mt-2 btn-press"
      >
        SEND ENQUIRY →
      </button>
    </form>

    <style>
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        15%       { transform: translateX(-5px); }
        30%       { transform: translateX(5px); }
        45%       { transform: translateX(-4px); }
        60%       { transform: translateX(4px); }
        75%       { transform: translateX(-2px); }
        90%       { transform: translateX(2px); }
      }
      .shake { animation: shake 0.4s ease-in-out; }
    </style>

    <script>
      const contactForm = document.getElementById('contact-form-mail') as HTMLFormElement;

      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();

        if (!validateAll()) return;

        const name = nameInput.value.trim();
        const email = emailInput.value.trim();
        const specs = specsInput.value.trim();

        const subject = encodeURIComponent("Enquiry about your services");

        const body = encodeURIComponent(`Hi,

Here are my details:

Name: ${name}

Email: ${email}

Project / Requirement:
${specs}

Looking forward to hearing from you about this enquiry and exploring the next steps.

Thanks,
${name}
        `);

        window.location.href = `mailto:info@indvaltech.com?subject=${subject}&body=${body}`;
      });

      const nameInput  = document.getElementById('contact-name')  as HTMLInputElement;
      const emailInput = document.getElementById('contact-email') as HTMLInputElement;
      const specsInput = document.getElementById('contact-specs') as HTMLTextAreaElement;
      const btn        = document.getElementById('contact-submit') as HTMLButtonElement;

      const nameError  = document.getElementById('contact-name-error')  as HTMLParagraphElement;
      const emailError = document.getElementById('contact-email-error') as HTMLParagraphElement;
      const specsError = document.getElementById('contact-specs-error') as HTMLParagraphElement;

      const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      let submitted = false;

      function validateName()  { return nameInput.value.trim()  === '' ? 'Name is required.' : ''; }
      function validateEmail() {
        const v = emailInput.value.trim();
        if (v === '') return 'Email is required.';
        if (!EMAIL_RE.test(v)) return 'Please enter a valid email address (e.g. jane@company.com).';
        return '';
      }
      function validateSpecs() { return specsInput.value.trim() === '' ? 'Technical specifications are required.' : ''; }

      function applyError(el: HTMLParagraphElement, input: HTMLElement, msg: string) {
        if (msg) {
          el.textContent = msg;
          el.classList.remove('hidden');
          input.setAttribute('data-invalid', '');
        } else {
          el.textContent = '';
          el.classList.add('hidden');
          input.removeAttribute('data-invalid');
        }
      }

      function validateAll() {
        applyError(nameError,  nameInput,  validateName());
        applyError(emailError, emailInput, validateEmail());
        applyError(specsError, specsInput, validateSpecs());
        return validateName() === '' && validateEmail() === '' && validateSpecs() === '';
      }

      function shake(el: HTMLElement) {
        el.classList.remove('shake');
        void el.offsetWidth; // reflow to allow re-triggering
        el.classList.add('shake');
        el.addEventListener('animationend', () => el.classList.remove('shake'), { once: true });
      }

      btn.addEventListener('click', (e) => {
        submitted = true;
        const valid = validateAll();
        if (!valid) {
          e.preventDefault();
          [nameInput, emailInput, specsInput].forEach(f => {
            if (f.hasAttribute('data-invalid')) shake(f);
          });
        }
      });

      [nameInput, emailInput, specsInput].forEach(f =>
        f.addEventListener('input', () => { if (submitted) validateAll(); })
      );
    </script>
  </div>

  <!-- RIGHT: Map + Address Panel -->
  <div class="w-full md:w-1/2 bg-primary flex flex-col md:h-auto">

    <!-- Decorative badge -->
    <div class="px-8 pt-8 flex justify-end shrink-0">
      <span class="text-secondary border border-secondary/40 text-xs font-label px-3 py-1 tracking-widest uppercase">
        Reach Out Anytime
      </span>
    </div>

    <!-- SVG World Map -->
    <div class="h-64 md:h-auto md:flex-1 min-h-0 overflow-hidden">
      <svg
        viewBox="0 0 800 400"
        preserveAspectRatio="xMidYMid slice"
        class="w-full h-full"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <defs>
          <!-- Dot grid pattern -->
          <pattern id="contact-dots" width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="10" cy="10" r="0.8" fill="rgba(255,255,255,0.07)" />
          </pattern>
        </defs>

        <!-- Background -->
        <rect width="800" height="400" fill="#00316c" />

        <!-- Subtle lat/lon grid lines -->
        <!-- Latitudes: 60°N y=67, 30°N y=133, 0° y=200, 30°S y=267, 60°S y=333 -->
        <line x1="0" y1="67" x2="800" y2="67" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="0" y1="133" x2="800" y2="133" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="0" y1="200" x2="800" y2="200" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
        <line x1="0" y1="267" x2="800" y2="267" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <!-- Longitudes: 120°W x=133, 60°W x=267, 0° x=400, 60°E x=533, 120°E x=667 -->
        <line x1="133" y1="0" x2="133" y2="400" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="267" y1="0" x2="267" y2="400" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="400" y1="0" x2="400" y2="400" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
        <line x1="533" y1="0" x2="533" y2="400" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
        <line x1="667" y1="0" x2="667" y2="400" stroke="rgba(255,255,255,0.04)" stroke-width="1" />

        <!-- Dot grid overlay -->
        <rect width="800" height="400" fill="url(#contact-dots)" />

        <!-- ── CONTINENTS (Natural Earth 110m, equirectangular) ────────── -->
        <path
          d={landPath}
          fill="rgba(11,71,147,0.5)"
          stroke="rgba(255,255,255,0.18)"
          stroke-width="0.5"
        />

        <!-- ── CONNECTION LINES ─────────────────────────────────────────── -->
        <!-- Bangalore ↔ Valencia CA -->
        <line x1="572" y1="171" x2="136" y2="123" stroke="rgba(255,103,31,0.18)" stroke-width="1" stroke-dasharray="5 5" />
        <!-- Bangalore ↔ Wrocław -->
        <line x1="572" y1="171" x2="438" y2="86" stroke="rgba(255,103,31,0.18)" stroke-width="1" stroke-dasharray="5 5" />
        <!-- Valencia CA ↔ Wrocław -->
        <line x1="136" y1="123" x2="438" y2="86" stroke="rgba(255,103,31,0.18)" stroke-width="1" stroke-dasharray="5 5" />

        <!-- ── CITY MARKERS ─────────────────────────────────────────────── -->

        <!-- Bangalore (77.6°E, 12.9°N) → SVG (572, 171) -->
        <g>
          <circle cx="572" cy="171" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.6">
            <animate attributeName="r" from="4" to="22" dur="2.5s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.6" to="0" dur="2.5s" repeatCount="indefinite" />
          </circle>
          <circle cx="572" cy="171" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.4">
            <animate attributeName="r" from="4" to="22" dur="2.5s" begin="0.9s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.4" to="0" dur="2.5s" begin="0.9s" repeatCount="indefinite" />
          </circle>
          <circle cx="572" cy="171" r="4" fill="#ff671f" />
          <text x="582" y="168" fill="rgba(255,255,255,0.88)" font-size="9" font-family="Space Grotesk, sans-serif" letter-spacing="0.12em" font-weight="600">BENGALURU, INDIA</text>
        </g>

        <!-- Valencia CA (118.6°W, 34.4°N) → SVG (136, 123) -->
        <g>
          <circle cx="136" cy="123" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.6">
            <animate attributeName="r" from="4" to="22" dur="2.5s" begin="0.4s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.6" to="0" dur="2.5s" begin="0.4s" repeatCount="indefinite" />
          </circle>
          <circle cx="136" cy="123" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.4">
            <animate attributeName="r" from="4" to="22" dur="2.5s" begin="1.3s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.4" to="0" dur="2.5s" begin="1.3s" repeatCount="indefinite" />
          </circle>
          <circle cx="136" cy="123" r="4" fill="#ff671f" />
          <text x="146" y="116" fill="rgba(255,255,255,0.88)" font-size="9" font-family="Space Grotesk, sans-serif" letter-spacing="0.12em" font-weight="600">CALIFORNIA, USA</text>
        </g>

        <!-- Wrocław (17°E, 51.1°N) → SVG (438, 86) -->
        <g>
          <circle cx="438" cy="86" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.6">
            <animate attributeName="r" from="4" to="22" dur="2.5s" begin="0.8s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.6" to="0" dur="2.5s" begin="0.8s" repeatCount="indefinite" />
          </circle>
          <circle cx="438" cy="86" r="4" fill="none" stroke="#ff671f" stroke-opacity="0.4">
            <animate attributeName="r" from="4" to="22" dur="2.5s" begin="1.7s" repeatCount="indefinite" />
            <animate attributeName="stroke-opacity" from="0.4" to="0" dur="2.5s" begin="1.7s" repeatCount="indefinite" />
          </circle>
          <circle cx="438" cy="86" r="4" fill="#ff671f" />
          <text x="448" y="83" fill="rgba(255,255,255,0.88)" font-size="9" font-family="Space Grotesk, sans-serif" letter-spacing="0.12em" font-weight="600">WROCŁAW, POLAND</text>
        </g>

      </svg>
    </div>

    <!-- Address Grid (2×2) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 shrink-0" style="background-color: #001a40;">

      <!-- Divider line at top -->
      <div class="col-span-1 lg:col-span-2 h-px" style="background: rgba(255,255,255,0.08);"></div>

      <!-- Cell 1: HQ Address -->
      <div class="p-6 border-b lg:border-r order-1 lg:order-none" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-secondary text-xs font-label uppercase tracking-widest mb-2">HQ — Bengaluru, India</p>
        <p class="text-white text-xs leading-relaxed">
          Indval Technologies Private Limited<br />
          #181, 3rd Floor, Outer Ring Road<br />
          Nagarbhavi BDA Complex, 2nd Stage<br />
          Nagarbhavi, Bengaluru — 560072
        </p>
        <a
          href="https://maps.app.goo.gl/AKYnrs1VYDsCrm786"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-secondary text-xs font-label uppercase tracking-wider mt-3 hover:opacity-80 transition-opacity duration-200"
        >
          View on Map →
        </a>
      </div>

      <!-- Cell 2: Contact -->
      <div class="p-6 lg:border-b order-4 lg:order-none" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-secondary text-xs font-label uppercase tracking-widest mb-3">Contact</p>
        <div class="flex flex-col gap-3">
          <a
            href="mailto:info@indvaltech.com"
            class="inline-flex items-center gap-2 text-white text-xs hover:text-secondary transition-colors duration-200 break-all"
          >
            <span class="material-symbols-outlined text-secondary shrink-0" style="font-size: 1em;">mail</span>
            <span>info@indvaltech.com</span>
          </a>
          <div class="flex flex-col gap-2">
            {phones.map(({ display, tel }) => (
              <a
                href={`tel:${tel}`}
                class="inline-flex items-center gap-2 text-white text-xs hover:text-secondary transition-colors duration-200"
              >
                <span class="material-symbols-outlined text-secondary shrink-0" style="font-size: 1em;">phone</span>
                <span>{display}</span>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Cell 3: USA -->
      <div class="p-6 border-b lg:border-b-0 lg:border-r order-2 lg:order-none" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-secondary text-xs font-label uppercase tracking-widest mb-2">USA — Valencia, California</p>
        <p class="text-white text-xs leading-relaxed">
          Regent Indval Engineering Services LLC<br />
          28110 W Harrison Parkway<br />
          Valencia, CA 91355
        </p>
        <a
          href="https://maps.app.goo.gl/gnhKiixM7rxnQLxw9"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-secondary text-xs font-label uppercase tracking-wider mt-3 hover:opacity-80 transition-opacity duration-200"
        >
          View on Map →
        </a>
      </div>

      <!-- Cell 4: Poland -->
      <div class="p-6 border-b lg:border-b-0 order-3 lg:order-none" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-secondary text-xs font-label uppercase tracking-widest mb-2">Europe — Wrocław, Poland</p>
        <p class="text-white text-xs leading-relaxed">
          Indval Technologies Sp. z o.o.<br />
          Ul. Marsz. Józefa Piłsudskiego 74/320<br />
          50-020 Wrocław, Lower Silesia, Poland<br />
          KRS: 0001238201 | NIP: 8971971294
        </p>
        <a
          href="https://maps.app.goo.gl/pm8Qi4Jp6iJ1XrXy8"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-secondary text-xs font-label uppercase tracking-wider mt-3 hover:opacity-80 transition-opacity duration-200"
        >
          View on Map →
        </a>
      </div>

    </div>

  </div>

</section>
