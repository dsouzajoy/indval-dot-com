---
import { withBase } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  canonicalURL: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage = '/images/og-default.webp' } = Astro.props;

// Base-aware, absolute URL for social cards.
const ogImageURL = new URL(withBase(ogImage), Astro.site).toString();

// Base-aware font paths.
const interFont = withBase('/fonts/inter-variable.woff2');
const spaceGroteskFont = withBase('/fonts/space-grotesk-variable.woff2');
const materialSymbolsFont = withBase('/fonts/material-symbols-outlined.woff2');

const fontFaceCss = `
@font-face{font-family:'Inter';src:url('${interFont}') format('woff2');font-weight:100 900;font-style:normal;font-display:swap;}
@font-face{font-family:'Space Grotesk';src:url('${spaceGroteskFont}') format('woff2');font-weight:300 700;font-style:normal;font-display:swap;}
@font-face{font-family:'Material Symbols Outlined';src:url('${materialSymbolsFont}') format('woff2');font-weight:100 700;font-style:normal;font-display:block;}
`;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content="website" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- TODO: add google-site-verification meta tag once client provides the Search Console token -->

<!-- Font face declarations (base-aware) -->
<style is:inline set:html={fontFaceCss}></style>

<!-- Font preload -->
<link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={spaceGroteskFont} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={materialSymbolsFont} as="font" type="font/woff2" crossorigin />

<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
<meta name="generator" content={Astro.generator} />
