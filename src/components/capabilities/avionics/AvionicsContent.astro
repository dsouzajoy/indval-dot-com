---

<!-- INTRO -->
<section class="bg-surface">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="avionics.intro.eyebrow"
      >{av.intro.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary text-balance"
        data-i18n="avionics.intro.heading"
      >{av.intro.heading}</h2>
      <p
        class="mt-6 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="avionics.intro.para1"
      >{av.intro.para1}</p>
      <p
        class="mt-5 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="avionics.intro.para2"
      >{av.intro.para2}</p>
      <ul class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
        {av.intro.examples.map((item, j) => (
          <li class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-secondary shrink-0 text-lg leading-relaxed" style="font-variation-settings: 'FILL' 1" aria-hidden="true">check_circle</span>
            <span class="text-sm text-on-surface-variant leading-relaxed" data-i18n={`avionics.intro.examples.${j}`}>{item}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="rounded overflow-hidden shadow-lg aspect-[4/3]">
      <Image
        src={introImg}
        alt="Close-up view of an airplane cockpit window and avionics panel"
        format="avif"
        quality={100}
        width={800}
        height={600}
        loading="eager"
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</section>

<!-- CAPABILITIES (TABS) -->
<section id="capabilities" class="bg-surface-container-low py-24 lg:py-30" style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">

    <div class="mb-14 max-w-2xl">
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">Core Competencies</p>
      <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mt-2">
        Our Avionics Engineering Capabilities
      </h2>
    </div>

    <!-- Tab bar -->
    <div class="relative">
      <div class="absolute right-0 top-0 h-full w-16 bg-gradient-to-l from-surface-container-low to-transparent pointer-events-none z-10"></div>
      <div id="av-tab-scroll-container" class="flex border-b border-outline-variant overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
        {tabs.map((tab, i) => (
          <button
            data-tab={i}
            class={`av-tab-btn font-label text-sm uppercase tracking-wider py-3 px-5 border-b-2 whitespace-nowrap transition-colors duration-200 shrink-0 cursor-pointer ${
              i === 0
                ? 'border-secondary text-primary font-bold'
                : 'border-transparent text-on-surface-variant hover:text-primary'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Tab panels -->
    <div class="relative mt-10">
      {tabs.map((tab, i) => (
        <div
          data-panel={i}
          class={`av-tab-panel grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center transition-opacity duration-150 ${
            i === 0 ? 'relative opacity-100 pointer-events-auto' : 'absolute top-0 left-0 right-0 opacity-0 pointer-events-none'
          }`}
        >
          <div class="space-y-6">
            <h3 class="font-headline font-bold text-3xl text-on-surface">{tab.heading}</h3>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
              {tab.bullets.map((bullet) => (
                <li class="flex gap-3 items-start">
                  <span
                    class="material-symbols-outlined text-secondary shrink-0 text-xl leading-relaxed"
                    style="font-variation-settings: 'FILL' 1"
                    aria-hidden="true"
                  >check_circle</span>
                  <span class="text-sm text-on-surface-variant leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded overflow-hidden aspect-video">
            <Image
              src={tab.image}
              alt={`${tab.heading} engineering capability`}
              format="avif"
              quality={100}
              width={1200}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const avTabBtns = document.querySelectorAll<HTMLButtonElement>('.av-tab-btn');
  const avTabPanels = document.querySelectorAll<HTMLElement>('.av-tab-panel');

  function activateAvTab(index: number) {
    avTabBtns.forEach((btn) => {
      const isActive = Number(btn.dataset.tab) === index;
      btn.classList.toggle('border-secondary', isActive);
      btn.classList.toggle('text-primary', isActive);
      btn.classList.toggle('font-bold', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-on-surface-variant', !isActive);
    });

    avTabPanels.forEach((panel, i) => {
      const isActive = i === index;
      panel.classList.toggle('relative', isActive);
      panel.classList.toggle('opacity-100', isActive);
      panel.classList.toggle('pointer-events-auto', isActive);
      panel.classList.toggle('absolute', !isActive);
      panel.classList.toggle('top-0', !isActive);
      panel.classList.toggle('left-0', !isActive);
      panel.classList.toggle('right-0', !isActive);
      panel.classList.toggle('opacity-0', !isActive);
      panel.classList.toggle('pointer-events-none', !isActive);
    });
  }

  avTabBtns.forEach((btn) => {
    btn.addEventListener('click', () => activateAvTab(Number(btn.dataset.tab)));
  });

  const avTabScrollContainer = document.getElementById('av-tab-scroll-container');
  if (avTabScrollContainer) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.disconnect();
          setTimeout(() => {
            avTabScrollContainer.scrollTo({ left: avTabScrollContainer.scrollWidth, behavior: 'smooth' });
            setTimeout(() => {
              avTabScrollContainer.scrollTo({ left: 0, behavior: 'smooth' });
            }, 900);
          }, 400);
        }
      });
    }, { threshold: 0.3 });

    const section = document.getElementById('capabilities');
    if (section) observer.observe(section);
  }
</script>

<!-- CERTIFICATION & PROGRAM EXPERIENCE -->
<section class="bg-surface py-24 border-t border-outline-variant">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="rounded overflow-hidden shadow-lg aspect-[4/3] lg:order-2">
      <Image
        src={certificationImg}
        alt="Engineers reviewing certification documentation and compliance records"
        format="avif"
        quality={100}
        width={800}
        height={600}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
    <div class="lg:order-1">
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">Certification Experience</p>
      <h2 class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary text-balance">
        Stage of Involvement Audits and Expert Services
      </h2>

      <h3 class="mt-8 text-sm font-bold uppercase tracking-wider text-on-surface">Stage of Involvement (SOI) Audits</h3>
      <ul class="mt-4 space-y-3">
        {soiAudits.map((item) => (
          <li class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-secondary shrink-0 text-lg leading-relaxed" style="font-variation-settings: 'FILL' 1" aria-hidden="true">check_circle</span>
            <span class="text-sm text-on-surface-variant leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>

      <h3 class="mt-8 text-sm font-bold uppercase tracking-wider text-on-surface">Expert Services Offered</h3>
      <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
        {expertServices.map((item) => (
          <li class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-secondary shrink-0 text-lg leading-relaxed" style="font-variation-settings: 'FILL' 1" aria-hidden="true">check_circle</span>
            <span class="text-sm text-on-surface-variant leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- AVIONICS SYSTEMS WORKED ON (COMPONENT TABLE) -->
<section class="bg-surface-container-low py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] lg:grid-rows-[auto_1fr] gap-x-12 lg:gap-x-16 gap-y-6">
    <div class="lg:col-start-1 lg:row-start-1">
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">Program Experience</p>
      <h2 class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary">
        Avionics Systems Worked On
      </h2>
    </div>

    <div class="aspect-[3/2] rounded overflow-hidden lg:col-start-2 lg:row-start-2">
      <Image
        src={systemsWorkedOnImg}
        alt="Commercial airliner in flight"
        format="avif"
        quality={100}
        width={1200}
        height={800}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>

    <div class="h-full lg:col-start-1 lg:row-start-2">
      <div class="h-full overflow-x-auto">
        <table class="h-full w-full min-w-[480px] rounded-[4px] overflow-hidden border border-outline-variant shadow-ambient bg-surface border-separate border-spacing-0">
          <thead>
            <tr>
              <th scope="col" class="px-5 py-2.5 text-left font-label text-xs uppercase tracking-widest text-on-surface-variant/60 font-bold border-b-2 border-secondary/40">
                System
              </th>
              <th scope="col" class="px-5 py-2.5 text-left font-label text-xs uppercase tracking-widest text-on-surface-variant/60 font-bold border-b-2 border-secondary/40">
                Program
              </th>
            </tr>
          </thead>
          <tbody>
            {systemsWorkedOn.map((row, i) => (
              <tr class:list={[i % 2 === 0 ? 'bg-surface' : 'bg-surface-container-low', i > 0 && 'border-t border-outline-variant']}>
                <td class="px-5 py-2.5 align-middle whitespace-nowrap">
                  <span class="flex items-center gap-2.5">
                    <span class="w-1 h-3 rounded-full bg-secondary shrink-0" aria-hidden="true"></span>
                    <span class="font-headline font-bold text-xs text-primary">{row.system}</span>
                  </span>
                </td>
                <td class="px-5 py-2.5 align-middle text-xs text-on-surface-variant leading-snug">
                  {row.program}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- SDLC ENGINEERING PROCESS -->
<section class="bg-surface py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-14 max-w-2xl">
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">How We Work</p>
      <h2 class="mt-2 text-3xl lg:text-4xl font-bold tracking-tight text-primary">
        Our SDLC Engineering Process
      </h2>
    </div>
    <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12">
      {sdlcPhases.map(({ num, title, description }) => (
        <li class="flex gap-5">
          <span class="font-headline text-4xl font-black leading-none tabular-nums text-secondary/90 shrink-0 pt-1">{num}</span>
          <div>
            <h3 class="text-lg font-bold tracking-tight text-on-surface">{title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-on-surface-variant">{description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<!-- INDUSTRIES WE SERVE -->
<section class="bg-surface-container-low py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-14">
      <p class="font-label font-bold text-sm uppercase tracking-widest text-secondary">Who We Work With</p>
      <h2 class="mt-2 text-3xl lg:text-4xl font-bold tracking-tight text-primary">Industries We Serve</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: numbered list -->
      <ul class="space-y-1">
        {industries.map(({ num, title, desc }, i) => (
          <li
            data-industry={i}
            class={`av-industry-item flex gap-5 items-start py-5 px-4 rounded cursor-default transition-all duration-300 ${i === 0 ? 'bg-surface shadow-sm' : ''}`}
          >
            <span class={`font-headline text-5xl font-black leading-none tabular-nums shrink-0 transition-colors duration-300 ${i === 0 ? 'text-secondary' : 'text-outline'}`}>{num}</span>
            <div class="pt-1">
              <h3 class={`text-lg font-bold tracking-tight transition-colors duration-300 ${i === 0 ? 'text-primary' : 'text-on-surface-variant'}`}>{title}</h3>
              <p class={`text-sm leading-relaxed mt-1 transition-colors duration-300 ${i === 0 ? 'text-on-surface-variant' : 'text-on-surface-variant/60'}`}>{desc}</p>
            </div>
          </li>
        ))}
      </ul>

      <!-- Right: image swap panel -->
      <div class="relative aspect-[4/3] rounded overflow-hidden shadow-xl">
        {industries.map(({ image, alt }, i) => (
          <Image
            data-industry-img={i}
            src={image}
            alt={alt}
            format="avif"
            quality={100}
            width={900}
            class={`av-industry-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
            loading="lazy"
          />
        ))}
        <div class="absolute inset-0 bg-gradient-to-t from-on-surface/30 to-transparent pointer-events-none"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const avIndustryItems = document.querySelectorAll<HTMLElement>('.av-industry-item');
  const avIndustryImgs = document.querySelectorAll<HTMLElement>('.av-industry-img');

  function activateAvIndustry(idx: number) {
    avIndustryItems.forEach((item, i) => {
      const isActive = i === idx;
      item.classList.toggle('bg-surface', isActive);
      item.classList.toggle('shadow-sm', isActive);
      const num = item.querySelector('span');
      if (num) {
        num.classList.toggle('text-secondary', isActive);
        num.classList.toggle('text-outline', !isActive);
      }
      const h3 = item.querySelector('h3');
      if (h3) {
        h3.classList.toggle('text-primary', isActive);
        h3.classList.toggle('text-on-surface-variant', !isActive);
      }
      const p = item.querySelector('p');
      if (p) {
        p.classList.toggle('text-on-surface-variant', isActive);
        p.classList.toggle('text-on-surface-variant/70', !isActive);
      }
    });
    avIndustryImgs.forEach((img, i) => {
      img.classList.toggle('opacity-100', i === idx);
      img.classList.toggle('opacity-0', i !== idx);
    });
  }

  avIndustryItems.forEach((item, i) => {
    item.addEventListener('mouseenter', () => activateAvIndustry(i));
  });
</script>

<!-- WHY CHOOSE US -->
<section class="relative bg-on-surface overflow-hidden">
