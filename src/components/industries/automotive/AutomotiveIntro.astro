---
import { withBase } from '@/lib/utils';
---

<section class="pt-24 pb-0 px-8 max-w-7xl mx-auto text-center" aria-label="Automotive industry">
  <div class="inline-block px-4 py-1.5 mb-6 bg-surface-container-high text-primary font-label text-xs tracking-[0.2em] uppercase rounded-full">
    Industry Focus
  </div>

  <h1 class="text-5xl md:text-6xl font-headline font-black text-primary tracking-tight mb-6 max-w-3xl mx-auto leading-none">
    Automotive
  </h1>

  <p class="text-on-surface-variant text-lg max-w-2xl mx-auto font-body leading-relaxed">
    Precision design and development of cockpit systems, exterior assemblies,
    and interior trims for global automotive programmes.
  </p>

  <div class="mt-8 mx-auto max-w-[900px]">
    <img
      src={withBase('/images/automotive-hero.png')}
      alt="Automotive vehicle systems diagram showing cockpit, HVAC, seating, and exterior components"
      class="w-full object-contain"
      style="mix-blend-mode: multiply;"
      loading="eager"
    />
  </div>
</section>
