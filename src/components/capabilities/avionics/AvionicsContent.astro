const whyUs = [
  { icon: 'route', title: 'End-to-End Avionics Expertise', desc: av.whyUs.endToEndExpertise },
  { icon: 'verified', title: 'Safety and Compliance Focus', desc: av.whyUs.safetyAndCompliance },
  { icon: 'hub', title: 'Systems Integration Excellence', desc: av.whyUs.systemsIntegration },
  { icon: 'engineering', title: 'Advanced Engineering Capabilities', desc: av.whyUs.advancedCapabilities },
  { icon: 'bolt', title: 'Accelerated Development', desc: av.whyUs.acceleratedDevelopment },
