---
const navLinks = [
  { label: 'Services',   href: '/404' },
  { label: 'Industries', href: '/404' },
  { label: 'Quality',    href: '/404' },
  { label: 'Company',    href: '/404' },
  { label: 'Careers',    href: '/404' },
];
---
<nav aria-label="Main navigation">
  <ul class="flex gap-8 list-none m-0 p-0">
    {navLinks.map(({ label, href }) => (
      <li>
        <a
          href={href}
          class="font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
