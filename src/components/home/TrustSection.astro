---
import { en } from '@/i18n/locales/en';

const logos = [
  { src: '/images/partners/air-india.svg', alt: 'Air India' },
  { src: '/images/partners/ford.png',      alt: 'Ford' },
  { src: '/images/partners/newag.png',     alt: 'Newag Group' },
  { src: '/images/partners/caterpillar.png', alt: 'Caterpillar' },
  { src: '/images/partners/siemens.png',   alt: 'Siemens' },
];
---
<section class="py-20 bg-surface-container-lowest" aria-label="Trusted clients">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <p
      class="font-label text-[10px] text-on-surface-variant text-center uppercase tracking-[0.4em] mb-12"
      data-i18n="trust.heading"
    >
      {en.trust.heading}
    </p>

    <div class="flex flex-wrap justify-center items-center gap-12 lg:gap-16">
      {logos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-5 lg:h-7 w-auto object-contain opacity-50 grayscale hover:opacity-80 transition-all duration-300"
          loading="lazy"
          draggable="false"
        />
      ))}
    </div>

  </div>
</section>
