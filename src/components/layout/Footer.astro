---
import { en } from '@/i18n/locales/en';
import { Image } from 'astro:assets';
import { withBase } from '@/lib/utils';
import logoImg from '@/assets/images/logo.png';
import certIsoQualityImg from '@/assets/images/cert-iso-quality.png';
import certIsoInfosecImg from '@/assets/images/cert-iso-infosec.png';
import certDunsImg from '@/assets/images/cert-duns.png';

const industries = [
  { label: en.industries.aerospace.title,  href: '/industries/aerospace',  i18nKey: 'industries.aerospace.title'  },
  { label: en.industries.automotive.title, href: '/industries/automotive', i18nKey: 'industries.automotive.title' },
  { label: en.industries.locomotive.title, href: '/industries/locomotive', i18nKey: 'industries.locomotive.title' },
  { label: en.industries.offHighway.title, href: '/industries/off-highway', i18nKey: 'industries.offHighway.title' },
  { label: en.industries.general.title,    href: '/industries/general',    i18nKey: 'industries.general.title'    },
];

const services = [
  { label: en.capabilities.engineeringAnalysis.fea,          href: '/capabilities/fea',                    i18nKey: 'capabilities.engineeringAnalysis.fea'          },
  { label: en.capabilities.engineeringAnalysis.cfd,          href: '/capabilities/cfd',                    i18nKey: 'capabilities.engineeringAnalysis.cfd'          },
  { label: en.capabilities.manufacturing.heading,            href: '/capabilities/manufacturing',          i18nKey: 'capabilities.manufacturing.heading'            },
  { label: en.capabilities.biwTurnkey.heading,               href: '/capabilities/biw-turnkey-solutions',  i18nKey: 'capabilities.biwTurnkey.heading'               },
  { label: en.capabilities.mechanicalDesign.pressToolDesign, href: '/capabilities/press-tool-design',      i18nKey: 'capabilities.mechanicalDesign.pressToolDesign' },
  { label: en.capabilities.mechanicalDesign.specialMachineDesign, href: '/capabilities/special-machine-design', i18nKey: 'capabilities.mechanicalDesign.specialMachineDesign' },
  { label: en.capabilities.mechanicalDesign.secondaryStructureDesign, href: '/capabilities/secondary-structure-design', i18nKey: 'capabilities.mechanicalDesign.secondaryStructureDesign' },
  { label: en.capabilities.mechanicalDesign.toolingDesign,    href: '/capabilities/tooling-design',          i18nKey: 'capabilities.mechanicalDesign.toolingDesign'   },
  { label: en.capabilities.reverseEngineering.heading,       href: '/capabilities/reverse-engineering',    i18nKey: 'capabilities.reverseEngineering.heading'       },
  { label: en.capabilities.technicalPublication.heading,     href: '/capabilities/technical-publication',  i18nKey: 'capabilities.technicalPublication.heading'     },
  { label: en.capabilities.electricalHarnessDesign.heading, href: '/capabilities/electrical-harness-design', i18nKey: 'capabilities.electricalHarnessDesign.heading' },
  { label: en.capabilities.mroServices.heading,            href: '/capabilities/mro-services',              i18nKey: 'capabilities.mroServices.heading'              },
  { label: en.capabilities.cabinInterior.heading,          href: '/capabilities/cabin-interior',            i18nKey: 'capabilities.cabinInterior.heading'            },
  { label: en.capabilities.mechanicalDesign.productDevelopment, href: '/capabilities/product-development', i18nKey: 'capabilities.mechanicalDesign.productDevelopment' },
  { label: 'Composite Design Solutions',                   href: '/capabilities/composite-design' },
];

const year = new Date().getFullYear();
---
<footer role="contentinfo" class="bg-primary text-white">

  <!-- Main grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="inline-flex items-center gap-3 mb-4">
          <Image src={logoImg} alt="Indvaltech" format="avif" loading="lazy" class="h-12 w-auto shrink-0" />
          <span class="h-9 w-px bg-white/30 shrink-0"></span>
          <span class="font-label tracking-tight leading-none flex flex-col">
            <span class="text-xl font-bold"><span class="text-secondary">INDVAL</span><span class="text-white">TECH</span></span>
            <span class="text-[0.46rem] font-medium text-slate-400 tracking-[0.12em] uppercase mt-0.5">Engineering Excellence</span>
          </span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xs" data-i18n="footer.brand">
          {en.footer.brand}
        </p>
      </div>

      <!-- Industries + Company -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.industriesHeading">
          {en.footer.industriesHeading}
        </h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {industries.map(({ label, href, i18nKey }) => (
            <li>
              <a href={withBase(href)} data-i18n={i18nKey} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mt-8 mb-5" data-i18n="footer.companyHeading">
          {en.footer.companyHeading}
        </h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          <li>
            <a href={withBase('/about')} data-i18n="nav.aboutUs" class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
              {en.nav.aboutUs}
            </a>
          </li>
          <li>
            <a href={withBase('/life')} data-i18n="nav.lifeAtIndvaltech" class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
              {en.nav.lifeAtIndvaltech}
            </a>
          </li>
          <li>
            <a href={withBase('/business-model')} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
              Business Model
            </a>
          </li>
          <li>
            <a href={withBase('/academia')} data-i18n="nav.academia" class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
              {en.nav.academia}
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.servicesHeading">
          {en.footer.servicesHeading}
        </h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {services.map(({ label, href, i18nKey }) => (
            <li>
              <a href={withBase(href)} data-i18n={i18nKey} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Get In Touch -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5" data-i18n="footer.getInTouchHeading">
          {en.footer.getInTouchHeading}
        </h3>
        <div class="flex flex-col gap-4 mb-6">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary shrink-0 text-base" style="font-variation-settings: 'FILL' 1;">mail</span>
            <a href="mailto:info@indvaltech.com" class="text-sm text-slate-400 hover:text-white transition-colors duration-200">info@indvaltech.com</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary shrink-0 text-base" style="font-variation-settings: 'FILL' 1;">phone</span>
            <a href="tel:+918088887220" class="text-sm text-slate-400 hover:text-white transition-colors duration-200">+91 8088887220</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary shrink-0 text-base" style="font-variation-settings: 'FILL' 1;">phone</span>
            <a href="tel:+48717079133" class="text-sm text-slate-400 hover:text-white transition-colors duration-200">+48 717079133</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary shrink-0 text-base" style="font-variation-settings: 'FILL' 1;">phone</span>
            <a href="tel:+16615513080" class="text-sm text-slate-400 hover:text-white transition-colors duration-200">+1 6615513080</a>
          </div>
        </div>
        <a
          href={withBase('/contact#contact-form')}
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-secondary text-white font-label font-bold text-sm uppercase tracking-wider cursor-pointer hover:bg-secondary/90 rounded btn-press"
          data-i18n="footer.getInTouchCta"
        >
          {en.footer.getInTouchCta}
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
        <div class="flex items-center gap-5 mt-10">
          <a href="https://www.linkedin.com/company/indval-technologies-private-limited/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-400 hover:text-white transition-colors duration-200">
            <svg viewBox="0 0 24 24" class="w-6 h-6 fill-current" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Certifications bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex items-center justify-center gap-8">
      <a href={withBase('/docs/iso-9001-certificate.pdf')} target="_blank" rel="noopener noreferrer" class="inline-flex">
        <Image src={certIsoQualityImg} alt="ISO 9001 Quality Certification" format="avif" width={200} loading="lazy" class="h-24 w-24 object-contain" />
      </a>
      <Image src={certIsoInfosecImg} alt="ISO 27001 Information Security Certification" format="avif" width={200} loading="lazy" class="h-[108px] w-[108px] object-contain" />
      <a href={withBase('/docs/duns-certificate.pdf')} target="_blank" rel="noopener noreferrer" class="inline-flex">
        <Image src={certDunsImg} alt="DUNS Certification" format="avif" width={200} loading="lazy" class="h-36 w-36 object-contain" />
      </a>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p
        class="font-label text-[10px] uppercase tracking-widest text-slate-400"
        data-i18n="footer.copyright"
        data-i18n-vars={`{"year":"${year}"}`}
      >
        © {year} Indvaltech. Precision Guaranteed.
      </p>
      <nav aria-label="Legal" class="flex items-center gap-5 flex-wrap justify-center">
        <a href={withBase('/privacy')} class="font-label text-[10px] uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors duration-200" data-i18n="legal.footer.privacy">{en.legal.footer.privacy}</a>
        <a href={withBase('/terms')} class="font-label text-[10px] uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors duration-200" data-i18n="legal.footer.terms">{en.legal.footer.terms}</a>
        <a href={withBase('/cookies')} class="font-label text-[10px] uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors duration-200" data-i18n="legal.footer.cookies">{en.legal.footer.cookies}</a>
        <button
          onclick="window.dispatchEvent(new Event('indval:showCookieBanner'))"
          class="font-label text-[10px] uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors duration-200 bg-transparent border-none p-0 cursor-pointer"
          data-i18n="legal.footer.cookiePreferences"
        >{en.legal.footer.cookiePreferences}</button>
      </nav>
    </div>
  </div>

</footer>
