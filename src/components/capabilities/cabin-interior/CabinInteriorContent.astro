</section>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const sections = document.querySelectorAll<HTMLElement>('.eng-spec-section');

  // --- Stat counter (odometer digit roll) ---
  type SlotState = { curr: HTMLElement; nxt: HTMLElement; lineH: number; target: number };

  const setupCounter = (el: HTMLElement): SlotState => {
    const target = parseInt(el.dataset.count!, 10);
    el.textContent = '';
    el.style.display = 'inline-flex';
    el.style.alignItems = 'baseline';

    const slotWrap = document.createElement('span');
    slotWrap.style.cssText = 'display:inline-block;overflow:hidden;position:relative;';

    const curr = document.createElement('span');
    curr.style.cssText = 'display:block;position:absolute;top:0;left:0;right:0;text-align:left;';
    curr.textContent = '0';

    const nxt = document.createElement('span');
    nxt.style.cssText = 'display:block;position:absolute;left:0;right:0;text-align:left;';

    const spacer = document.createElement('span');
    spacer.setAttribute('aria-hidden', 'true');
    spacer.style.cssText = 'display:block;visibility:hidden;pointer-events:none;';
    spacer.textContent = String(target);

    slotWrap.append(curr, nxt, spacer);
    el.appendChild(slotWrap);

    const lineH = spacer.offsetHeight;
    slotWrap.style.height = `${lineH}px`;
    nxt.style.top = `${lineH}px`;

    return { curr, nxt, lineH, target };
  };

  const animateCounter = ({ curr, nxt, lineH, target }: SlotState) => {
    const TARGET_FLIPS = 12;
    const stepSize = Math.max(1, Math.ceil(target / TARGET_FLIPS));

    const steps: number[] = [];
    for (let v = stepSize; v < target; v += stepSize) steps.push(v);
    steps.push(target);

    const totalSteps = steps.length;
    const endTimes: number[] = [];
    let cumulative = 0;
    for (let i = 0; i < totalSteps; i++) {
      const t = totalSteps > 1 ? i / (totalSteps - 1) : 1;
      cumulative += 55 + t ** 2 * 80;
      endTimes.push(cumulative);
    }

    let startTime: number | null = null;

    const frame = (now: number) => {
      if (startTime === null) startTime = now;
      const elapsed = now - startTime;

      if (elapsed >= endTimes[totalSteps - 1]) {
        curr.textContent = String(target);
        curr.style.transform = 'translateY(0)';
        nxt.style.transform = `translateY(${lineH}px)`;
        nxt.textContent = '';
        return;
      }

      let i = 0;
      while (i < totalSteps - 1 && endTimes[i] <= elapsed) i++;

      const stepStart = i === 0 ? 0 : endTimes[i - 1];
      const stepDuration = endTimes[i] - stepStart;
      const t = (elapsed - stepStart) / stepDuration;
      const eased = 1 - (1 - t) ** 2;

      curr.textContent = String(i === 0 ? 0 : steps[i - 1]);
      nxt.textContent = String(steps[i]);
      curr.style.transform = `translateY(${-eased * lineH}px)`;
      nxt.style.transform = `translateY(${-eased * lineH}px)`;

      requestAnimationFrame(frame);
    };

    requestAnimationFrame(frame);
  };

  // --- Reveal: spec rows stagger in, image settles in ---
  const revealSection = (section: HTMLElement) => {
    if (reduceMotion) return;

    const rows = section.querySelectorAll<HTMLElement>('.eng-spec-row');
    rows.forEach((row, i) => {
      row.animate(
        [
          { opacity: 0, transform: 'translateY(10px)' },
          { opacity: 1, transform: 'translateY(0)' },
        ],
        { duration: 420, delay: Math.min(i, 10) * 35, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'backwards' }
      );
    });

    const image = section.querySelector<HTMLElement>('.eng-spec-image');
    if (image) {
      image.animate(
        [
          { opacity: 0, transform: 'scale(0.97)' },
          { opacity: 1, transform: 'scale(1)' },
        ],
        { duration: 520, easing: 'cubic-bezier(0.22, 1, 0.36, 1)', fill: 'backwards' }
      );
    }
  };

  const counterStates = new Map<HTMLElement, SlotState>();
  sections.forEach((section) => {
    const countEl = section.querySelector<HTMLElement>('.eng-stat-count');
    if (countEl) counterStates.set(section, setupCounter(countEl));
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const section = entry.target as HTMLElement;

        const state = counterStates.get(section);
        if (state) {
          if (reduceMotion) {
            state.curr.textContent = String(state.target);
            state.curr.style.transform = 'translateY(0)';
          } else {
            animateCounter(state);
          }
        }

        revealSection(section);

        observer.unobserve(section);
      });
    },
    { threshold: 0.2 }
  );

  sections.forEach((section) => observer.observe(section));
</script>

