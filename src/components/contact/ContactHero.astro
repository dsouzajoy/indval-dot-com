---
import { en } from '@/i18n/locales/en';

const { hero } = en.contact;
---

<section class="pt-20 md:pt-24 pb-12 px-6 md:px-8 max-w-7xl mx-auto text-center" aria-label="Contact hero">
  <h1
    class="text-4xl sm:text-5xl md:text-6xl font-headline font-black text-primary tracking-tight max-w-3xl md:max-w-none mx-auto leading-none md:whitespace-nowrap"
    data-i18n="contact.hero.heading"
  >{hero.heading}</h1>
</section>
