---
import { en } from '@/i18n/locales/en';

const wu = en.businessModel.whyUs;

const pillars = [
  {
    icon: 'person_pin',
    titleKey: 'businessModel.whyUs.customerFocused.title',
    bodyKey: 'businessModel.whyUs.customerFocused.body',
    title: wu.customerFocused.title,
    body: wu.customerFocused.body,
  },
  {
    icon: 'verified',
    titleKey: 'businessModel.whyUs.qualityAssured.title',
    bodyKey: 'businessModel.whyUs.qualityAssured.body',
    title: wu.qualityAssured.title,
    body: wu.qualityAssured.body,
  },
  {
    icon: 'expand',
    titleKey: 'businessModel.whyUs.scalableFlexible.title',
    bodyKey: 'businessModel.whyUs.scalableFlexible.body',
    title: wu.scalableFlexible.title,
    body: wu.scalableFlexible.body,
  },
  {
    icon: 'alarm_on',
    titleKey: 'businessModel.whyUs.onTimeDelivery.title',
    bodyKey: 'businessModel.whyUs.onTimeDelivery.body',
    title: wu.onTimeDelivery.title,
    body: wu.onTimeDelivery.body,
  },
  {
    icon: 'handshake',
    titleKey: 'businessModel.whyUs.longTermPartnership.title',
    bodyKey: 'businessModel.whyUs.longTermPartnership.body',
    title: wu.longTermPartnership.title,
    body: wu.longTermPartnership.body,
  },
];
---

<section class="py-20 px-8 lg:px-16 bg-surface-container-low blueprint-bg" aria-label="Why Choose Us">
  <div class="container mx-auto">
    <!-- Section header -->
    <div class="text-center mb-12">
      <span
        class="font-label text-secondary uppercase tracking-[0.3em] text-xs font-bold block mb-3"
        data-i18n="businessModel.whyUs.eyebrow"
      >{en.businessModel.whyUs.eyebrow}</span>
      <h2
        class="font-headline font-black text-4xl text-primary leading-[0.9] tracking-tight"
        data-i18n="businessModel.whyUs.heading"
      >{en.businessModel.whyUs.heading}</h2>
    </div>

    <!-- 5-column compact grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      {pillars.map(({ icon, titleKey, bodyKey, title, body }) => (
        <div class="relative flex flex-col gap-4 p-5 bg-white rounded-[4px] border border-outline-variant/20 border-l-4 border-l-secondary shadow-[0_1px_4px_rgba(11,28,48,0.08)] overflow-hidden group hover:-translate-y-1 hover:shadow-[0_2px_8px_rgba(11,28,48,0.10)] transition-all duration-300">
          <!-- Fading dot mask: right corner -->
          <div class="absolute inset-y-0 right-0 w-24 pointer-events-none" style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 12px 12px; mask-image: linear-gradient(to right, transparent, black 60%); -webkit-mask-image: linear-gradient(to right, transparent, black 60%);"></div>
          <!-- Icon in tinted circle -->
          <div class="shrink-0 w-10 h-10 flex items-center justify-center bg-secondary/10 rounded-full group-hover:bg-secondary/20 transition-colors duration-300">
            <span
              class="material-symbols-outlined text-secondary"
              style="font-size: 1.25rem; font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 48;"
              aria-hidden="true"
            >{icon}</span>
          </div>
          <div>
            <h3
              class="font-label font-bold text-primary uppercase tracking-widest text-xs mb-1"
              data-i18n={titleKey}
            >{title}</h3>
            <p
              class="text-xs text-on-surface-variant leading-relaxed"
              data-i18n={bodyKey}
            >{body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
