---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';
import HeroImage from '@/components/ui/HeroImage.astro';
import HeroVideo from '@/components/ui/HeroVideo.astro';
import { getLQIP } from '@/lib/lqip';
import biwHeroVideo from '@/assets/videos/biw-hero-video.mp4';
import biwHeroPoster from '@/assets/images/biw/biw-hero-poster.jpg';
import cabinHeroImg from '@/assets/images/cabin-interior/hero.jpg';
import manufacturingHeroImg from '@/assets/images/manufacturing-hero.webp';
import capabilitiesHeroImg from '@/assets/images/capabilities-overview-hero.jpg';

const [cabinPlaceholder, manufacturingPlaceholder, capabilitiesPlaceholder] = await Promise.all([
  getLQIP('src/assets/images/cabin-interior/hero.jpg'),
  getLQIP('src/assets/images/manufacturing-hero.webp'),
  getLQIP('src/assets/images/capabilities-overview-hero.jpg'),
]);

const slides = [
  {
    eyebrow: en.cabinInterior.hero.eyebrow,
    heading: en.cabinInterior.hero.heading,
    body: en.cabinInterior.hero.description,
    cta: en.cabinInterior.hero.cta,
    href: '/capabilities/cabin-interior#intro',
    i18nPrefix: 'cabinInterior.hero',
    img: cabinHeroImg,
    placeholder: cabinPlaceholder,
    imgAlt: 'Aircraft cabin interior',
  },
  {
    eyebrow: en.biwTurnkey.hero.eyebrow,
    heading: en.biwTurnkey.hero.heading,
    body: 'End-to-end advanced manufacturing engineering, bridging product design and production through process planning, digital simulation, and industrialization support.',
    cta: en.biwTurnkey.hero.cta,
    href: '/capabilities/biw-turnkey-solutions#capabilities',
    i18nPrefix: 'biwTurnkey.hero',
    video: biwHeroVideo,
    poster: biwHeroPoster,
  },
  {
    heading: en.manufacturing.hero.heading,
    body: en.manufacturing.hero.description,
    cta: en.manufacturing.hero.cta,
    href: '/capabilities/manufacturing#capabilities',
    i18nPrefix: 'manufacturing.hero',
    img: manufacturingHeroImg,
    placeholder: manufacturingPlaceholder,
    imgAlt: 'Manufacturing facility',
  },
  {
    eyebrow: en.capabilitiesOverview.hero.eyebrow,
    heading: en.capabilitiesOverview.hero.heading,
    body: en.capabilitiesOverview.hero.description,
    cta: en.capabilitiesOverview.hero.cta,
    openMegaMenu: true,
    i18nPrefix: 'capabilitiesOverview.hero',
    img: capabilitiesHeroImg,
    placeholder: capabilitiesPlaceholder,
    imgAlt: 'Precision machined components on engineering blueprints',
  },
];
---

<section
  id="hero-carousel"
  class="relative min-h-[85vh] lg:min-h-[700px] xl:min-h-[800px] 2xl:min-h-[921px] w-full bg-slate-950 overflow-hidden"
  aria-label="Hero"
>
  <div class="relative h-full w-full min-h-[85vh] lg:min-h-[700px] xl:min-h-[800px] 2xl:min-h-[921px]">
    {slides.map((slide) => (
      <div class="carousel-item w-full h-full">
        <div class="absolute inset-0 bg-gradient-to-r from-on-surface/85 via-on-surface/65 to-on-surface/20 z-10"></div>
        {slide.video ? (
          <HeroVideo videoSrc={slide.video} poster={slide.poster} />
        ) : (
          <HeroImage src={slide.img} placeholder={slide.placeholder} alt={slide.imgAlt} />
        )}
        <div class="absolute inset-0 z-20 flex items-center px-8 max-w-screen-2xl mx-auto">
          <div class="max-w-2xl">
            {slide.eyebrow && (
              <span
                class="font-label text-secondary font-bold tracking-[0.2em] uppercase text-sm mb-6 block"
                data-i18n={`${slide.i18nPrefix}.eyebrow`}
              >
                {slide.eyebrow}
              </span>
            )}
            <h1
              class="font-headline font-black text-5xl lg:text-6xl xl:text-7xl 2xl:text-8xl text-white leading-[0.9] tracking-tight mb-8"
              data-i18n={`${slide.i18nPrefix}.heading`}
            >
              {slide.heading}
            </h1>
            <p
              class="text-white/80 text-xl leading-relaxed max-w-xl mb-12"
              data-i18n={`${slide.i18nPrefix}.description`}
            >
              {slide.body}
            </p>
            {slide.openMegaMenu ? (
              <button
                type="button"
                data-open-capabilities
                class="inline-block bg-secondary text-white px-8 py-4 rounded font-label font-bold uppercase tracking-wider hover:bg-secondary/80 btn-press"
                data-i18n={`${slide.i18nPrefix}.cta`}
              >
                {slide.cta}
              </button>
            ) : (
              <a
                href={withBase(slide.href!)}
                class="inline-block bg-secondary text-white px-8 py-4 rounded font-label font-bold uppercase tracking-wider hover:bg-secondary/80 btn-press"
                data-i18n={`${slide.i18nPrefix}.cta`}
              >
                {slide.cta}
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Navigation controls -->
  <div class="absolute bottom-12 left-0 right-0 z-30 flex justify-center items-center gap-8">
    <button
      id="prev-slide"
      class="text-white/50 hover:text-white transition-colors"
      aria-label="Previous slide"
    >
      <span class="material-symbols-outlined text-4xl">chevron_left</span>
    </button>
    <div class="flex gap-4" id="carousel-dots">
      {slides.map((_, i) => (
        <div
          class={`h-3 rounded-full transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-white w-8' : 'bg-white/30 w-3'}`}
          data-slide={String(i)}
          role="button"
          tabindex="0"
          aria-label={`Go to slide ${i + 1}`}
        ></div>
      ))}
    </div>
    <button
      id="next-slide"
      class="text-white/50 hover:text-white transition-colors"
      aria-label="Next slide"
    >
      <span class="material-symbols-outlined text-4xl">chevron_right</span>
    </button>
  </div>
</section>

<style>
  .carousel-item {
    display: block;
    position: absolute;
    inset: 0;
    transform: translateX(100%);
    will-change: transform;
  }
  .carousel-item.active {
    transform: translateX(0);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = Array.from(
      document.querySelectorAll<HTMLElement>('#hero-carousel .carousel-item')
    );
    const dots = document.querySelectorAll<HTMLElement>('#carousel-dots [data-slide]');
    const DURATION = 700;
    const EASING = 'cubic-bezier(0.4, 0, 0.2, 1)';
    let currentSlide = 0;
    let animating = false;
    let autoplayTimer: ReturnType<typeof setInterval>;

    // Initialise: first slide visible, rest hidden to the right
    slides.forEach((slide, i) => {
      slide.style.transform = i === 0 ? 'translateX(0)' : 'translateX(100%)';
      slide.style.transition = 'none';
    });

    function goTo(nextIndex: number, direction: 'forward' | 'backward') {
      if (animating || nextIndex === currentSlide) return;
      animating = true;

      const incoming = slides[nextIndex];
      const outgoing = slides[currentSlide];
      const enterFrom = direction === 'forward' ? '100%' : '-100%';
      const exitTo   = direction === 'forward' ? '-100%' : '100%';

      // Stage incoming off-screen without transition
      incoming.style.transition = 'none';
      incoming.style.transform = `translateX(${enterFrom})`;

      // Force reflow so the browser registers the start position
      incoming.offsetHeight;

      // Slide both panels simultaneously
      const t = `transform ${DURATION}ms ${EASING}`;
      incoming.style.transition = t;
      outgoing.style.transition = t;
      incoming.style.transform = 'translateX(0)';
      outgoing.style.transform = `translateX(${exitTo})`;

      // Update dots immediately
      dots.forEach((dot, i) => {
        const active = i === nextIndex;
        dot.classList.toggle('bg-white', active);
        dot.classList.toggle('w-8', active);
        dot.classList.toggle('bg-white/30', !active);
        dot.classList.toggle('w-3', !active);
      });

      setTimeout(() => {
        currentSlide = nextIndex;
        animating = false;
      }, DURATION);
    }

    function startAutoplay() {
      autoplayTimer = setInterval(() => {
        goTo((currentSlide + 1) % slides.length, 'forward');
      }, 6000);
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      startAutoplay();
    }

    document.getElementById('next-slide')?.addEventListener('click', () => {
      goTo((currentSlide + 1) % slides.length, 'forward');
      resetAutoplay();
    });

    document.getElementById('prev-slide')?.addEventListener('click', () => {
      goTo((currentSlide - 1 + slides.length) % slides.length, 'backward');
      resetAutoplay();
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-slide') ?? '0', 10);
        goTo(index, index > currentSlide ? 'forward' : 'backward');
        resetAutoplay();
      });
    });

    startAutoplay();

    document.querySelectorAll<HTMLElement>('[data-open-capabilities]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        document.getElementById('capabilities-trigger')
          ?.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', bubbles: true }));
      });
    });
  });
</script>
