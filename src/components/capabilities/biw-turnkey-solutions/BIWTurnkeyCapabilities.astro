---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';
import { getImage } from 'astro:assets';
import BIWPillarLightbox from './BIWPillarLightbox.astro';
import pp01Raw from '@/assets/images/biw/process-planning/01.png';
import pp02Raw from '@/assets/images/biw/process-planning/02.png';
import pp03Raw from '@/assets/images/biw/process-planning/03.png';
import dm01Raw from '@/assets/images/biw/digital-manufacturing/01.png';
import dm02Raw from '@/assets/images/biw/digital-manufacturing/02.png';
import dm03Raw from '@/assets/images/biw/digital-manufacturing/03.png';
import pd01Raw from '@/assets/images/biw/production-development/01.png';
import pd02Raw from '@/assets/images/biw/production-development/02.png';
import pd03Raw from '@/assets/images/biw/production-development/03.png';
import ind01Raw from '@/assets/images/biw/industrialization/01.png';
import ind02Raw from '@/assets/images/biw/industrialization/02.png';
import ind03Raw from '@/assets/images/biw/industrialization/03.png';
import ind04Raw from '@/assets/images/biw/industrialization/04.png';

const [pp01, pp02, pp03, dm01, dm02, dm03, pd01, pd02, pd03, ind01, ind02, ind03, ind04] = await Promise.all([
  getImage({ src: pp01Raw, format: 'avif' }),
  getImage({ src: pp02Raw, format: 'avif' }),
  getImage({ src: pp03Raw, format: 'avif' }),
  getImage({ src: dm01Raw, format: 'avif' }),
  getImage({ src: dm02Raw, format: 'avif' }),
  getImage({ src: dm03Raw, format: 'avif' }),
  getImage({ src: pd01Raw, format: 'avif' }),
  getImage({ src: pd02Raw, format: 'avif' }),
  getImage({ src: pd03Raw, format: 'avif' }),
  getImage({ src: ind01Raw, format: 'avif' }),
  getImage({ src: ind02Raw, format: 'avif' }),
  getImage({ src: ind03Raw, format: 'avif' }),
  getImage({ src: ind04Raw, format: 'avif' }),
]);

const differentiators = [
  'Digital-first engineering approach',
  'Automotive BIW domain expertise',
  'End-to-end from feasibility to line commissioning',
  'Risk reduction through simulation before build',
  'Single-point accountability across the full programme',
];

const pillars = [
  {
    key: 'processPlan',
    icon: 'route',
    ...en.biwTurnkey.pillars.processPlan,
    images: [{ src: pp01.src }, { src: pp02.src }, { src: pp03.src }],
  },
  {
    key: 'digitalMfg',
    icon: 'memory',
    ...en.biwTurnkey.pillars.digitalMfg,
    images: [{ src: dm01.src }, { src: dm02.src }, { src: dm03.src }],
  },
  {
    key: 'productionDev',
    icon: 'factory',
    ...en.biwTurnkey.pillars.productionDev,
    images: [{ src: pd01.src }, { src: pd02.src }, { src: pd03.src }],
  },
  {
    key: 'industrialization',
    icon: 'rocket_launch',
    ...en.biwTurnkey.pillars.industrialization,
    images: [{ src: ind01.src }, { src: ind02.src }, { src: ind03.src }, { src: ind04.src }],
  },
];

const keyCompetencies = en.biwTurnkey.keyCompetencies;

const steps = [
  {
    number: '01',
    icon: 'schema',
    title: 'Feasibility & Planning',
    description: 'Define scope, validate the manufacturing concept, and establish programme milestones before any engineering begins.',
  },
  {
    number: '02',
    icon: 'memory',
    title: 'Digital Factory Setup',
    description: 'Build the virtual production environment — line layouts, station definitions, and equipment geometry in the digital twin.',
  },
  {
    number: '03',
    icon: 'analytics',
    title: 'Simulation & Validation',
    description: 'Robotic reachability, cycle time simulation, ergonomic checks — all risks resolved before physical build.',
  },
  {
    number: '04',
    icon: 'factory',
    title: 'Production System Design',
    description: 'Full 3D equipment and tooling design with interference checks, BOM, and manufacturing drawings.',
  },
  {
    number: '05',
    icon: 'biotech',
    title: 'Prototype & Pilot Build',
    description: 'Support physical prototyping, pilot builds, and functional testing against production targets.',
  },
  {
    number: '06',
    icon: 'rocket_launch',
    title: 'Launch & Commissioning',
    description: 'Ramp-up management, line commissioning support, and handover to production operations.',
  },
];

const joiningAssemblyCards = [
  {
    heading: 'Spot Welding Systems',
    description: 'Development of manual and robotic spot welding fixtures engineered for repeatable positioning, weld accessibility, and high-volume production requirements.',
    image: 'https://images.unsplash.com/photo-1647427060118-4911c9821b82?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'MIG Welding Tooling',
    description: 'Design of welding stations and fixtures for structural and closure assemblies with emphasis on rigidity, operator accessibility, and process consistency.',
    image: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Hemming Solutions',
    description: 'Engineering of hemming tools for doors, hoods, and tailgates, ensuring dimensional accuracy, surface quality, and reliable panel forming.',
    image: 'https://images.unsplash.com/photo-1695603414659-4d573962b517?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Flow Drill Screw (FDS) Systems',
    description: 'Fixture solutions for multi-material joining applications, integrating precise screw positioning, clamping strategies, and process monitoring requirements.',
    image: 'https://images.unsplash.com/photo-1564226591723-659ff3852b2a?auto=format&fit=crop&w=1200&q=80',
  },
];

const manufacturingSupportCards = [
  {
    heading: 'Safety Fencing & Access Systems',
    description: 'Modular movable fencing and guarding solutions designed to provide operator safety while maintaining ease of maintenance and process accessibility.',
    image: 'https://images.unsplash.com/photo-1777269390301-3d40dbd19f36?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Maintenance Platforms',
    description: 'Custom-designed platforms and walkways for safe access to robotic cells, fixtures, and process equipment.',
    image: 'https://images.unsplash.com/photo-1770119074920-3c5603188095?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Structural Supports & Stands',
    description: 'Design and fabrication of equipment stands, support frames, and base structures engineered for durability and operational stability.',
    image: 'https://images.unsplash.com/photo-1745162391671-244e8d3ccd5f?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Buffer & Intermediate Stations',
    description: 'Production buffering systems and temporary storage solutions designed to improve line balancing and workflow efficiency.',
    image: 'https://images.unsplash.com/photo-1587293852726-70cdb56c2866?auto=format&fit=crop&w=1200&q=80',
  },
];

const processSpecificFixtureCards = [
  {
    heading: 'Marking & Traceability Fixtures',
    description: 'Tooling solutions for component identification, traceability marking, and process verification throughout the manufacturing cycle.',
    image: 'https://images.unsplash.com/photo-1640090330138-4360e82a690c?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Ejection Systems',
    description: 'Mechanically and pneumatically actuated systems for controlled component release and part transfer.',
    image: 'https://images.unsplash.com/photo-1752802469747-bff685763f3f?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Adhesive & Sealing Fixtures',
    description: 'Precision tooling for sealant and adhesive application processes with controlled bead placement and repeatable quality.',
    image: 'https://images.unsplash.com/photo-1596495578090-4f64ed1d4c80?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Checking & Validation Fixtures',
    description: 'Inspection fixtures designed for dimensional verification, GD&T evaluation, and assembly conformity checks.',
    image: 'https://images.unsplash.com/photo-1745571479807-8a0dda362f94?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Takeout & Transfer Systems',
    description: 'Automated and manual part removal systems developed to ensure safe handling and smooth integration between manufacturing operations.',
    image: 'https://images.unsplash.com/photo-1761195696590-3490ea770aa1?auto=format&fit=crop&w=1200&q=80',
  },
];

const materialHandlingCards = [
  {
    heading: 'Geo and Handling Grippers',
    description: 'Robotic grippers designed for accurate part location, handling, and transfer of automotive panels and assemblies.',
    image: 'https://images.unsplash.com/photo-1774229637247-3cd45219826c?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Lifting Devices & Tackles',
    description: 'Custom lifting equipment for large panels, fixtures, and assemblies with a focus on safety and ergonomic operation.',
    image: 'https://images.unsplash.com/photo-1652837135986-d737901cc7d7?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Lift-Assist Systems',
    description: 'Ergonomic handling solutions developed to reduce operator fatigue and improve productivity during assembly operations.',
    image: 'https://images.unsplash.com/photo-1730584476120-8534d2850654?auto=format&fit=crop&w=1200&q=80',
  },
  {
    heading: 'Conveyor Pallets & Carriers',
    description: 'Engineered pallets and carrier systems for precise part transportation, process indexing, and automated line integration.',
    image: 'https://images.unsplash.com/photo-1780850503758-cab85c57bc65?auto=format&fit=crop&w=1200&q=80',
  },
];
---

<!-- Section 01 — Overview -->
<section
  id="capabilities"
  class="bg-surface py-24 lg:py-32"
  style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;"
>
  <div class="max-w-7xl mx-auto px-8 lg:px-16">

    <div class="bg-surface-container-lowest rounded border-l-4 border-secondary shadow-ambient overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Left: value-led explanation -->
        <div class="p-8 lg:p-12 flex flex-col justify-center">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-6">From engineering concept to production launch.</h2>
          <p class="text-on-surface-variant leading-relaxed text-sm mb-4">
            Our Advanced Manufacturing Engineering (AME) team acts as the bridge between product design and the production floor — transforming engineering concepts into efficient, scalable, and high-quality manufacturing systems for the automotive BIW sector.
          </p>
          <p class="text-on-surface-variant leading-relaxed text-sm">
            We integrate digital engineering tools, process simulation, and advanced manufacturing methodologies to minimise programme risk and enhance operational efficiency from the earliest stages of a new vehicle launch.
          </p>
        </div>
        <!-- Right: differentiators checklist -->
        <div class="bg-surface-container-low p-8 lg:p-12 flex flex-col justify-center">
          <p class="font-label text-xs uppercase tracking-widest text-secondary mb-6">What We Bring</p>
          <ul class="space-y-4">
            {differentiators.map((item) => (
              <li class="flex items-start gap-3 text-sm text-on-surface-variant leading-relaxed">
                <span class="material-symbols-outlined text-secondary text-base mt-0.5 shrink-0" aria-hidden="true">check_circle</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Section 02 — Service Pillars -->
<section class="bg-surface-container-low py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-12">
      <p class="font-label text-sm uppercase tracking-widest text-secondary mb-3">01 — What We Deliver</p>
      <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface">Our Four Service Pillars</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {pillars.map((pillar, i) => (
        <div
          class="group bg-surface rounded border-b-2 border-transparent hover:border-secondary hover:bg-surface-container-high btn-press-card p-8 flex flex-col cursor-pointer focus:outline-none focus:ring-2 focus:ring-secondary/50"
          role="button"
          tabindex="0"
          data-pillar-index={i}
          data-pillar-title={pillar.title}
          data-pillar-icon={pillar.icon}
          data-images={JSON.stringify(pillar.images)}
        >
          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <span
              class="material-symbols-outlined text-primary"
              style="font-size: 3.5rem;"
              aria-hidden="true"
            >{pillar.icon}</span>
          </div>
          <!-- Title -->
          <h3 class="font-headline font-bold text-xl text-on-surface mb-2 text-center" data-i18n={`biwTurnkey.pillars.${pillar.key}.title`}>{pillar.title}</h3>
          <!-- One-line description -->
          <p class="text-on-surface-variant text-sm leading-relaxed text-center mb-6" data-i18n={`biwTurnkey.pillars.${pillar.key}.description`}>{pillar.description}</p>
          <!-- Bullet sub-items -->
          <ul class="space-y-2 mb-6">
            {pillar.items.map((item, j) => (
              <li class="flex items-start gap-3 text-sm text-on-surface-variant leading-relaxed">
                <span class="material-symbols-outlined text-secondary text-base mt-0.5 shrink-0" aria-hidden="true">check_circle</span>
                <span data-i18n={`biwTurnkey.pillars.${pillar.key}.items.${j}`}>{item}</span>
              </li>
            ))}
          </ul>
          <!-- View Gallery CTA -->
          <div class="mt-auto pt-5 border-t border-outline-variant flex items-center gap-2 text-secondary text-xs font-label font-bold uppercase tracking-wider group-hover:gap-3 transition-all duration-200">
            <span class="material-symbols-outlined text-base shrink-0" aria-hidden="true">photo_library</span>
            View Gallery
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<BIWPillarLightbox />

<!-- Section 03 — AME Delivery Workflow -->
<section
  class="bg-surface py-24"
  style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;"
>
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-12">
      <p class="font-label text-sm uppercase tracking-widest text-secondary mb-3">02 — Our Methodology</p>
      <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface">AME Delivery Workflow</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {steps.map((step) => (
        <div class="group relative bg-surface-container-low rounded p-8 hover:-translate-y-1 transition-transform duration-300 overflow-hidden">
          <p class="absolute font-headline font-black leading-none select-none pointer-events-none" style="top: 1rem; right: 1.5rem; font-size: 5rem; color: rgba(255, 103, 31, 0.15)">{step.number}</p>
          <div class="bg-primary rounded p-3 inline-flex mb-4 relative">
            <span class="material-symbols-outlined text-white text-3xl" aria-hidden="true">{step.icon}</span>
          </div>
          <h3 class="font-headline font-bold text-lg text-on-surface mb-2 relative">{step.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed relative">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Section 04 — End-to-end Engineering Solutions -->
<section
  class="bg-surface-container-low py-24"
  style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;"
>
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-14">
      <p class="font-label text-sm uppercase tracking-widest text-secondary mb-3">03 — Full-Spectrum Capability</p>
      <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface">End-to-end Engineering Solutions</h2>
    </div>

    <div class="mb-14 max-w-2xl">
      <h3 class="font-headline text-2xl lg:text-3xl font-bold text-on-surface">Joining &amp; Assembly Tooling</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {joiningAssemblyCards.map((card) => (
        <div class="group bg-surface rounded flex flex-col overflow-hidden border border-outline-variant border-b-2 hover:border-b-secondary transition-all duration-300">
          <div class="aspect-video overflow-hidden">
            <img
              src={card.image}
              alt={card.heading}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="font-headline font-bold text-xl text-on-surface mb-3">{card.heading}</h3>
            <p class="text-on-surface-variant leading-relaxed text-sm flex-grow">{card.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 mb-14 max-w-2xl">
      <h3 class="font-headline text-2xl lg:text-3xl font-bold text-on-surface">Manufacturing Support Equipment</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {manufacturingSupportCards.map((card) => (
        <div class="group bg-surface rounded flex flex-col overflow-hidden border border-outline-variant border-b-2 hover:border-b-secondary transition-all duration-300">
          <div class="aspect-video overflow-hidden">
            <img
              src={card.image}
              alt={card.heading}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="font-headline font-bold text-xl text-on-surface mb-3">{card.heading}</h3>
            <p class="text-on-surface-variant leading-relaxed text-sm flex-grow">{card.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 mb-14 max-w-2xl">
      <h3 class="font-headline text-2xl lg:text-3xl font-bold text-on-surface">Process-Specific Fixtures</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {processSpecificFixtureCards.map((card) => (
        <div class="group bg-surface rounded flex flex-col overflow-hidden border border-outline-variant border-b-2 hover:border-b-secondary transition-all duration-300">
          <div class="aspect-video overflow-hidden">
            <img
              src={card.image}
              alt={card.heading}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="font-headline font-bold text-xl text-on-surface mb-3">{card.heading}</h3>
            <p class="text-on-surface-variant leading-relaxed text-sm flex-grow">{card.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 mb-14 max-w-2xl">
      <h3 class="font-headline text-2xl lg:text-3xl font-bold text-on-surface">Material Handling & Automation Tooling</h3>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {materialHandlingCards.map((card) => (
        <div class="group bg-surface rounded flex flex-col overflow-hidden border border-outline-variant border-b-2 hover:border-b-secondary transition-all duration-300">
          <div class="aspect-video overflow-hidden">
            <img
              src={card.image}
              alt={card.heading}
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="font-headline font-bold text-xl text-on-surface mb-3">{card.heading}</h3>
            <p class="text-on-surface-variant leading-relaxed text-sm flex-grow">{card.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Section 05 — Key Competencies -->
<section class="bg-surface py-24">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">
    <div class="mb-14">
      <p class="font-label text-sm uppercase tracking-widest text-secondary mb-3" data-i18n="biwTurnkey.keyCompetencies.eyebrow">{keyCompetencies.eyebrow}</p>
      <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface" data-i18n="biwTurnkey.keyCompetencies.heading">{keyCompetencies.heading}</h2>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-4">
      {keyCompetencies.items.map((item, i) => (
        <li class="flex items-start gap-3 text-sm text-on-surface-variant leading-relaxed">
          <span class="material-symbols-outlined text-secondary text-base mt-0.5 shrink-0" aria-hidden="true">check_circle</span>
          <span data-i18n={`biwTurnkey.keyCompetencies.items.${i}`}>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- CTA Banner -->
<section class="bg-on-surface py-20">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 text-center">
    <h2 class="font-headline text-3xl lg:text-4xl font-bold text-white mb-4">
      Build Your BIW Production System
    </h2>
    <p class="text-white/80 text-base mb-10 max-w-xl mx-auto leading-relaxed">
      Connect with our AME specialists to plan, simulate, and launch your next production line.
    </p>
    <a
      href={withBase('/contact#contact-form')}
      class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-secondary/90 btn-press"
    >
      Get In Touch
    </a>
  </div>
</section>
