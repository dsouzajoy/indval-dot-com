---
import { withBase } from '@/lib/utils';
---

<section id="what-we-do" class="py-24 px-8" style="background-image: linear-gradient(to right, rgba(0,49,108,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(0,49,108,0.05) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-10">
      What We Do
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <!-- Tooling Design (unclickable) -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Clamping bar (light fill) -->
            <rect x="14" y="10" width="36" height="8" rx="1.5" fill="#dce9ff"/>
            <rect x="14" y="10" width="36" height="8" rx="1.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Screw shaft + arrow -->
            <line x1="32" y1="18" x2="32" y2="26" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <polyline points="28,24 32,28 36,24" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <!-- Left drill bushing body (light fill) -->
            <circle cx="20" cy="36" r="10" fill="#dce9ff"/>
            <circle cx="20" cy="36" r="10" stroke="#00316c" stroke-width="1.5"/>
            <!-- Left drill hole (navy) -->
            <circle cx="20" cy="36" r="4" fill="#00316c"/>
            <!-- Right drill bushing body (light fill) -->
            <circle cx="44" cy="36" r="10" fill="#dce9ff"/>
            <circle cx="44" cy="36" r="10" stroke="#00316c" stroke-width="1.5"/>
            <!-- Right drill hole (navy) -->
            <circle cx="44" cy="36" r="4" fill="#00316c"/>
            <!-- Bushing stems -->
            <line x1="20" y1="46" x2="20" y2="48" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="44" y1="46" x2="44" y2="48" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Base fixture plate (light fill) -->
            <rect x="8" y="48" width="48" height="9" rx="1.5" fill="#dce9ff"/>
            <rect x="8" y="48" width="48" height="9" rx="1.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Locating pins (navy) -->
            <rect x="9" y="40" width="4" height="8" rx="1" fill="#00316c"/>
            <rect x="51" y="40" width="4" height="8" rx="1" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Tooling Design</span>
      </div>

      <!-- Secondary Structure Design (unclickable) -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Outer fuselage ring (light fill) -->
            <ellipse cx="32" cy="34" rx="26" ry="20" fill="#dce9ff"/>
            <ellipse cx="32" cy="34" rx="26" ry="20" stroke="#00316c" stroke-width="1.5"/>
            <!-- Inner wall cutout (white) -->
            <ellipse cx="32" cy="34" rx="21" ry="15" fill="white"/>
            <ellipse cx="32" cy="34" rx="21" ry="15" stroke="#00316c" stroke-width="1.5"/>
            <!-- Radial ribs (navy) -->
            <line x1="32" y1="14" x2="32" y2="19" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="49" x2="32" y2="54" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="6"  y1="34" x2="11" y2="34" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="53" y1="34" x2="58" y2="34" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="13.6" y1="20.6" x2="17.4" y2="24.4" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="50.4" y1="20.6" x2="46.6" y2="24.4" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="13.6" y1="47.4" x2="17.4" y2="43.6" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="50.4" y1="47.4" x2="46.6" y2="43.6" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Node dots -->
            <circle cx="32" cy="19" r="2" fill="#00316c"/>
            <circle cx="32" cy="49" r="2" fill="#00316c"/>
            <circle cx="11" cy="34" r="2" fill="#00316c"/>
            <circle cx="53" cy="34" r="2" fill="#00316c"/>
            <circle cx="17.4" cy="24.4" r="2" fill="#00316c"/>
            <circle cx="46.6" cy="24.4" r="2" fill="#00316c"/>
            <circle cx="17.4" cy="43.6" r="2" fill="#00316c"/>
            <circle cx="46.6" cy="43.6" r="2" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Secondary Structure Design</span>
      </div>

      <!-- Finite Element Analysis — same icon as automotive (linkable) -->
      <a href={withBase('/capabilities/fea')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <polygon points="8,8 26,8 8,26" fill="#dce9ff"/>
            <polygon points="26,8 44,8 26,26" fill="#dce9ff"/>
            <polygon points="44,8 62,8 44,26" fill="#dce9ff"/>
            <polygon points="8,26 26,26 8,44" fill="#dce9ff"/>
            <polygon points="26,26 44,26 26,44" fill="#dce9ff"/>
            <polygon points="44,26 62,26 44,44" fill="#dce9ff"/>
            <polygon points="8,44 26,44 8,62" fill="#dce9ff"/>
            <polygon points="26,44 44,44 26,62" fill="#dce9ff"/>
            <polygon points="44,44 62,44 44,62" fill="#dce9ff"/>
            <polygon points="8,8 26,26 8,26" fill="#00316c" opacity="0.15"/>
            <polygon points="26,8 44,26 26,26" fill="#00316c" opacity="0.15"/>
            <polygon points="8,26 26,44 8,44" fill="#00316c" opacity="0.15"/>
            <line x1="8"  y1="8"  x2="62" y2="8"  stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="26" x2="62" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="44" x2="62" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="62" x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="8"  x2="8"  y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="8"  x2="26" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="8"  x2="44" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="62" y1="8"  x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="8"  x2="26" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="8"  x2="44" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="8"  x2="62" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="26" x2="26" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="26" x2="44" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="26" x2="62" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="44" x2="26" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="44" x2="44" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="44" x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <circle cx="8"  cy="8"  r="2" fill="#00316c"/>
            <circle cx="26" cy="8"  r="2" fill="#00316c"/>
            <circle cx="44" cy="8"  r="2" fill="#00316c"/>
            <circle cx="62" cy="8"  r="2" fill="#00316c"/>
            <circle cx="8"  cy="26" r="2" fill="#00316c"/>
            <circle cx="26" cy="26" r="2" fill="#00316c"/>
            <circle cx="44" cy="26" r="2" fill="#00316c"/>
            <circle cx="62" cy="26" r="2" fill="#00316c"/>
            <circle cx="8"  cy="44" r="2" fill="#00316c"/>
            <circle cx="26" cy="44" r="2" fill="#00316c"/>
            <circle cx="44" cy="44" r="2" fill="#00316c"/>
            <circle cx="62" cy="44" r="2" fill="#00316c"/>
            <circle cx="8"  cy="62" r="2" fill="#00316c"/>
            <circle cx="26" cy="62" r="2" fill="#00316c"/>
            <circle cx="44" cy="62" r="2" fill="#00316c"/>
            <circle cx="62" cy="62" r="2" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Finite Element Analysis</span>
      </a>

      <!-- Computational Fluid Dynamics — same icon as automotive (linkable) -->
      <a href={withBase('/capabilities/cfd')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18 32 C18 24 26 18 36 20 C44 22 48 28 48 32 C48 36 44 42 36 44 C26 46 18 40 18 32 Z" fill="#dce9ff"/>
            <path d="M18 32 C18 24 26 18 36 20 C44 22 48 28 48 32 C48 36 44 42 36 44 C26 46 18 40 18 32 Z" stroke="#00316c" stroke-width="1.5"/>
            <path d="M4 16 C10 16 14 20 18 24"   stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 24 C8 24 12 26 16 29"    stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 32 L16 32"               stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 40 C8 40 12 38 16 35"    stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 48 C10 48 14 44 18 40"   stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 26 C52 25 56 22 60 20"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 32 L60 32"              stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 38 C52 39 56 42 60 44"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Computational Fluid Dynamics</span>
      </a>

      <!-- Cabin Interior (unclickable) -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Fuselage body (light fill) -->
            <circle cx="32" cy="30" r="26" fill="#dce9ff"/>
            <circle cx="32" cy="30" r="26" stroke="#00316c" stroke-width="1.5"/>
            <!-- Cabin floor area (slightly darker) -->
            <path d="M10 42 A26 26 0 0 0 54 42 L54 56 L10 56 Z" fill="#00316c" opacity="0.1"/>
            <!-- Floor line -->
            <line x1="10" y1="42" x2="54" y2="42" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Left window (navy tinted) -->
            <rect x="7" y="22" width="7" height="9" rx="2.5" fill="#00316c" opacity="0.2"/>
            <rect x="7" y="22" width="7" height="9" rx="2.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Right window -->
            <rect x="50" y="22" width="7" height="9" rx="2.5" fill="#00316c" opacity="0.2"/>
            <rect x="50" y="22" width="7" height="9" rx="2.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Left seat (navy fill) -->
            <rect x="14" y="38" width="10" height="4" rx="1" fill="#00316c"/>
            <line x1="14" y1="42" x2="14" y2="34" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Right seat (navy fill) -->
            <rect x="40" y="38" width="10" height="4" rx="1" fill="#00316c"/>
            <line x1="50" y1="42" x2="50" y2="34" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Overhead bin arc -->
            <path d="M16 34 Q32 28 48 34" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Aisle dashes -->
            <line x1="32" y1="42" x2="32" y2="54" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="3,3"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Cabin Interior</span>
      </div>

      <!-- Wire Harness Design EHI — adapted from automotive Wire Harnessing (unclickable) -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Left connector block (light fill) -->
            <rect x="4" y="20" width="14" height="24" rx="3" fill="#dce9ff"/>
            <rect x="4" y="20" width="14" height="24" rx="3" stroke="#00316c" stroke-width="1.5"/>
            <!-- Left connector pins (navy) -->
            <rect x="8"  y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <rect x="13" y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <!-- Left socket holes -->
            <circle cx="9"  cy="29" r="2" fill="#00316c"/>
            <circle cx="15" cy="29" r="2" fill="#00316c"/>
            <circle cx="9"  cy="37" r="2" fill="#00316c"/>
            <circle cx="15" cy="37" r="2" fill="#00316c"/>
            <!-- Right connector block (light fill) -->
            <rect x="46" y="20" width="14" height="24" rx="3" fill="#dce9ff"/>
            <rect x="46" y="20" width="14" height="24" rx="3" stroke="#00316c" stroke-width="1.5"/>
            <!-- Right connector pins (navy) -->
            <rect x="48" y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <rect x="53" y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <!-- Right socket holes -->
            <circle cx="49" cy="29" r="2" fill="#00316c"/>
            <circle cx="55" cy="29" r="2" fill="#00316c"/>
            <circle cx="49" cy="37" r="2" fill="#00316c"/>
            <circle cx="55" cy="37" r="2" fill="#00316c"/>
            <!-- Wires between connectors -->
            <path d="M18 26 C28 26, 36 30, 46 30" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M18 30 L46 34"               stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M18 34 L46 30"               stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M18 38 C28 38, 36 34, 46 34" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Wire clip band -->
            <rect x="29" y="27" width="4" height="10" rx="2" fill="#dce9ff" stroke="#00316c" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Wire Harness Design (EHI)</span>
      </div>

      <!-- Avionics (unclickable) -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Instrument panel frame (light fill) -->
            <rect x="4" y="10" width="56" height="44" rx="2" fill="#dce9ff"/>
            <rect x="4" y="10" width="56" height="44" rx="2" stroke="#00316c" stroke-width="1.5"/>
            <!-- Primary flight display screen -->
            <rect x="18" y="16" width="28" height="22" rx="1" fill="#00316c" opacity="0.12"/>
            <rect x="18" y="16" width="28" height="22" rx="1" stroke="#00316c" stroke-width="1.5"/>
            <!-- Artificial horizon line -->
            <line x1="22" y1="27" x2="42" y2="27" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Sky/ground tint -->
            <rect x="19" y="17" width="26" height="10" rx="0.5" fill="#00316c" opacity="0.08"/>
            <!-- Aircraft symbol -->
            <line x1="32" y1="23" x2="32" y2="31" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="27" y1="27" x2="37" y2="27" stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Left circular gauge -->
            <circle cx="10" cy="27" r="7" fill="white"/>
            <circle cx="10" cy="27" r="7" stroke="#00316c" stroke-width="1.5"/>
            <line x1="10" y1="22" x2="10" y2="20" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="10" y1="27" x2="14" y2="23" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <circle cx="10" cy="27" r="1.5" fill="#00316c"/>
            <!-- Right circular gauge -->
            <circle cx="54" cy="27" r="7" fill="white"/>
            <circle cx="54" cy="27" r="7" stroke="#00316c" stroke-width="1.5"/>
            <line x1="54" y1="22" x2="54" y2="20" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="54" y1="27" x2="58" y2="23" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <circle cx="54" cy="27" r="1.5" fill="#00316c"/>
            <!-- Bottom indicators row (navy fill) -->
            <rect x="6"  y="44" width="14" height="6" rx="1" fill="#00316c" opacity="0.15"/>
            <rect x="6"  y="44" width="14" height="6" rx="1" stroke="#00316c" stroke-width="1"/>
            <rect x="25" y="44" width="14" height="6" rx="1" fill="#00316c" opacity="0.15"/>
            <rect x="25" y="44" width="14" height="6" rx="1" stroke="#00316c" stroke-width="1"/>
            <rect x="44" y="44" width="14" height="6" rx="1" fill="#00316c" opacity="0.15"/>
            <rect x="44" y="44" width="14" height="6" rx="1" stroke="#00316c" stroke-width="1"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Avionics</span>
      </div>

      <!-- Manufacturing (linkable) -->
      <a href={withBase('/capabilities/manufacturing')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Gear body (light fill) -->
            <circle cx="32" cy="32" r="20" fill="#dce9ff"/>
            <!-- Gear teeth (light fill + navy stroke, rotated around center) -->
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(0 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(45 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(90 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(135 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(180 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(225 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(270 32 32)"/>
            <rect x="30" y="6" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(315 32 32)"/>
            <!-- Gear body ring outline -->
            <circle cx="32" cy="32" r="20" stroke="#00316c" stroke-width="1.5"/>
            <!-- Center bore (white cutout) -->
            <circle cx="32" cy="32" r="7" fill="white"/>
            <circle cx="32" cy="32" r="7" stroke="#00316c" stroke-width="1.5"/>
            <!-- Bolt holes (navy) -->
            <circle cx="32" cy="20" r="2" fill="#00316c"/>
            <circle cx="43.4" cy="26" r="2" fill="#00316c"/>
            <circle cx="20.6" cy="26" r="2" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Manufacturing</span>
      </a>

      <!-- Technical Publications (linkable) -->
      <a href={withBase('/capabilities/technical-publication')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Document body (light fill) -->
            <path d="M10 6 L42 6 L54 18 L54 58 L10 58 Z" fill="#dce9ff"/>
            <path d="M10 6 L42 6 L54 18 L54 58 L10 58 Z" stroke="#00316c" stroke-width="1.5" stroke-linejoin="round"/>
            <!-- Folded corner (darker tint) -->
            <path d="M42 6 L42 18 L54 18 Z" fill="#00316c" opacity="0.2"/>
            <path d="M42 6 L42 18 L54 18" stroke="#00316c" stroke-width="1.5" stroke-linejoin="round"/>
            <!-- Horizontal dimension line with arrows -->
            <line x1="16" y1="28" x2="44" y2="28" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
