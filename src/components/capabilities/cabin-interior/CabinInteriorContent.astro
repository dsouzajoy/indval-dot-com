<script>
  const industryItems = document.querySelectorAll<HTMLElement>('.ci-industry-item');
  const industryImgs = document.querySelectorAll<HTMLElement>('.ci-industry-img');

  function activateIndustry(idx: number) {
    industryItems.forEach((item, i) => {
      const isActive = i === idx;
      item.classList.toggle('bg-surface', isActive);
      item.classList.toggle('shadow-sm', isActive);
      const num = item.querySelector('span');
      if (num) {
        num.classList.toggle('text-secondary', isActive);
        num.classList.toggle('text-outline', !isActive);
      }
      const h3 = item.querySelector('h3');
      if (h3) {
        h3.classList.toggle('text-primary', isActive);
        h3.classList.toggle('text-on-surface-variant', !isActive);
      }
      const p = item.querySelector('p');
      if (p) {
        p.classList.toggle('text-on-surface-variant', isActive);
        p.classList.toggle('text-on-surface-variant/70', !isActive);
      }
    });
    industryImgs.forEach((img, i) => {
      img.classList.toggle('opacity-100', i === idx);
      img.classList.toggle('opacity-0', i !== idx);
    });
  }

  industryItems.forEach((item, i) => {
    item.addEventListener('mouseenter', () => activateIndustry(i));
  });
</script>

