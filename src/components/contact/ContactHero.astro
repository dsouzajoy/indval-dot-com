---
import { en } from '@/i18n/locales/en';

const { hero } = en.contact;
---

<section class="pt-24 pb-16 px-8 max-w-7xl mx-auto text-center" aria-label="Contact hero">
  <div
    class="inline-block px-4 py-1.5 mb-6 bg-surface-container-high text-primary font-label text-xs tracking-[0.2em] uppercase rounded-full"
    data-i18n="contact.hero.eyebrow"
  >{hero.eyebrow}</div>

  <h1
    class="text-5xl md:text-6xl font-headline font-black text-primary tracking-tight mb-6 max-w-3xl mx-auto leading-none"
    data-i18n="contact.hero.heading"
  >{hero.heading}</h1>

  <p
    class="text-on-surface-variant text-lg max-w-2xl mx-auto font-body leading-relaxed"
    data-i18n="contact.hero.body"
  >{hero.body}</p>
</section>
