          alt="Cutaway illustration of an aircraft cabin retrofit showing overhead bins, window panels, and sidewall structure"
          format="avif"
          quality={100}
          width={1000}
          height={1000}
          loading="lazy"
          class="w-full h-auto rounded"
        />
      </div>

      <dl class="lg:order-2 flex-1 grid grid-cols-1 sm:grid-cols-2 sm:gap-x-10 border-t border-outline-variant/70">
        {retrofitSpecs.map((row) => (
          <div class="eng-spec-row group py-4 sm:py-5 px-2 -mx-2 rounded border-b border-outline-variant/70 transition-colors duration-200 hover:bg-surface">
            <dt class="flex items-start gap-2.5">
              <span class="mt-2 w-1.5 h-1.5 rounded-full bg-secondary shrink-0 transition-transform duration-200 group-hover:scale-[1.8]" aria-hidden="true"></span>
              <span class="font-headline font-bold text-[0.95rem] text-primary leading-snug">{row.component}</span>
