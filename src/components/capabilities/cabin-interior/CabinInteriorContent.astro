  {
    discipline: 'Structural Analysis',
    scope: 'Linear & non-linear FEA, ultimate load analysis, fatigue, damage tolerance, topology optimisation',
  },
  {
    discipline: 'Ballistic Engineering',
    scope: 'Layer stack design to STANAG 4569, NIJ, and AEP-55, integration with vehicle and aircraft armour systems',
  },
  {
    discipline: 'Manufacturing DFM',
    scope: 'Manufacturability reviews, CNC programme design, jig & fixture design',
  },
  {
    discipline: 'Certification Support',
    scope: 'FAA, EASA documentation, STC documentation packages, AS9100 audit evidence generation',
  },
  {
    discipline: 'Systems Integration',
    scope: 'Avionics housing design, electrical harness routing, EMI/EMC shielding design, DO-160 compliance',
  },
  {
    discipline: 'Tooling Design',
    scope: 'Autoclave mould design, RTM matched-die design, assembly jigs, holding fixtures',
  },
  {
    discipline: 'Reverse Engineering',
    scope: '3D laser scanning, point cloud to CAD conversion, legacy component digitization',
