---
import { withBase } from '@/lib/utils';
---
<div id="splash" class="fixed inset-0 z-[200] flex items-center justify-center bg-surface">
  <div id="splash-inner" style="display:flex; align-items:center;">
    <div class="inline-flex items-center gap-4">
      <img src={withBase('/images/logo.png')} alt="Indvaltech" style="height:5rem; width:auto;" />
      <span class="w-px bg-slate-300/60 shrink-0" style="height:3.5rem;"></span>
      <span class="font-label tracking-tight leading-none flex flex-col">
        <span class="text-2xl font-bold"><span class="text-secondary">INDVAL</span><span class="text-primary">TECH</span></span>
        <span class="text-[0.55rem] font-medium text-slate-500 tracking-[0.12em] uppercase mt-0.5">Engineering Excellence</span>
      </span>
    </div>
  </div>
</div>

<script>
  const splash = document.getElementById('splash') as HTMLElement;
  const inner = document.getElementById('splash-inner') as HTMLElement;

  if (sessionStorage.getItem('splashSeen')) {
    splash.remove();
  } else {
    document.body.style.overflow = 'hidden';

    const startTime = Date.now();
    const minDelay = 800;

    function dismissSplash() {
      inner.style.transition = 'transform 600ms ease-in-out, opacity 600ms ease-in-out';
      inner.style.transform = 'translateY(-40px)';
      inner.style.opacity = '0';
      splash.style.transition = 'opacity 600ms ease-in-out';
      splash.style.opacity = '0';
      setTimeout(() => {
        splash.remove();
        document.body.style.overflow = '';
      }, 650);
      sessionStorage.setItem('splashSeen', '1');
    }

    window.addEventListener('load', () => {
      const elapsed = Date.now() - startTime;
      const remaining = Math.max(0, minDelay - elapsed);
      setTimeout(dismissSplash, remaining);
    });
  }
</script>
