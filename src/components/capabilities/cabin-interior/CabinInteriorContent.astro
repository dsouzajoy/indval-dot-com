const industries = [
  {
    num: '01',
    title: 'Commercial Aviation',
    desc: 'Narrow-body, wide-body, and regional aircraft cabin interior programs.',
    image: industryCommercialImg,
    alt: 'Commercial aircraft cabin interior with passenger seats',
  },
  {
    num: '02',
    title: 'Business & VIP Aviation',
    desc: 'Premium and executive cabin design and development solutions.',
    image: industryVipImg,
    alt: 'Luxury private jet interior with business passengers',
  },
  {
    num: '03',
    title: 'Military Aviation',
    desc: 'Mission-specific cabin modifications and defense interior systems.',
    image: industryMilitaryImg,
    alt: 'Military cargo aircraft interior',
  },
  {
    num: '04',
    title: 'Advanced Air Mobility (AAM)',
    desc: 'Next-generation eVTOL and urban air mobility cabin solutions.',
    image: industryAamImg,
    alt: 'eVTOL aircraft at an advanced air mobility vertiport',
  },
  {
    num: '05',
    title: 'MRO & Cabin Retrofit',
    desc: 'Aircraft modernization, cabin refurbishment, and interior upgrade projects.',
    image: industryMroImg,
    alt: 'Aircraft cabin under maintenance and refurbishment',
  },
];

const whyUs = [
  {
    icon: 'engineering',
    title: 'Aerospace Domain Expertise',
    desc: 'Experienced engineers with extensive aircraft interior development knowledge.',
  },
  {
    icon: 'route',
    title: 'End-to-End Engineering Support',
    desc: 'From concept design through certification and production support.',
  },
  {
    icon: 'groups',
    title: 'Multi-Disciplinary Engineering Team',
    desc: 'Mechanical, electrical, stress, manufacturing, and technical publication specialists working together.',
  },
  {
    icon: 'verified',
    title: 'Quality & Compliance',
    desc: 'Engineering deliverables developed to meet stringent aerospace standards.',
  },
  {
    icon: 'public',
    title: 'Cost-Effective Global Delivery',
    desc: 'Flexible engagement models tailored to customer program requirements.',
  },
  {
    icon: 'workspace_premium',
    title: 'Proven Engineering Excellence',
    desc: 'Reliable support for complex aerospace development and cabin modernization programs.',
