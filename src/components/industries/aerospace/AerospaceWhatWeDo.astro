---
import { withBase } from '@/lib/utils';
---

<section id="what-we-do" class="py-24 px-8" style="background-image: linear-gradient(to right, rgba(0,49,108,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(0,49,108,0.05) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-10">
      What We Do
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <!-- 1. Cabin Interior (linkable) -->
      <a href={withBase('/capabilities/cabin-interior')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <clipPath id="aero-cabin-clip">
                <rect x="6" y="6" width="52" height="37"/>
              </clipPath>
            </defs>
            <!-- Outer fuselage circle -->
            <circle cx="32" cy="32" r="26" fill="#dce9ff"/>
            <circle cx="32" cy="32" r="26" stroke="#00316c" stroke-width="2"/>
            <!-- Inner cabin (white, clipped above floor) -->
            <circle cx="32" cy="32" r="20" fill="white" clip-path="url(#aero-cabin-clip)"/>
            <circle cx="32" cy="32" r="20" stroke="#00316c" stroke-width="1.5" clip-path="url(#aero-cabin-clip)"/>
            <!-- Underbelly depth tint -->
            <path d="M6 32 A26 26 0 0 0 58 32 L58 44 L6 44 Z" fill="#00316c" opacity="0.08"/>
            <!-- Cabin floor -->
            <line x1="10" y1="43" x2="54" y2="43" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Left window -->
            <rect x="8" y="24" width="8" height="11" rx="3.5" fill="#00316c" opacity="0.18"/>
            <rect x="8" y="24" width="8" height="11" rx="3.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Right window -->
            <rect x="48" y="24" width="8" height="11" rx="3.5" fill="#00316c" opacity="0.18"/>
            <rect x="48" y="24" width="8" height="11" rx="3.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Overhead bin arc -->
            <path d="M16 36 Q32 28 48 36" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Left seat: base + backrest -->
            <rect x="13" y="38" width="9" height="5" rx="1" fill="#00316c" opacity="0.80"/>
            <rect x="13" y="32" width="3" height="7" rx="1" fill="#00316c" opacity="0.80"/>
            <!-- Right seat: base + backrest -->
            <rect x="42" y="38" width="9" height="5" rx="1" fill="#00316c" opacity="0.80"/>
            <rect x="48" y="32" width="3" height="7" rx="1" fill="#00316c" opacity="0.80"/>
            <!-- Aisle dashed line -->
            <line x1="32" y1="43" x2="32" y2="56" stroke="#00316c" stroke-width="1" stroke-dasharray="3,3" stroke-linecap="round"/>
            <!-- Orange seatbelt symbol at center -->
            <circle cx="32" cy="32" r="3.5" fill="white" stroke="#ff671f" stroke-width="1.5"/>
            <line x1="30" y1="30" x2="34" y2="34" stroke="#ff671f" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Aircraft Cabin Interior</span>
      </a>

      <!-- 2. Secondary Structure Design -->
      <a href={withBase('/capabilities/secondary-structure-design')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Outer ring fill -->
            <ellipse cx="32" cy="32" rx="26" ry="22" fill="#dce9ff"/>
            <ellipse cx="32" cy="32" rx="26" ry="22" stroke="#00316c" stroke-width="2"/>
            <!-- Inner wall cutout -->
            <ellipse cx="32" cy="32" rx="20" ry="16" fill="white"/>
            <ellipse cx="32" cy="32" rx="20" ry="16" stroke="#00316c" stroke-width="1.5"/>
            <!-- Depth shading on lower half of frame ring -->
            <path d="M6 32 A26 22 0 0 0 58 32 A20 16 0 0 1 12 32 Z" fill="#00316c" opacity="0.08"/>
            <!-- Floor beam -->
            <line x1="18" y1="42" x2="46" y2="42" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Vertical floor supports -->
            <line x1="22" y1="47" x2="22" y2="42" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="42" y1="47" x2="42" y2="42" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- 8 radial ribs -->
            <line x1="32" y1="10" x2="32" y2="16" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="54" x2="32" y2="48" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="6"  y1="32" x2="12" y2="32" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="58" y1="32" x2="52" y2="32" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="13.6" y1="17.6" x2="17.6" y2="21.6" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="50.4" y1="17.6" x2="46.4" y2="21.6" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="13.6" y1="46.4" x2="17.6" y2="42.4" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="50.4" y1="46.4" x2="46.4" y2="42.4" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Node dots -->
            <circle cx="32" cy="16" r="2" fill="#00316c"/>
            <circle cx="32" cy="48" r="2" fill="#00316c"/>
            <circle cx="12" cy="32" r="2" fill="#00316c"/>
            <circle cx="52" cy="32" r="2" fill="#00316c"/>
            <circle cx="17.6" cy="21.6" r="2" fill="#00316c"/>
            <circle cx="46.4" cy="21.6" r="2" fill="#00316c"/>
            <circle cx="17.6" cy="42.4" r="2" fill="#00316c"/>
            <circle cx="46.4" cy="42.4" r="2" fill="#00316c"/>
            <!-- Orange top fastener -->
            <circle cx="32" cy="10" r="3.5" fill="#ff671f"/>
            <circle cx="32" cy="10" r="1.5" fill="white"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Secondary Structure Design</span>
      </a>

      <!-- 3. Wire Harness Design EHI (linkable) -->
      <a href={withBase('/capabilities/electrical-harness-design')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Left connector block -->
            <rect x="4" y="18" width="16" height="28" rx="3" fill="#dce9ff"/>
            <rect x="4" y="18" width="16" height="28" rx="3" stroke="#00316c" stroke-width="2"/>
            <!-- Left pins -->
            <rect x="8"  y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <rect x="13" y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <!-- Left socket holes (white-filled) -->
            <circle cx="9"  cy="28" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="15" cy="28" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="9"  cy="37" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="15" cy="37" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <!-- Orange locking tab on right edge of left connector -->
            <rect x="19" y="27" width="5" height="10" rx="1.5" fill="#ff671f"/>
            <!-- Right connector block -->
            <rect x="44" y="18" width="16" height="28" rx="3" fill="#dce9ff"/>
            <rect x="44" y="18" width="16" height="28" rx="3" stroke="#00316c" stroke-width="2"/>
            <!-- Right pins -->
            <rect x="48" y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <rect x="53" y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <!-- Right socket holes (white-filled) -->
            <circle cx="49" cy="28" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="55" cy="28" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="49" cy="37" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="55" cy="37" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <!-- 4 wires -->
            <path d="M20 25 C28 25 36 27 44 27" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M20 30 L44 30"             stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M20 35 L44 34"             stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M20 39 C28 39 36 37 44 37" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Wire bundle clip -->
            <rect x="30" y="26" width="5" height="12" rx="2.5" fill="#dce9ff" stroke="#00316c" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Wire Harness Design (EHI)</span>
      </a>

      <!-- 4. Tooling Design -->
      <a href={withBase('/capabilities/tooling-design')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Base fixture plate -->
            <rect x="6" y="50" width="52" height="9" rx="2" fill="#dce9ff"/>
            <rect x="6" y="50" width="52" height="9" rx="2" stroke="#00316c" stroke-width="2"/>
            <!-- Locating pins -->
            <rect x="10" y="43" width="4" height="8" rx="1" fill="#00316c"/>
            <rect x="50" y="43" width="4" height="8" rx="1" fill="#00316c"/>
            <!-- Left bushing body -->
            <circle cx="20" cy="36" r="10" fill="#dce9ff"/>
            <circle cx="20" cy="36" r="10" stroke="#00316c" stroke-width="2"/>
            <!-- Left bushing inner sleeve ring -->
            <circle cx="20" cy="36" r="6" fill="white" stroke="#00316c" stroke-width="1.5"/>
            <!-- Left drill hole -->
            <circle cx="20" cy="36" r="3" fill="#00316c"/>
            <!-- Right bushing body -->
            <circle cx="44" cy="36" r="10" fill="#dce9ff"/>
            <circle cx="44" cy="36" r="10" stroke="#00316c" stroke-width="2"/>
            <!-- Right bushing inner sleeve ring -->
            <circle cx="44" cy="36" r="6" fill="white" stroke="#00316c" stroke-width="1.5"/>
            <!-- Right drill hole -->
            <circle cx="44" cy="36" r="3" fill="#00316c"/>
            <!-- Bushing stems to base -->
            <line x1="20" y1="46" x2="20" y2="50" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="44" y1="46" x2="44" y2="50" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Clamp bar -->
            <rect x="10" y="14" width="44" height="8" rx="2" fill="#dce9ff"/>
            <rect x="10" y="14" width="44" height="8" rx="2" stroke="#00316c" stroke-width="2"/>
            <!-- Screw shaft -->
            <line x1="32" y1="22" x2="32" y2="36" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Thread marks -->
            <rect x="30" y="24" width="4" height="2" rx="0.5" fill="#00316c"/>
            <rect x="30" y="28" width="4" height="2" rx="0.5" fill="#00316c"/>
            <rect x="30" y="32" width="4" height="2" rx="0.5" fill="#00316c"/>
            <!-- T-handle (orange accent) -->
            <line x1="32" y1="6" x2="32" y2="14" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <rect x="24" y="4" width="16" height="5" rx="2" fill="#ff671f"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Tooling Design</span>
      </a>

      <!-- 5. Avionics (linkable) -->
      <a href={withBase('/capabilities/avionics')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Panel frame -->
            <rect x="4" y="8" width="56" height="48" rx="2.5" fill="#dce9ff"/>
            <rect x="4" y="8" width="56" height="48" rx="2.5" stroke="#00316c" stroke-width="2"/>
            <!-- Left altimeter gauge -->
            <circle cx="12" cy="26" r="8" fill="white"/>
            <circle cx="12" cy="26" r="8" stroke="#00316c" stroke-width="1.5"/>
            <line x1="12" y1="18" x2="12" y2="20" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="18" y1="22" x2="16.5" y2="23.5" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="20" y1="26" x2="18" y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="4"  y1="26" x2="6"  y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="12" y1="26" x2="15" y2="20" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <circle cx="12" cy="26" r="1.5" fill="#00316c"/>
            <!-- Right airspeed gauge -->
            <circle cx="52" cy="26" r="8" fill="white"/>
            <circle cx="52" cy="26" r="8" stroke="#00316c" stroke-width="1.5"/>
            <line x1="52" y1="18" x2="52" y2="20" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="58" y1="22" x2="56.5" y2="23.5" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="60" y1="26" x2="58" y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="44" y1="26" x2="46" y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="52" y1="26" x2="49" y2="20" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <circle cx="52" cy="26" r="1.5" fill="#00316c"/>
            <!-- PFD center screen -->
            <rect x="20" y="12" width="24" height="24" rx="1.5" fill="white" stroke="#00316c" stroke-width="1.5"/>
            <!-- Sky tint -->
            <rect x="21" y="13" width="22" height="11" rx="1" fill="#00316c" opacity="0.10"/>
            <!-- Ground tint -->
            <rect x="21" y="24" width="22" height="11" rx="1" fill="#00316c" opacity="0.06"/>
            <!-- Artificial horizon line -->
            <line x1="22" y1="24" x2="42" y2="24" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Aircraft crosshair -->
            <line x1="27" y1="26" x2="31" y2="26" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="33" y1="26" x2="37" y2="26" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="22" x2="32" y2="28" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Altitude tape -->
            <rect x="40" y="13" width="3" height="22" rx="0.5" fill="#00316c" opacity="0.08" stroke="#00316c" stroke-width="1"/>
            <line x1="41" y1="17" x2="43" y2="17" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="41" y1="21" x2="43" y2="21" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="41" y1="25" x2="43" y2="25" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="41" y1="29" x2="43" y2="29" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <!-- Bottom indicator row -->
            <rect x="6"  y="42" width="14" height="9" rx="1.5" fill="#00316c" opacity="0.10" stroke="#00316c" stroke-width="1"/>
            <rect x="25" y="42" width="14" height="9" rx="1.5" fill="#00316c" opacity="0.10" stroke="#00316c" stroke-width="1"/>
            <!-- Orange warning light -->
            <rect x="44" y="42" width="14" height="9" rx="1.5" fill="#ff671f" opacity="0.85"/>
            <rect x="44" y="42" width="14" height="9" rx="1.5" stroke="#00316c" stroke-width="1"/>
            <line x1="51" y1="44" x2="51" y2="47" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="51" cy="49" r="0.8" fill="white"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Avionics</span>
      </a>

      <!-- 6. Product Development -->
      <a href={withBase('/capabilities/product-development#aerospace')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Iterate / refresh arrows wrapping the gear -->
            <path d="M59 25 A28 28 0 0 0 5 25" stroke="#00316c" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <polygon points="4.5,26.9 9.9,22.1 2.1,20.1" fill="#00316c"/>
            <path d="M5 39 A28 28 0 0 0 59 39" stroke="#00316c" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <polygon points="59.5,37.1 61.9,43.9 54.1,41.9" fill="#00316c"/>
            <!-- Gear body fill (light blue) -->
            <circle cx="32" cy="32" r="15" fill="#dce9ff"/>
            <!-- Gear teeth (8, rotate around 32,32) -->
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(0   32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(45  32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(90  32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(135 32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(180 32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(225 32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(270 32 32)"/>
            <rect x="29.5" y="13" width="5" height="7" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(315 32 32)"/>
            <!-- Gear ring outline -->
            <circle cx="32" cy="32" r="15" stroke="#00316c" stroke-width="2"/>
            <!-- Gear depth tint (lower half) -->
            <path d="M17 32 A15 15 0 0 0 47 32 Z" fill="#00316c" opacity="0.08"/>
            <!-- Cube faces (fills) -->
            <polygon points="32,23 40,28 32,33 24,28" fill="white"/>
            <polygon points="24,28 32,33 32,42 24,37" fill="white"/>
            <polygon points="24,28 32,33 32,42 24,37" fill="#00316c" opacity="0.06"/>
            <polygon points="40,28 32,33 32,42 40,37" fill="white"/>
            <polygon points="40,28 32,33 32,42 40,37" fill="#00316c" opacity="0.12"/>
            <!-- Cube outline + interior upper edges -->
            <polygon points="32,23 40,28 40,37 32,42 24,37 24,28" fill="none" stroke="#00316c" stroke-width="1.5" stroke-linejoin="round"/>
            <line x1="24" y1="28" x2="32" y2="33" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="40" y1="28" x2="32" y2="33" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Orange front edge accent -->
            <line x1="32" y1="33" x2="32" y2="42" stroke="#ff671f" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Product Development</span>
      </a>

      <!-- 7. Manufacturing (linkable) -->
      <a href={withBase('/capabilities/manufacturing')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary btn-press-card cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Large gear body fill -->
            <circle cx="28" cy="34" r="20" fill="#dce9ff"/>
            <!-- Large gear teeth (8, rotate around 28,34) -->
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(0   28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(45  28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(90  28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(135 28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(180 28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(225 28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(270 28 34)"/>
            <rect x="26" y="9" width="4" height="8" rx="1" fill="#dce9ff" stroke="#00316c" stroke-width="1.5" transform="rotate(315 28 34)"/>
            <!-- Large gear ring outline -->
