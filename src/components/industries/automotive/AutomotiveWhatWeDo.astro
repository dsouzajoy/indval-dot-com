---
import { withBase } from '@/lib/utils';
---

<section class="py-12 px-8">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-10">
      What We Do
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <!-- BIW Turnkey Solutions -->
      <a href={withBase('/capabilities/biw-turnkey-solutions')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Base: car body silhouette -->
            <path d="M6 38 L6 48 Q6 50 8 50 L56 50 Q58 50 58 48 L58 38 L50 24 Q48 20 44 20 L20 20 Q16 20 14 24 Z" fill="#dce9ff"/>
            <!-- Roof -->
            <path d="M20 20 L24 10 Q25 8 28 8 L36 8 Q39 8 40 10 L44 20 Z" fill="#dce9ff"/>
            <!-- Structural detail: A-pillar, B-pillar, sill -->
            <line x1="20" y1="20" x2="24" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="44" y1="20" x2="40" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="20" x2="32" y2="38" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Sill line -->
            <line x1="8" y1="38" x2="56" y2="38" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Roof rail -->
            <path d="M24 10 L40 10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Wheels -->
            <circle cx="18" cy="50" r="6" fill="#00316c"/>
            <circle cx="18" cy="50" r="3" fill="#dce9ff"/>
            <circle cx="46" cy="50" r="6" fill="#00316c"/>
            <circle cx="46" cy="50" r="3" fill="#dce9ff"/>
            <!-- Joint nodes -->
            <circle cx="20" cy="20" r="2.5" fill="#00316c"/>
            <circle cx="44" cy="20" r="2.5" fill="#00316c"/>
            <circle cx="32" cy="20" r="2.5" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">BIW Turnkey Solutions</span>
      </a>

      <!-- Die Design -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Upper die base shape -->
            <rect x="10" y="6" width="44" height="16" rx="3" fill="#dce9ff"/>
            <!-- Lower die base shape -->
            <rect x="10" y="42" width="44" height="16" rx="3" fill="#dce9ff"/>
            <!-- Upper die detail face -->
            <rect x="10" y="6" width="44" height="16" rx="3" fill="none" stroke="#00316c" stroke-width="1.5"/>
            <!-- Lower die detail face -->
            <rect x="10" y="42" width="44" height="16" rx="3" fill="none" stroke="#00316c" stroke-width="1.5"/>
            <!-- Die cavity in lower -->
            <path d="M18 42 L18 46 Q32 52 46 46 L46 42" fill="#00316c" opacity="0.15"/>
            <path d="M18 42 L18 46 Q32 52 46 46 L46 42" stroke="#00316c" stroke-width="1.5" fill="none"/>
            <!-- Sheet metal workpiece -->
            <rect x="14" y="30" width="36" height="5" rx="1.5" fill="#00316c"/>
            <!-- Press arrow -->
            <line x1="32" y1="22" x2="32" y2="28" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <polyline points="28,26 32,30 36,26" stroke="#00316c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Die Design</span>
      </div>

      <!-- Wire Harnessing -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Connector block base -->
            <rect x="40" y="20" width="16" height="24" rx="3" fill="#dce9ff"/>
            <rect x="40" y="20" width="16" height="24" rx="3" stroke="#00316c" stroke-width="1.5"/>
            <!-- Connector pins -->
            <rect x="44" y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <rect x="50" y="16" width="3" height="6" rx="1" fill="#00316c"/>
            <!-- Connector socket holes -->
            <circle cx="46" cy="28" r="2" fill="#00316c"/>
            <circle cx="52" cy="28" r="2" fill="#00316c"/>
            <circle cx="46" cy="36" r="2" fill="#00316c"/>
            <circle cx="52" cy="36" r="2" fill="#00316c"/>
            <!-- Wires converging -->
            <path d="M8 16 C24 16, 32 28, 40 28" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M8 22 C22 22, 32 28, 40 28" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M8 32 L40 32" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M8 42 C22 42, 32 36, 40 36" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M8 48 C24 48, 32 36, 40 36" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- Wire clip/band -->
            <rect x="22" y="25" width="4" height="14" rx="2" fill="#dce9ff" stroke="#00316c" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Wire Harnessing</span>
      </div>

      <!-- Computational Fluid Dynamics -->
      <a href={withBase('/capabilities/cfd')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Airfoil base shape filled -->
            <path d="M18 32 C18 24 26 18 36 20 C44 22 48 28 48 32 C48 36 44 42 36 44 C26 46 18 40 18 32 Z" fill="#dce9ff"/>
            <path d="M18 32 C18 24 26 18 36 20 C44 22 48 28 48 32 C48 36 44 42 36 44 C26 46 18 40 18 32 Z" stroke="#00316c" stroke-width="1.5"/>
            <!-- Streamlines - navy -->
            <path d="M4 16 C10 16 14 20 18 24" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 24 C8 24 12 26 16 29" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 32 L16 32" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 40 C8 40 12 38 16 35" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M4 48 C10 48 14 44 18 40" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 26 C52 25 56 22 60 20" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 32 L60 32" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M48 38 C52 39 56 42 60 44" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Computational Fluid Dynamics</span>
      </a>

      <!-- Finite Element Analysis -->
      <a href={withBase('/capabilities/fea')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Filled triangles alternating for dual-tone mesh -->
            <polygon points="8,8 26,8 8,26" fill="#dce9ff"/>
            <polygon points="26,8 44,8 26,26" fill="#dce9ff"/>
            <polygon points="44,8 62,8 44,26" fill="#dce9ff"/>
            <polygon points="8,26 26,26 8,44" fill="#dce9ff"/>
            <polygon points="26,26 44,26 26,44" fill="#dce9ff"/>
            <polygon points="44,26 62,26 44,44" fill="#dce9ff"/>
            <polygon points="8,44 26,44 8,62" fill="#dce9ff"/>
            <polygon points="26,44 44,44 26,62" fill="#dce9ff"/>
            <polygon points="44,44 62,44 44,62" fill="#dce9ff"/>
            <!-- Accent triangles -->
            <polygon points="8,8 26,26 8,26" fill="#00316c" opacity="0.15"/>
            <polygon points="26,8 44,26 26,26" fill="#00316c" opacity="0.15"/>
            <polygon points="8,26 26,44 8,44" fill="#00316c" opacity="0.15"/>
            <!-- Grid lines -->
            <line x1="8" y1="8" x2="62" y2="8" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="26" x2="62" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="44" x2="62" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="62" x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="8" x2="8" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="8" x2="26" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="8" x2="44" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="62" y1="8" x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <!-- Diagonals -->
            <line x1="8" y1="8" x2="26" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="8" x2="44" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="8" x2="62" y2="26" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="26" x2="26" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="26" x2="44" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="26" x2="62" y2="44" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8" y1="44" x2="26" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="26" y1="44" x2="44" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <line x1="44" y1="44" x2="62" y2="62" stroke="#00316c" stroke-width="1.5"/>
            <!-- Nodes -->
            <circle cx="8" cy="8" r="2" fill="#00316c"/>
            <circle cx="26" cy="8" r="2" fill="#00316c"/>
            <circle cx="44" cy="8" r="2" fill="#00316c"/>
            <circle cx="62" cy="8" r="2" fill="#00316c"/>
            <circle cx="8" cy="26" r="2" fill="#00316c"/>
            <circle cx="26" cy="26" r="2" fill="#00316c"/>
            <circle cx="44" cy="26" r="2" fill="#00316c"/>
            <circle cx="62" cy="26" r="2" fill="#00316c"/>
            <circle cx="8" cy="44" r="2" fill="#00316c"/>
            <circle cx="26" cy="44" r="2" fill="#00316c"/>
            <circle cx="44" cy="44" r="2" fill="#00316c"/>
            <circle cx="62" cy="44" r="2" fill="#00316c"/>
            <circle cx="8" cy="62" r="2" fill="#00316c"/>
            <circle cx="26" cy="62" r="2" fill="#00316c"/>
            <circle cx="44" cy="62" r="2" fill="#00316c"/>
            <circle cx="62" cy="62" r="2" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Finite Element Analysis</span>
      </a>

      <!-- Jigs & Fixtures -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- C-clamp body base (light) -->
            <path d="M20 8 L44 8 L44 56 L20 56 L20 48 L12 44 L12 20 L20 16 Z" fill="#dce9ff"/>
            <!-- C-clamp outline -->
            <line x1="20" y1="10" x2="42" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="20" y1="54" x2="42" y2="54" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <path d="M20 10 Q10 10 10 20" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M20 54 Q10 54 10 44" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <line x1="10" y1="20" x2="10" y2="44" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Screw shaft -->
            <line x1="42" y1="10" x2="42" y2="6" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="38" y1="6" x2="46" y2="6" stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="42" y1="10" x2="42" y2="28" stroke="#00316c" stroke-width="2" stroke-linecap="round" stroke-dasharray="3,2"/>
            <!-- Pressure pad -->
            <rect x="36" y="28" width="12" height="5" rx="1.5" fill="#00316c"/>
            <!-- Workpiece -->
            <rect x="16" y="34" width="18" height="16" rx="2" fill="#00316c" opacity="0.2"/>
            <rect x="16" y="34" width="18" height="16" rx="2" stroke="#00316c" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Jigs & Fixtures</span>
      </div>

      <!-- Cubing & Control Gauges -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Gauge base circle (light fill) -->
            <circle cx="32" cy="34" r="24" fill="#dce9ff"/>
            <circle cx="32" cy="34" r="24" stroke="#00316c" stroke-width="1.5"/>
            <!-- Inner ring -->
            <circle cx="32" cy="34" r="18" stroke="#00316c" stroke-width="1" opacity="0.3"/>
            <!-- Tick marks -->
            <line x1="32" y1="11" x2="32" y2="16" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="15" y1="19" x2="18.5" y2="23" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="9" y1="34" x2="14" y2="34" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="49" y1="19" x2="45.5" y2="23" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="55" y1="34" x2="50" y2="34" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="19" y1="50" x2="22" y2="46" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="45" y1="50" x2="42" y2="46" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Needle -->
            <line x1="32" y1="34" x2="46" y2="21" stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Center cap -->
            <circle cx="32" cy="34" r="4" fill="#00316c"/>
            <circle cx="32" cy="34" r="2" fill="#dce9ff"/>
            <!-- Scale arc highlight (orange accent zone) -->
            <path d="M14 48 A22 22 0 0 1 50 48" stroke="#ff671f" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Cubing & Control Gauges</span>
      </div>

    </div>
  </div>
</section>
