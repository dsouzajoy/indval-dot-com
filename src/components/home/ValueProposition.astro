---
import { en } from '@/i18n/locales/en';

const articles = [
  {
    icon: 'gpp_good',
    title: en.thought.articles.clientSuccess.title,
    description: en.thought.articles.clientSuccess.description,
    titleKey: 'thought.articles.clientSuccess.title',
    descKey: 'thought.articles.clientSuccess.description',
  },
  {
    icon: 'rocket_launch',
    title: en.thought.articles.veteranExpertise.title,
    description: en.thought.articles.veteranExpertise.description,
    titleKey: 'thought.articles.veteranExpertise.title',
    descKey: 'thought.articles.veteranExpertise.description',
  },
  {
    icon: 'payments',
    title: en.thought.articles.costEffective.title,
    description: en.thought.articles.costEffective.description,
    titleKey: 'thought.articles.costEffective.title',
    descKey: 'thought.articles.costEffective.description',
  },
  {
    icon: 'trending_up',
    title: en.thought.articles.continuousImprovement.title,
    description: en.thought.articles.continuousImprovement.description,
    titleKey: 'thought.articles.continuousImprovement.title',
    descKey: 'thought.articles.continuousImprovement.description',
  },
];
---
<section id="quality" class="bg-surface-container-lowest py-20 md:py-32 px-4 sm:px-6 lg:px-8 overflow-hidden relative" aria-label="Thought leadership">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">

    <!-- Left: sticky header -->
    <div class="lg:col-span-4 lg:sticky lg:top-32">
      <h2
        class="font-sans font-black text-4xl lg:text-5xl text-primary leading-tight mb-6"
        data-i18n="thought.heading"
      >
        {en.thought.heading}
      </h2>
      <p
        class="font-sans text-on-surface-variant text-base lg:text-lg leading-relaxed mb-8"
        data-i18n="thought.description"
      >
        {en.thought.description}
      </p>
      <div class="h-px w-20 bg-secondary mb-6"></div>
      <p
        class="font-label text-sm uppercase tracking-[0.3em] text-secondary font-bold"
        data-i18n="thought.label"
      >
        {en.thought.label}
      </p>
    </div>

    <!-- Right: 2x2 article grid -->
    <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-12">
      {articles.map(({ icon, title, description, titleKey, descKey }) => (
        <div>
          <h4 class="font-sans font-bold text-lg lg:text-xl text-primary mb-3 flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary shrink-0">{icon}</span>
            <span data-i18n={titleKey}>{title}</span>
          </h4>
          <p
            class="font-sans text-on-surface-variant text-sm leading-relaxed"
            data-i18n={descKey}
          >
            {description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
