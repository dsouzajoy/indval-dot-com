---
import { Image } from 'astro:assets';
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';
import CapabilityCard from '@/components/ui/CapabilityCard.astro';

import introImg from '@/assets/images/inspection-metrology/intro.jpg';
import cmmImg from '@/assets/images/inspection-metrology/cmm-inspection.jpg';
import vmmImg from '@/assets/images/inspection-metrology/vmm-inspection.jpg';
import precisionGaugingImg from '@/assets/images/inspection-metrology/precision-gauging.jpg';
import surfaceRoughnessImg from '@/assets/images/inspection-metrology/surface-roughness.jpg';
import contourMeasurementImg from '@/assets/images/inspection-metrology/contour-measurement.jpg';
import firstArticleInspectionImg from '@/assets/images/inspection-metrology/first-article-inspection.jpg';
import dimensionalValidationImg from '@/assets/images/inspection-metrology/dimensional-validation.jpg';
import qualityDocumentationImg from '@/assets/images/inspection-metrology/quality-documentation.jpg';

const im = en.inspectionMetrology;

const capabilities = [
  { key: 'cmmInspection', icon: 'straighten', image: cmmImg, data: im.capabilities.cmmInspection },
  { key: 'vmmInspection', icon: 'visibility', image: vmmImg, data: im.capabilities.vmmInspection },
  { key: 'precisionGauging', icon: 'rule', image: precisionGaugingImg, data: im.capabilities.precisionGauging },
  { key: 'surfaceRoughnessTesting', icon: 'texture', image: surfaceRoughnessImg, data: im.capabilities.surfaceRoughnessTesting },
  { key: 'contourMeasurement', icon: 'timeline', image: contourMeasurementImg, data: im.capabilities.contourMeasurement },
  { key: 'firstArticleInspection', icon: 'fact_check', image: firstArticleInspectionImg, data: im.capabilities.firstArticleInspection },
  { key: 'dimensionalValidation', icon: 'verified', image: dimensionalValidationImg, data: im.capabilities.dimensionalValidation },
  { key: 'qualityDocumentation', icon: 'description', image: qualityDocumentationImg, data: im.capabilities.qualityDocumentation },
];

const whyUs = [
  { key: 'advancedEquipment', icon: 'precision_manufacturing', label: im.whyUs.advancedEquipment },
  { key: 'accurateProcesses', icon: 'verified', label: im.whyUs.accurateProcesses },
  { key: 'prototypeAndProduction', icon: 'science', label: im.whyUs.prototypeAndProduction },
  { key: 'comprehensiveReporting', icon: 'assignment_turned_in', label: im.whyUs.comprehensiveReporting },
  { key: 'improvedProcessControl', icon: 'trending_up', label: im.whyUs.improvedProcessControl },
  { key: 'commitmentToPrecision', icon: 'workspace_premium', label: im.whyUs.commitmentToPrecision },
];
---

<!-- INTRO -->
<section class="bg-surface">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="inspectionMetrology.intro.eyebrow"
      >{im.intro.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold leading-tight tracking-tight text-primary text-balance"
        data-i18n="inspectionMetrology.intro.heading"
      >{im.intro.heading}</h2>
      <p
        class="mt-6 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="inspectionMetrology.intro.para1"
      >{im.intro.para1}</p>
      <p
        class="mt-5 text-lg leading-relaxed text-on-surface-variant"
        data-i18n="inspectionMetrology.intro.para2"
      >{im.intro.para2}</p>
    </div>
    <div class="rounded overflow-hidden shadow-lg aspect-[4/3]">
      <Image
        src={introImg}
        alt="Quality engineer reviewing precision measurement data on a workstation"
        format="avif"
        quality={100}
        width={800}
        height={600}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
  </div>
</section>

<!-- CAPABILITIES -->
<section id="capabilities" class="bg-surface py-24 lg:py-30" style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <p
          class="font-label text-sm uppercase tracking-widest text-secondary mb-3"
          data-i18n="inspectionMetrology.capabilities.eyebrow"
        >{im.capabilities.eyebrow}</p>
        <h2
          class="font-headline text-4xl lg:text-5xl font-bold text-on-surface"
          data-i18n="inspectionMetrology.capabilities.heading"
        >{im.capabilities.heading}</h2>
      </div>
      <p
        class="text-sm text-on-surface-variant font-label max-w-xs md:text-right shrink-0 leading-relaxed"
        data-i18n="inspectionMetrology.capabilities.intro"
      >{im.capabilities.intro}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {capabilities.map((cap) => (
        <CapabilityCard
          image={cap.image}
          icon={cap.icon}
          label={cap.data.label}
          description={cap.data.description}
          labelKey={`inspectionMetrology.capabilities.${cap.key}.label`}
          descriptionKey={`inspectionMetrology.capabilities.${cap.key}.description`}
        />
      ))}
    </div>

  </div>
</section>

<!-- WHY CHOOSE US -->
<section class="relative bg-on-surface overflow-hidden">
  <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.04) 1.5px, transparent 1.5px); background-size: 32px 32px;"></div>
  <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(0,49,108,0.15) 0%, rgba(11,28,48,0.4) 100%);"></div>
  <div class="relative max-w-7xl mx-auto px-8 lg:px-16 py-20">
    <div class="mb-11 max-w-2xl">
      <p
        class="font-label font-bold text-sm uppercase tracking-widest text-secondary"
        data-i18n="inspectionMetrology.whyUs.eyebrow"
      >{im.whyUs.eyebrow}</p>
      <h2
        class="mt-2 text-3xl lg:text-4xl font-bold tracking-tight text-white"
        data-i18n="inspectionMetrology.whyUs.heading"
      >{im.whyUs.heading}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {whyUs.map(({ key, icon, label }) => (
        <div class="flex items-start gap-4 bg-white/5 border border-white/10 rounded p-6">
          <span class="material-symbols-outlined text-secondary shrink-0" style="font-size: 28px; font-variation-settings: 'FILL' 1">{icon}</span>
          <p
            class="text-base font-semibold text-white leading-snug"
            data-i18n={`inspectionMetrology.whyUs.${key}`}
          >{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CLOSING BRAND STATEMENT + CTA -->
<section class="bg-on-surface py-20 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 text-center">
    <h2
      class="font-headline text-3xl lg:text-4xl font-bold text-white mb-4 max-w-3xl mx-auto text-balance"
      data-i18n="inspectionMetrology.cta.heading"
    >{im.cta.heading}</h2>
    <p
      class="text-white/80 text-base mb-10 max-w-2xl mx-auto leading-relaxed"
      data-i18n="inspectionMetrology.cta.body"
    >{im.cta.body}</p>
    <a
      href={withBase('/contact#contact-form')}
      class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-secondary/90 btn-press"
      data-i18n="inspectionMetrology.cta.button"
    >{im.cta.button}</a>
  </div>
</section>
