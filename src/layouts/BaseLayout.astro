---
import BaseHead, { type BreadcrumbItem } from '../components/seo/BaseHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Splash from '../components/layout/Splash.astro';
import I18nRuntime from '../components/i18n/I18nRuntime.astro';
import CookieBanner from '../components/legal/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  showSplash?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
  ogImage,
  showSplash = false,
  breadcrumbs,
  noindex = false,
} = Astro.props;

---
<!doctype html>
<html lang="en">
  <head>
    <!-- FOUC prevention: hide translatable nodes before runtime script fires for non-English users -->
    <script is:inline>
      (function() {
        var s = localStorage.getItem('lang');
        if (s && s !== 'en' && ['de','pl'].indexOf(s) !== -1)
          document.documentElement.setAttribute('data-lang', s);
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      canonicalURL={canonicalURL}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      noindex={noindex}
    />
  </head>
  <body class="min-h-screen flex flex-col font-sans bg-surface text-on-surface">
    {showSplash && <Splash />}
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <I18nRuntime />
  </body>
</html>
