---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';

const { apply } = en.careers;
---

<section class="py-20 md:py-24 bg-surface-container-low overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-8 relative">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

      <!-- Left: text content -->
      <div>
        <span
          class="font-label text-secondary font-bold text-xs uppercase tracking-widest block mb-4"
          data-i18n="careers.apply.eyebrow"
        >{apply.eyebrow}</span>

        <h2
          class="text-primary font-headline font-black text-4xl md:text-5xl mb-8 leading-tight tracking-tighter"
          data-i18n="careers.apply.heading"
        >{apply.heading}</h2>

        <div class="space-y-6 text-on-surface-variant mb-10">
          <p class="text-base md:text-lg leading-relaxed">
            <span data-i18n="careers.apply.body">{apply.body}</span>
            {' '}
            <a
              href="mailto:hr@indvaltech.com"
              class="font-headline font-bold text-primary hover:text-primary-container transition-colors"
            >hr@indvaltech.com</a>
          </p>

          <!-- Subject line callout -->
          <p
            class="p-5 bg-surface-container-high border-l-4 border-secondary rounded-r font-label text-on-surface text-sm leading-relaxed"
            data-i18n="careers.apply.subjectHint"
          >
            <span class="font-black">SUBJECT LINE: </span>{apply.subjectHint.replace('SUBJECT LINE: ', '')}
          </p>

          <!-- Bullet points -->
          <ul class="space-y-3">
            {[
              { key: 'careers.apply.bullet1', text: apply.bullet1 },
              { key: 'careers.apply.bullet2', text: apply.bullet2 },
              { key: 'careers.apply.bullet3', text: apply.bullet3 },
            ].map(({ key, text }) => (
              <li class="flex items-start gap-3">
                <div class="w-2 h-2 rounded-full bg-secondary mt-2 shrink-0"></div>
                <p class="text-sm font-bold text-on-surface" data-i18n={key}>{text}</p>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA -->
        <a
          href="mailto:hr@indvaltech.com"
          class="inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-primary-container btn-press"
          data-i18n="careers.apply.cta"
        >
          {apply.cta}
        </a>
      </div>

      <!-- Right: image with decorative blobs (hidden on small mobile, shown md+) -->
      <div class="relative hidden sm:block">
        <div class="rounded overflow-hidden shadow-ambient-lg relative z-10 aspect-square">
          <img
            src={withBase('/images/pexels/application-team.jpeg')}
            alt="Engineering team collaborating"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <!-- Decorative blurred circles -->
        <div class="absolute -top-10 -right-10 w-56 h-56 bg-primary/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-56 h-56 bg-secondary/10 rounded-full blur-3xl pointer-events-none"></div>
      </div>

    </div>
  </div>
</section>
