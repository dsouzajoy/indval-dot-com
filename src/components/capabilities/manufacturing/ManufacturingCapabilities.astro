---
import { withBase } from '@/lib/utils';
import CapabilityCard from '@/components/ui/CapabilityCard.astro';
import mfgMachiningImg from '@/assets/images/manufacturing-machining.jpg';
import mfgCastingsImg from '@/assets/images/manufacturing-castings.jpg';
import mfgSheetMetalImg from '@/assets/images/manufacturing-sheet-metal.jpg';
import mfgKittingImg from '@/assets/images/manufacturing-kitting.jpg';
import mfgAssemblyToolingImg from '@/assets/images/manufacturing-assembly-tooling.jpg';
import mfgRapidPrototypingImg from '@/assets/images/manufacturing-rapid-prototyping.jpg';
import mfgWeldFabricationImg from '@/assets/images/manufacturing-weld-fabrication.jpg';
import reHeroImg from '@/assets/images/reverse-engineering-hero.jpg';
import mfgInspectionMetrologyImg from '@/assets/images/manufacturing-inspection-metrology.jpg';
const capabilities = [
  {
    id: 'machining',
    label: 'Machining',
    icon: 'precision_manufacturing',
    image: mfgMachiningImg,
    description: 'Specialized high-precision CNC machining solutions supported by advanced multi-axis facilities to meet complex engineering tolerances.',
    href: '/capabilities/cnc-machining',
  },
  {
    id: 'castings',
    label: 'Castings',
    icon: 'format_paint',
    image: mfgCastingsImg,
    description: 'Highly diversified range of investment and sand castings with intricate geometries.',
    href: '/capabilities/casting',
  },
  {
    id: 'sheet-metal',
    label: 'Sheet Metal',
    icon: 'layers',
    image: mfgSheetMetalImg,
    description: 'Custom fabrication and premium finish services including laser cutting and complex assembly.',
    href: '/capabilities/sheet-metal',
  },
  {
    id: 'kitting-and-assemblies',
    label: 'Kitting and Assemblies',
    icon: 'inventory_2',
    image: mfgKittingImg,
    description: 'End-to-end integration for complex sourcing needs, providing complete solutions from individual sub-components to full-scale mechanical assemblies.',
    href: '/capabilities/kitting-and-assembly',
  },
  {
    id: 'assembly-tooling',
    label: 'Assembly Tooling',
    icon: 'handyman',
    image: mfgAssemblyToolingImg,
    description: 'Design and production of precision aerostructure assembly frames, jigs, and sub-assembly equipment optimized for industrial performance and safety standards.',
    href: '/capabilities/assembly-tooling',
  },
  {
    id: 'weld-fabrication',
    label: 'Weld Fabrication',
    icon: 'whatshot',
    image: mfgWeldFabricationImg,
    description: 'Structural and precision weld fabrication across a range of materials including steel, aluminum, and specialty alloys, with capabilities spanning MIG, TIG, and resistance welding for aerospace, industrial, and defense applications.',
    href: '/coming-soon',
  },
  {
    id: 'rapid-prototyping',
    label: 'Rapid Prototyping',
    icon: '3d_rotation',
    image: mfgRapidPrototypingImg,
    description: 'Accelerated prototyping services utilizing advanced additive manufacturing and rapid tooling to validate designs and bridge the gap to production.',
    href: '/capabilities/rapid-prototyping',
  },
  {
    id: 'reverse-engineering',
    label: 'Reverse Engineering',
    icon: 'manage_search',
    image: reHeroImg,
    description: 'Comprehensive dimensional analysis and CAD reconstruction from physical parts, enabling design validation, legacy part digitization, and engineering improvements.',
    href: '/capabilities/reverse-engineering',
  },
  {
    id: 'inspection-metrology',
    label: 'Inspection & Metrology',
    icon: 'straighten',
    image: mfgInspectionMetrologyImg,
    description: 'Precision dimensional inspection and quality validation using CMM, VMM, and advanced measurement technologies to ensure every component meets specification.',
    href: '/capabilities/inspection-metrology',
  },
];
---

<section id="capabilities" class="bg-surface py-30" style="background-image: radial-gradient(circle, rgba(195,198,211,0.8) 1px, transparent 1px); background-size: 40px 40px;">
  <div class="max-w-7xl mx-auto px-8 lg:px-16">

    <!-- Section heading -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
      <div>
        <p class="font-label text-sm uppercase tracking-widest text-secondary mb-3">Core Competencies</p>
        <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface">
          Our Manufacturing Capabilities
        </h2>
      </div>
      <p class="text-sm text-on-surface-variant font-label max-w-xs md:text-right shrink-0">
        Technical expertise across multi-material processes and precision engineering standards.
      </p>
    </div>

    <!-- Bento card grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {capabilities.map((cap) => (
        <CapabilityCard
          id={cap.id}
          image={cap.image}
          label={cap.label}
          icon={cap.icon}
          description={cap.description}
          href={cap.href}
        />
      ))}
    </div>

  </div>
</section>

<!-- CTA Banner -->
<section class="bg-on-surface py-20">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 text-center">
    <h2 class="font-headline text-3xl lg:text-4xl font-bold text-white mb-4">
      Accelerate Your Manufacturing Engineering
    </h2>
    <p class="text-white/80 text-base mb-10 max-w-xl mx-auto leading-relaxed">
      Partner with our manufacturing specialists to streamline your production processes, from process planning and simulation to full industrialization support.
    </p>
    <a
      href={withBase('/contact#contact-form')}
      class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-secondary/90 btn-press"
    >
      Get In Touch
    </a>
  </div>
</section>
