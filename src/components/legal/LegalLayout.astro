---
interface Props {
  title: string;
  effectiveDate?: string;
}

const { title, effectiveDate } = Astro.props;
---

<article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
  <header class="mb-12 pb-8 border-b border-outline-variant">
    <p class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-3">Legal</p>
    <h1 class="font-headline font-black text-4xl sm:text-5xl text-on-surface tracking-tight mb-4">{title}</h1>
    {effectiveDate && (
      <p class="text-sm text-on-surface-variant">Effective date: {effectiveDate}</p>
    )}
  </header>

  <div class="prose-legal">
    <slot />
  </div>
</article>

<style>
  .prose-legal :global(h2) {
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-secondary);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .prose-legal :global(h3) {
    font-family: var(--font-label);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-on-surface);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose-legal :global(p) {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-on-surface-variant);
    margin-bottom: 1rem;
    max-width: 68ch;
  }

  .prose-legal :global(ul) {
    margin: 0.75rem 0 1rem 1.25rem;
    list-style-type: disc;
  }

  .prose-legal :global(li) {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.4rem;
  }

  .prose-legal :global(a) {
    color: var(--color-primary);
    text-underline-offset: 3px;
  }

  .prose-legal :global(a:hover) {
    color: var(--color-primary-container);
  }

  .prose-legal :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose-legal :global(th) {
    text-align: left;
    font-family: var(--font-label);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-on-surface);
    padding: 0.6rem 0.75rem;
    background: var(--color-surface-container-high);
    border-bottom: 2px solid var(--color-outline-variant);
  }

  .prose-legal :global(td) {
    padding: 0.6rem 0.75rem;
    color: var(--color-on-surface-variant);
    border-bottom: 1px solid var(--color-outline-variant);
    vertical-align: top;
  }

  .prose-legal :global(strong) {
    color: var(--color-on-surface);
    font-weight: 600;
  }

  .prose-legal :global(code) {
    font-family: ui-monospace, monospace;
    font-size: 0.8125rem;
    background: var(--color-surface-container-high);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    color: var(--color-on-surface);
  }
</style>
