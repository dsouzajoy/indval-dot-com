---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AutomotiveIntro from '../../components/industries/automotive/AutomotiveIntro.astro';
import AutomotiveTabs from '../../components/industries/automotive/AutomotiveTabs.astro';
import AutomotiveWhatWeDo from '../../components/industries/automotive/AutomotiveWhatWeDo.astro';
---

<BaseLayout
  title="Automotive | Indvaltech Engineering Services"
  description="Precision design and development of cockpit systems, exterior assemblies, and interior trims for global automotive programmes."
  showSplash={false}
  breadcrumbs={[{ name: 'Automotive', href: '/industries/automotive' }]}
>
  <div style="background-image: linear-gradient(to right, rgba(0,49,108,0.05) 1px, transparent 1px), linear-gradient(to bottom, rgba(0,49,108,0.05) 1px, transparent 1px); background-size: 40px 40px;">
    <AutomotiveIntro />
    <AutomotiveWhatWeDo />
    <AutomotiveTabs />
  </div>
</BaseLayout>
