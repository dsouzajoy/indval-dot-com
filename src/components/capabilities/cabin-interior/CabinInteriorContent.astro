  { component: 'Insulation Blankets', scope: 'Thermal and acoustic design' },
  { component: 'Floor Panels', scope: 'Structural analysis, weight and load calculations' },
  { component: 'Carpets', scope: 'Specification and supplier qualification documents' },
  { component: 'Seat Tracks & Covers', scope: 'Design to EASA CS-25 / FAR 25 seat track standards' },
  { component: 'Floor Path Marking', scope: 'Layout, illumination design' },
  { component: 'Dado Panels', scope: 'Composite design, bracket and attachment' },
  { component: 'Ceiling Panels', scope: 'Composite lay-up and attachment design' },
  { component: 'PSU Channels & Coverings', scope: 'Structural and MEP integration' },
  { component: 'Lighting Systems', scope: 'Lumen calculations, fixture integration' },
  { component: 'Placards & Signage', scope: 'Specification, layout, regulatory compliance' },
  { component: 'Bulkheads', scope: 'Primary and secondary structural design' },
  { component: 'Window Panels', scope: 'Thermal analysis, attachment design' },
  { component: 'Emergency Exit Signs', scope: 'Placement analysis, regulatory submission' },
