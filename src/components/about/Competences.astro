---
import { en } from '@/i18n/locales/en';

const teamItems = [
  { key: 'about.competences.team.item1', label: en.about.competences.team.item1 },
  { key: 'about.competences.team.item2', label: en.about.competences.team.item2 },
  { key: 'about.competences.team.item3', label: en.about.competences.team.item3 },
  { key: 'about.competences.team.item4', label: en.about.competences.team.item4 },
  { key: 'about.competences.team.item5', label: en.about.competences.team.item5 },
];

const certBadges = ['ISO 9001', 'TISAX', 'TUV NORD', 'DUNS'];
---

<section
  class="py-24 px-8 lg:px-16 bg-surface-container-low relative overflow-hidden"
  aria-label="Competences and commitment"
>
  <div class="absolute top-0 right-0 w-1/3 h-full blueprint-bg opacity-20 pointer-events-none"></div>

  <div class="container mx-auto relative z-10">
    <div class="flex flex-col lg:flex-row justify-between items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <span
          class="font-label text-secondary uppercase tracking-[0.2em] text-xs mb-4 block"
          data-i18n="about.competences.eyebrow"
        >{en.about.competences.eyebrow}</span>
        <h2
          class="font-headline text-5xl font-extrabold tracking-tighter text-on-surface"
          data-i18n="about.competences.heading"
        >{en.about.competences.heading}</h2>
      </div>
      <div class="hidden lg:block text-right"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">

      <!-- Technical Team -->
      <div class="space-y-6">
        <div class="h-px w-16 bg-primary"></div>
        <h4
          class="font-label text-sm uppercase tracking-widest font-bold text-primary"
          data-i18n="about.competences.team.title"
        >{en.about.competences.team.title}</h4>
        <p
          class="text-on-surface-variant leading-relaxed"
          data-i18n="about.competences.team.body"
        >{en.about.competences.team.body}</p>
        <ul class="space-y-3 font-label text-sm uppercase tracking-wider text-on-surface">
          {teamItems.map(({ key, label }) => (
            <li class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 bg-secondary rounded-full shrink-0"></span>
              <span data-i18n={key}>{label}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quality Assurance -->
      <div class="space-y-6">
        <div class="h-px w-16 bg-primary"></div>
        <h4
          class="font-label text-sm uppercase tracking-widest font-bold text-primary"
          data-i18n="about.competences.qa.title"
        >{en.about.competences.qa.title}</h4>
        <p
          class="text-on-surface-variant leading-relaxed"
          data-i18n="about.competences.qa.body"
        >{en.about.competences.qa.body}</p>
        <div class="flex flex-wrap gap-2">
          {certBadges.map((badge) => (
            <div class="bg-surface-container-high px-3 py-1 text-[10px] font-label font-bold tracking-widest uppercase">
              {badge}
            </div>
          ))}
        </div>
      </div>

      <!-- Global Reach -->
      <div class="space-y-6">
        <div class="h-px w-16 bg-primary"></div>
        <h4
          class="font-label text-sm uppercase tracking-widest font-bold text-primary"
          data-i18n="about.competences.global.title"
        >{en.about.competences.global.title}</h4>
        <p
          class="text-on-surface-variant leading-relaxed"
          data-i18n="about.competences.global.body"
        >{en.about.competences.global.body}</p>
      </div>

    </div>
  </div>
</section>
