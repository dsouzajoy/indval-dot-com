---
import { en } from '@/i18n/locales/en';

const { hero } = en.contact;
---

<section class="pt-24 pb-12 px-8 max-w-7xl mx-auto text-center" aria-label="Contact hero">
  <h1
    class="text-5xl md:text-6xl font-headline font-black text-primary tracking-tight max-w-3xl mx-auto leading-none"
    data-i18n="contact.hero.heading"
  >{hero.heading}</h1>
</section>
