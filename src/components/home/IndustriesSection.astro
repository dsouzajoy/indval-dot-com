---
import { Image } from 'astro:assets';
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';
import aerospaceImg from '@/assets/images/industries/aerospace.jpg';
import automotiveImg from '@/assets/images/industries/automotive.jpg';
import locomotiveImg from '@/assets/images/industries/locomotive.jpg';
import offHighwayImg from '@/assets/images/industries/off-highway.png';
import generalImg from '@/assets/images/industries/general.png';
---
<section id="services" class="py-20 md:py-24 px-4 sm:px-6 lg:px-8" aria-label="Services">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="mb-20 max-w-2xl">
      <h2
        class="font-sans font-black text-4xl text-primary mb-4 leading-tight"
        data-i18n="industries.heading"
      >
        {en.industries.heading}
      </h2>
      <p
        class="font-sans text-base text-on-surface-variant leading-relaxed"
        data-i18n="industries.description"
      >
        {en.industries.description}
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Aerospace — 8 cols -->
      <a href={withBase('/industries/aerospace')} class="md:col-span-8 group relative h-96 overflow-hidden rounded bg-surface-container-high btn-press-card block">
        <Image
          src={aerospaceImg}
          alt="Aerospace engine component"
          format="avif"
          quality={100}
          width={1200}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/95 via-primary/40 to-transparent p-12 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">flight</span>
          </div>
          <h3
            class="font-sans font-bold text-3xl text-white mb-2"
            data-i18n="industries.aerospace.title"
          >
            {en.industries.aerospace.title}
          </h3>
          <p
            class="font-sans text-white/80 text-sm leading-relaxed max-w-lg"
            data-i18n="industries.aerospace.description"
          >
            {en.industries.aerospace.description}
          </p>
        </div>
      </a>

      <!-- Automotive Systems — 4 cols -->
      <a href={withBase('/industries/automotive')} class="md:col-span-4 group relative h-96 overflow-hidden rounded bg-surface-container-high btn-press-card block">
        <Image
          src={automotiveImg}
          alt="Automotive engineering"
          format="avif"
          quality={100}
          width={800}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/60 to-transparent p-10 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">directions_car</span>
          </div>
          <h3
            class="font-sans font-bold text-2xl text-white mb-2"
            data-i18n="industries.automotive.title"
          >
            {en.industries.automotive.title}
          </h3>
          <p
            class="font-sans text-white/80 text-sm leading-relaxed"
            data-i18n="industries.automotive.description"
          >
            {en.industries.automotive.description}
          </p>
        </div>
      </a>

      <!-- Locomotive — 4 cols -->
      <a href={withBase('/industries/locomotive')} class="md:col-span-4 group relative h-96 overflow-hidden rounded bg-surface-container-lowest btn-press-card block">
        <Image
          src={locomotiveImg}
          alt="Locomotive engineering"
          format="avif"
          quality={100}
          width={800}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent p-10 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">train</span>
          </div>
          <h3
            class="font-sans font-bold text-2xl text-white mb-2"
            data-i18n="industries.locomotive.title"
          >
            {en.industries.locomotive.title}
          </h3>
          <p
            class="font-sans text-white/80 text-sm leading-relaxed"
            data-i18n="industries.locomotive.description"
          >
            {en.industries.locomotive.description}
          </p>
        </div>
      </a>

      <!-- Off Highway — 4 cols -->
      <a href={withBase('/industries/off-highway')} class="md:col-span-4 group relative h-96 overflow-hidden rounded bg-surface-container-high btn-press-card block">
        <Image
          src={offHighwayImg}
          alt="Off highway machinery"
          format="avif"
          quality={100}
          width={800}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary/90 to-transparent p-10 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">agriculture</span>
          </div>
          <h3
            class="font-sans font-bold text-2xl text-white mb-2"
            data-i18n="industries.offHighway.title"
          >
            {en.industries.offHighway.title}
          </h3>
          <p
            class="font-sans text-white/80 text-sm leading-relaxed"
            data-i18n="industries.offHighway.description"
          >
            {en.industries.offHighway.description}
          </p>
        </div>
      </a>

      <!-- General Engineering — 4 cols -->
      <a href={withBase('/industries/general')} class="md:col-span-4 group relative h-96 overflow-hidden rounded bg-primary-container btn-press-card block">
        <Image
          src={generalImg}
          alt="General engineering"
          format="avif"
          quality={100}
          width={800}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent p-10 flex flex-col justify-end">
          <div class="w-fit mb-4 p-2 bg-secondary/20 rounded">
            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">precision_manufacturing</span>
          </div>
          <h3
            class="font-sans font-bold text-2xl text-white mb-2"
            data-i18n="industries.general.title"
          >
            {en.industries.general.title}
          </h3>
          <p
            class="font-sans text-white/80 text-sm leading-relaxed"
            data-i18n="industries.general.description"
          >
            {en.industries.general.description}
          </p>
        </div>
      </a>

    </div>
  </div>
</section>
