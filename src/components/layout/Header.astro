---
import Navigation from './Navigation.astro';

const mobileNavLinks = [
  { label: 'Services',   href: '/404' },
  { label: 'Industries', href: '/404' },
  { label: 'Quality',    href: '/404' },
  { label: 'Company',    href: '/404' },
  { label: 'Careers',    href: '/404' },
];
---
<header
  id="site-header"
  role="banner"
  class="w-full fixed top-0 left-0 right-0 z-50 bg-surface/80 glass-nav transition-shadow duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" aria-label="Indvaltech home" class="flex items-center gap-2 shrink-0">
      <span class="material-symbols-outlined text-secondary text-2xl" style="font-variation-settings: 'FILL' 1;">architecture</span>
      <span class="font-sans font-bold text-xl tracking-tighter text-primary">INDVALTECH</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex flex-1 justify-center">
      <Navigation />
    </div>

    <!-- Desktop CTA -->
    <a
      href="/404"
      class="hidden md:inline-flex items-center px-6 py-2.5 rounded-xl font-label text-sm font-bold uppercase tracking-widest text-white
             bg-gradient-to-r from-primary to-primary-container shrink-0
             hover:shadow-ambient-lg active:scale-95 transition-all duration-200"
    >
      Consult Experts
    </a>

    <!-- Hamburger (mobile) -->
    <button
      id="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-primary"
    >
      <span id="hamburger-icon" class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-40 md:hidden pointer-events-none"
>
  <!-- Backdrop -->
  <div
    id="drawer-backdrop"
    class="absolute inset-0 bg-on-surface/40 opacity-0 transition-opacity duration-300"
  ></div>

  <!-- Panel -->
  <div
    id="drawer-panel"
    class="absolute top-0 right-0 h-full w-72 bg-surface-container-lowest shadow-ambient-lg
           translate-x-full transition-transform duration-300 ease-in-out flex flex-col pt-20 pb-8 px-6"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1 list-none m-0 p-0">
        {mobileNavLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="block px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <div class="mt-6">
      <a
        href="/404"
        class="block w-full text-center px-6 py-3 rounded-xl font-label text-sm font-bold uppercase tracking-widest text-white
               bg-gradient-to-r from-primary to-primary-container"
      >
        Consult Experts
      </a>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-16"></div>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('hamburger-btn')!;
  const icon = document.getElementById('hamburger-icon')!;
  const drawer = document.getElementById('mobile-drawer')!;
  const backdrop = document.getElementById('drawer-backdrop')!;
  const panel = document.getElementById('drawer-panel')!;

  // Deepen shadow on scroll — background stays glassy always
  window.addEventListener('scroll', () => {
    header.classList.toggle('shadow-ambient-lg', window.scrollY > 10);
  }, { passive: true });

  function openDrawer() {
    drawer.classList.remove('pointer-events-none');
    backdrop.classList.remove('opacity-0');
    panel.classList.remove('translate-x-full');
    btn.setAttribute('aria-expanded', 'true');
    icon.textContent = 'close';
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    backdrop.classList.add('opacity-0');
    panel.classList.add('translate-x-full');
    btn.setAttribute('aria-expanded', 'false');
    icon.textContent = 'menu';
    document.body.style.overflow = '';
    drawer.classList.add('pointer-events-none');
  }

  btn.addEventListener('click', () => {
    btn.getAttribute('aria-expanded') === 'true' ? closeDrawer() : openDrawer();
  });

  backdrop.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });

  drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));
</script>
