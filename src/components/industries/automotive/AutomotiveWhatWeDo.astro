---
import { withBase } from '@/lib/utils';
---

<section class="py-12 px-8">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-10">
      What We Do
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <!-- BIW Turnkey Solutions -->
      <a href={withBase('/capabilities/biw-turnkey-solutions')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Lower body -->
            <path d="M6 36 L6 46 Q6 48 8 48 L56 48 Q58 48 58 46 L58 36 L52 24 Q50 20 46 20 L18 20 Q14 20 12 24 Z" fill="#dce9ff"/>
            <path d="M6 36 L6 46 Q6 48 8 48 L56 48 Q58 48 58 46 L58 36 L52 24 Q50 20 46 20 L18 20 Q14 20 12 24 Z" stroke="#00316c" stroke-width="2" stroke-linejoin="round"/>
            <!-- Roof section -->
            <path d="M20 20 L24 10 Q26 8 32 8 Q38 8 40 10 L44 20 Z" fill="#dce9ff"/>
            <path d="M20 20 L24 10 Q26 8 32 8 Q38 8 40 10 L44 20 Z" stroke="#00316c" stroke-width="2" stroke-linejoin="round"/>
            <!-- Lower body depth tint -->
            <path d="M6 40 L6 46 Q6 48 8 48 L56 48 Q58 48 58 46 L58 40 Z" fill="#00316c" opacity="0.08"/>
            <!-- Structural lines -->
            <line x1="18" y1="20" x2="24" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="46" y1="20" x2="40" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="20" x2="32" y2="36" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="24" y1="10" x2="40" y2="10" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="8"  y1="36" x2="56" y2="36" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="8"  y1="36" x2="8"  y2="44" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="56" y1="36" x2="56" y2="44" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Wheel arches -->
            <path d="M8 48 A12 12 0 0 1 20 36" stroke="#00316c" stroke-width="1.5" fill="none"/>
            <path d="M44 36 A12 12 0 0 1 56 48" stroke="#00316c" stroke-width="1.5" fill="none"/>
            <!-- Wheels -->
            <circle cx="14" cy="48" r="7" fill="#00316c"/>
            <circle cx="14" cy="48" r="3.5" fill="#dce9ff"/>
            <circle cx="50" cy="48" r="7" fill="#00316c"/>
            <circle cx="50" cy="48" r="3.5" fill="#dce9ff"/>
            <!-- Orange structural joint nodes -->
            <circle cx="18" cy="20" r="3" fill="#ff671f"/>
            <circle cx="46" cy="20" r="3" fill="#ff671f"/>
            <circle cx="32" cy="20" r="3" fill="#ff671f"/>
            <circle cx="24" cy="10" r="2.5" fill="#ff671f"/>
            <circle cx="40" cy="10" r="2.5" fill="#ff671f"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">BIW Turnkey Solutions</span>
      </a>

      <!-- Die Design -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Shadow offsets behind dies -->
            <rect x="14" y="10" width="44" height="14" rx="2.5" fill="#00316c" opacity="0.15"/>
            <rect x="14" y="42" width="44" height="14" rx="2.5" fill="#00316c" opacity="0.15"/>
            <!-- Upper die body -->
            <rect x="10" y="6" width="44" height="14" rx="2.5" fill="#dce9ff"/>
            <rect x="10" y="6" width="44" height="14" rx="2.5" stroke="#00316c" stroke-width="2"/>
            <!-- Upper die inner bevel -->
            <line x1="12" y1="8" x2="52" y2="8" stroke="#00316c" stroke-width="1" opacity="0.40"/>
            <!-- Upper die form contour -->
            <path d="M14 20 L14 22 Q22 18 32 17 Q42 18 50 22 L50 20" stroke="#00316c" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <!-- Press arrow -->
            <line x1="32" y1="20" x2="32" y2="26" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <polyline points="28,24 32,28 36,24" stroke="#00316c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <!-- Orange sheet metal workpiece -->
            <rect x="10" y="28" width="44" height="6" rx="1.5" fill="#ff671f"/>
            <rect x="10" y="28" width="44" height="6" rx="1.5" stroke="#00316c" stroke-width="1.5"/>
            <!-- Lower die body -->
            <rect x="10" y="38" width="44" height="14" rx="2.5" fill="#dce9ff"/>
            <rect x="10" y="38" width="44" height="14" rx="2.5" stroke="#00316c" stroke-width="2"/>
            <!-- Lower die form cavity -->
            <path d="M14 38 L14 40 Q22 44 32 45 Q42 44 50 40 L50 38" stroke="#00316c" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M14 40 Q22 44 32 45 Q42 44 50 40 L50 38 Q42 42 32 43 Q22 42 14 38 Z" fill="#00316c" opacity="0.12"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Die Design</span>
      </div>

      <!-- Wire Harnessing -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Connector block (right side) -->
            <rect x="44" y="18" width="16" height="28" rx="3" fill="#dce9ff"/>
            <rect x="44" y="18" width="16" height="28" rx="3" stroke="#00316c" stroke-width="2"/>
            <!-- Pins -->
            <rect x="48" y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <rect x="53" y="12" width="3" height="8" rx="1" fill="#00316c"/>
            <!-- Socket holes -->
            <circle cx="49" cy="27" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="55" cy="27" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="49" cy="36" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <circle cx="55" cy="36" r="2.5" fill="white" stroke="#00316c" stroke-width="1"/>
            <!-- Orange wire bundle clip at center -->
            <rect x="28" y="26" width="6" height="12" rx="3" fill="#ff671f"/>
            <rect x="28" y="26" width="6" height="12" rx="3" stroke="#00316c" stroke-width="1.5"/>
            <!-- 5 fanning wires (left side, converging to clip) -->
            <path d="M6 10 C12 10 20 16 28 28" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M6 22 C12 22 20 24 28 28" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M6 32 L28 32"             stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M6 42 C12 42 20 40 28 36" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <path d="M6 52 C12 52 20 48 28 36" stroke="#00316c" stroke-width="2" stroke-linecap="round" fill="none"/>
            <!-- 3 wires clip to connector -->
            <path d="M34 28 L44 27" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M34 32 L44 32" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M34 36 L44 36" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Wire Harnessing</span>
      </div>

      <!-- Computational Fluid Dynamics -->
      <a href={withBase('/capabilities/cfd')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Airfoil body -->
            <path d="M18 32 C20 25 28 20 38 20 C46 20 52 24 56 32 C52 40 46 44 38 44 C28 44 20 39 18 32 Z" fill="#dce9ff"/>
            <path d="M18 32 C20 25 28 20 38 20 C46 20 52 24 56 32 C52 40 46 44 38 44 C28 44 20 39 18 32 Z" stroke="#00316c" stroke-width="2" stroke-linejoin="round"/>
            <!-- Depth tint on lower half -->
            <path d="M18 32 C20 39 28 44 38 44 C46 44 52 40 56 32 Z" fill="#00316c" opacity="0.10"/>
            <!-- Left streamlines -->
            <path d="M4 16 C8 16 12 18 16 24"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M4 22 C8 22 12 24 15 27"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M4 32 L16 32"             stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M4 42 C8 42 12 40 15 37"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M4 48 C8 48 12 46 16 40"  stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Left arrowheads -->
            <polygon points="14,22 16,24 18,23" fill="#00316c"/>
            <polygon points="13,25 15,27 17,26" fill="#00316c"/>
            <polygon points="14,30 16,32 14,34" fill="#00316c"/>
            <polygon points="13,38 15,37 17,38" fill="#00316c"/>
            <polygon points="14,39 16,40 18,41" fill="#00316c"/>
            <!-- Right streamlines -->
            <path d="M56 26 C58 25 60 22 60 18" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M56 29 C58 28 60 26 60 24" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M56 32 L60 32"             stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M56 35 C58 36 60 38 60 40" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <path d="M56 38 C58 40 60 42 60 46" stroke="#00316c" stroke-width="1.5" stroke-linecap="round" fill="none"/>
            <!-- Right arrowheads -->
            <polygon points="58,17 60,18 58,20" fill="#00316c"/>
            <polygon points="58,23 60,24 58,26" fill="#00316c"/>
            <polygon points="58,30 60,32 58,34" fill="#00316c"/>
            <polygon points="58,39 60,40 58,42" fill="#00316c"/>
            <polygon points="58,45 60,46 58,47" fill="#00316c"/>
            <!-- Orange stagnation dot on leading edge -->
            <circle cx="18" cy="32" r="2.5" fill="#ff671f"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Computational Fluid Dynamics</span>
      </a>

      <!-- Finite Element Analysis -->
      <a href={withBase('/capabilities/fea')} class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4 hover:border-secondary hover:shadow-ambient transition-all duration-300 cursor-pointer">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Curved plate base fill -->
            <path d="M6 14 Q20 10 38 8 Q54 10 58 18 Q56 36 50 52 Q36 58 18 56 Q8 46 6 30 Z" fill="#dce9ff"/>
            <path d="M6 14 Q20 10 38 8 Q54 10 58 18 Q56 36 50 52 Q36 58 18 56 Q8 46 6 30 Z" stroke="#00316c" stroke-width="2" stroke-linejoin="round"/>
            <!-- Triangle fills (upper) -->
            <polygon points="8,12 28,8 10,32"   fill="#dce9ff"/>
            <polygon points="28,8 48,12 30,30"  fill="#dce9ff"/>
            <polygon points="10,32 30,30 12,52" fill="#dce9ff"/>
            <polygon points="30,30 52,30 32,54" fill="#dce9ff"/>
            <!-- Triangle fills (lower-half depth tint) -->
            <polygon points="28,8 30,30 10,32"  fill="#00316c" opacity="0.08"/>
            <polygon points="48,12 52,30 30,30" fill="#00316c" opacity="0.08"/>
            <polygon points="30,30 32,54 12,52" fill="#00316c" opacity="0.08"/>
            <polygon points="52,30 54,50 32,54" fill="#00316c" opacity="0.08"/>
            <!-- Orange stress hot-spot -->
            <polygon points="30,30 52,30 32,54" fill="#ff671f" opacity="0.25"/>
            <polygon points="48,12 52,30 30,30" fill="#ff671f" opacity="0.18"/>
            <!-- Mesh edges -->
            <line x1="8"  y1="12" x2="28" y2="8"  stroke="#00316c" stroke-width="1.5"/>
            <line x1="28" y1="8"  x2="48" y2="12" stroke="#00316c" stroke-width="1.5"/>
            <line x1="10" y1="32" x2="30" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="30" y1="30" x2="52" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="12" y1="52" x2="32" y2="54" stroke="#00316c" stroke-width="1.5"/>
            <line x1="32" y1="54" x2="54" y2="50" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="12" x2="10" y2="32" stroke="#00316c" stroke-width="1.5"/>
            <line x1="10" y1="32" x2="12" y2="52" stroke="#00316c" stroke-width="1.5"/>
            <line x1="28" y1="8"  x2="30" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="30" y1="30" x2="32" y2="54" stroke="#00316c" stroke-width="1.5"/>
            <line x1="48" y1="12" x2="52" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="52" y1="30" x2="54" y2="50" stroke="#00316c" stroke-width="1.5"/>
            <line x1="8"  y1="12" x2="30" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="28" y1="8"  x2="52" y2="30" stroke="#00316c" stroke-width="1.5"/>
            <line x1="10" y1="32" x2="32" y2="54" stroke="#00316c" stroke-width="1.5"/>
            <line x1="30" y1="30" x2="54" y2="50" stroke="#00316c" stroke-width="1.5"/>
            <!-- Nodes -->
            <circle cx="8"  cy="12" r="2" fill="#00316c"/>
            <circle cx="28" cy="8"  r="2" fill="#00316c"/>
            <circle cx="48" cy="12" r="2" fill="#00316c"/>
            <circle cx="10" cy="32" r="2" fill="#00316c"/>
            <circle cx="30" cy="30" r="2" fill="#00316c"/>
            <circle cx="52" cy="30" r="2" fill="#00316c"/>
            <circle cx="12" cy="52" r="2" fill="#00316c"/>
            <circle cx="32" cy="54" r="2" fill="#00316c"/>
            <circle cx="54" cy="50" r="2" fill="#00316c"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Finite Element Analysis</span>
      </a>

      <!-- Jigs & Fixtures -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- C-frame body fill -->
            <path d="M12 8 L50 8 L50 20 L22 20 L22 44 L50 44 L50 56 L12 56 Q8 56 8 52 L8 12 Q8 8 12 8 Z" fill="#dce9ff"/>
            <!-- C-frame outline: top arm -->
            <line x1="10" y1="8"  x2="50" y2="8"  stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="10" y1="20" x2="50" y2="20" stroke="#00316c" stroke-width="2"   stroke-linecap="round"/>
            <!-- Right caps (rounded corners) -->
            <path d="M50 8 Q56 8 56 14"   stroke="#00316c" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <path d="M50 20 Q56 20 56 14" stroke="#00316c" stroke-width="2"   stroke-linecap="round" fill="none"/>
            <!-- Left spine -->
            <line x1="8"  y1="8"  x2="8"  y2="56" stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="20" y1="20" x2="20" y2="44" stroke="#00316c" stroke-width="2"   stroke-linecap="round"/>
            <!-- C-frame: bottom arm -->
            <line x1="10" y1="56" x2="50" y2="56" stroke="#00316c" stroke-width="2.5" stroke-linecap="round"/>
            <line x1="10" y1="44" x2="50" y2="44" stroke="#00316c" stroke-width="2"   stroke-linecap="round"/>
            <!-- Right caps bottom -->
            <path d="M50 56 Q56 56 56 50" stroke="#00316c" stroke-width="2.5" stroke-linecap="round" fill="none"/>
            <path d="M50 44 Q56 44 56 50" stroke="#00316c" stroke-width="2"   stroke-linecap="round" fill="none"/>
            <!-- T-bar handle -->
            <line x1="34" y1="4" x2="46" y2="4" stroke="#00316c" stroke-width="3" stroke-linecap="round"/>
            <!-- Screw shaft (through upper arm, down into jaw) -->
            <line x1="40" y1="4" x2="40" y2="32" stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Thread marks -->
            <line x1="38" y1="10" x2="42" y2="10" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="38" y1="14" x2="42" y2="14" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="38" y1="18" x2="42" y2="18" stroke="#00316c" stroke-width="1.5" stroke-linecap="round"/>
            <!-- Orange pressure pad -->
            <rect x="32" y="32" width="16" height="5" rx="2" fill="#ff671f"/>
            <rect x="32" y="32" width="16" height="5" rx="2" stroke="#00316c" stroke-width="1.5"/>
            <!-- Workpiece in jaw (sits below pressure pad) -->
            <rect x="22" y="38" width="20" height="8" rx="2" fill="#dce9ff"/>
            <rect x="22" y="38" width="20" height="8" rx="2" stroke="#00316c" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="font-label text-base font-semibold text-on-surface leading-snug">Jigs & Fixtures</span>
      </div>

      <!-- Cubing & Control Gauges -->
      <div class="bg-white border border-outline-variant rounded-lg p-8 flex flex-col items-start gap-4">
        <div class="w-16 h-16">
          <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Outer gauge body -->
            <circle cx="32" cy="32" r="28" fill="#dce9ff"/>
            <circle cx="32" cy="32" r="28" stroke="#00316c" stroke-width="2"/>
            <!-- Lower half depth tint -->
            <path d="M4 32 A28 28 0 0 0 60 32 Z" fill="#00316c" opacity="0.08"/>
            <!-- Inner reference ring -->
            <circle cx="32" cy="32" r="22" stroke="#00316c" stroke-width="1" opacity="0.30"/>
            <!-- Major tick marks (every 30°, 12 ticks) -->
            <line x1="32" y1="4"    x2="32" y2="10"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="46" y1="7.6"  x2="43" y2="13"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="56" y1="18"   x2="51" y2="21"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="60" y1="32"   x2="54" y2="32"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="56" y1="46"   x2="51" y2="43"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="46" y1="56.4" x2="43" y2="51"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="32" y1="60"   x2="32" y2="54"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="18" y1="56.4" x2="21" y2="51"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="8"  y1="46"   x2="13" y2="43"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="4"  y1="32"   x2="10" y2="32"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="8"  y1="18"   x2="13" y2="21"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <line x1="18" y1="7.6"  x2="21" y2="13"   stroke="#00316c" stroke-width="2" stroke-linecap="round"/>
            <!-- Minor tick marks (every 15°, between majors) -->
            <line x1="39" y1="5"  x2="38" y2="8"  stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="52" y1="12" x2="49" y2="15" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="59" y1="25" x2="56" y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="59" y1="39" x2="56" y2="38" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="52" y1="52" x2="49" y2="49" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="39" y1="59" x2="38" y2="56" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="25" y1="59" x2="26" y2="56" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="12" y1="52" x2="15" y2="49" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="5"  y1="39" x2="8"  y2="38" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="5"  y1="25" x2="8"  y2="26" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="12" y1="12" x2="15" y2="15" stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <line x1="25" y1="5"  x2="26" y2="8"  stroke="#00316c" stroke-width="1" stroke-linecap="round"/>
            <!-- Orange red-zone arc at bottom -->
            <path d="M46 56 A28 28 0 0 1 18 56" stroke="#ff671f" stroke-width="3.5" stroke-linecap="round" fill="none" opacity="0.50"/>
            <!-- Orange needle (~10 o'clock) -->
            <line x1="32" y1="32" x2="19" y2="17" stroke="#ff671f" stroke-width="2.5" stroke-linecap="round"/>
            <!-- Counter-weight nub -->
            <line x1="32" y1="32" x2="37" y2="38" stroke="#ff671f" stroke-width="2" stroke-linecap="round"/>
            <!-- Center cap -->
            <circle cx="32" cy="32" r="5" fill="#00316c"/>
            <circle cx="32" cy="32" r="2" fill="white"/>
          </svg>
        </div>
