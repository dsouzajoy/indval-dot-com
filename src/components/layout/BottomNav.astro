---
const items = [
  { label: 'Home',     icon: 'home',    href: '/',    active: true  },
  { label: 'Explore',  icon: 'explore', href: '/404', active: false },
  { label: 'Services', icon: 'settings', href: '/404', active: false },
  { label: 'Contact',  icon: 'person',  href: '/404', active: false },
];
---
<nav
  class="fixed bottom-0 left-0 right-0 md:hidden bg-surface/95 backdrop-blur-md border-t border-outline-variant/10 z-50 px-4 py-2"
  aria-label="Mobile bottom navigation"
>
  <div class="flex justify-between items-center max-w-lg mx-auto">
    {items.map(({ label, icon, href, active }) => (
      <a
        href={href}
        class:list={[
          'flex flex-col items-center gap-0.5 px-3 py-1 transition-colors duration-200',
          active ? 'text-primary' : 'text-on-surface-variant opacity-60',
        ]}
        aria-current={active ? 'page' : undefined}
      >
        <span
          class="material-symbols-outlined text-2xl"
          style={active ? "font-variation-settings: 'FILL' 1;" : ''}
        >
          {icon}
        </span>
        <span class="font-label text-[10px] font-bold uppercase">{label}</span>
      </a>
    ))}
  </div>
</nav>
