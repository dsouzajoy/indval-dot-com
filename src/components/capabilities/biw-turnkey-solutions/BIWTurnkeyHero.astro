---
import { en } from '@/i18n/locales/en';
import HeroVideo from '@/components/ui/HeroVideo.astro';
import heroVideo from '@/assets/videos/biw-hero-video.mp4';
import heroPoster from '@/assets/images/biw/biw-hero-poster.jpg';
---

<section
  class="relative min-h-screen flex items-center overflow-hidden"
  aria-label="BIW Turnkey Solutions"
>
  <HeroVideo videoSrc={heroVideo} poster={heroPoster} />
  <!-- Dark gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-on-surface/85 via-on-surface/65 to-on-surface/20 z-10"></div>

  <div class="container mx-auto px-8 lg:px-16 relative z-20 py-24">
    <div class="max-w-2xl space-y-8">

      <!-- Eyebrow -->
      <p class="font-label text-sm uppercase tracking-widest text-secondary" data-i18n="biwTurnkey.hero.eyebrow">
        {en.biwTurnkey.hero.eyebrow}
      </p>

      <!-- Heading -->
      <h1
        class="font-headline text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tighter text-white leading-tight"
        data-i18n="biwTurnkey.hero.heading"
      >{en.biwTurnkey.hero.heading}</h1>

      <!-- Description with left-border accent -->
      <p
        class="text-xl text-white/90 font-light leading-relaxed border-l-4 border-secondary pl-8 max-w-xl"
        data-i18n="biwTurnkey.hero.description"
      >{en.biwTurnkey.hero.description}</p>

      <!-- CTA -->
      <div class="pt-2">
        <a
          href="#capabilities"
          id="biw-hero-cta"
          class="inline-block bg-gradient-to-r from-secondary to-secondary/80 text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-widest btn-press"
          data-i18n="biwTurnkey.hero.cta"
        >
          {en.biwTurnkey.hero.cta}
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  document.getElementById('biw-hero-cta')?.addEventListener('click', (e) => {
    e.preventDefault();
    document.getElementById('capabilities')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
