---
import Navigation from './Navigation.astro';
import { LanguageSwitcher } from '../i18n/LanguageSwitcher';
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';

const mobileNavLinks = [
  { label: en.nav.home,     href: '/',    i18nKey: 'nav.home'     },
  { label: en.nav.services, href: '/404', i18nKey: 'nav.services' },
  { label: en.nav.career,   href: '/careers', i18nKey: 'nav.career'   },
];

const mobileIndustriesItems = [
  { label: en.industries.aerospace.title,  href: '/industries/aerospace',   i18nKey: 'industries.aerospace.title',  icon: 'flight'         },
  { label: en.industries.automotive.title, href: '/industries/automotive',  i18nKey: 'industries.automotive.title', icon: 'directions_car' },
  { label: en.industries.locomotive.title, href: '/industries/locomotive',  i18nKey: 'industries.locomotive.title', icon: 'train'          },
  { label: en.industries.offHighway.title, href: '/industries/off-highway', i18nKey: 'industries.offHighway.title', icon: 'agriculture'    },
  { label: en.industries.general.title,    href: '/industries/general',     i18nKey: 'industries.general.title',    icon: 'precision_manufacturing'          },
];
---
<header
  id="site-header"
  role="banner"
  class="w-full fixed top-0 left-0 right-0 z-50 bg-surface/80 glass-nav transition-shadow duration-300"
>
  <div id="header-bar" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-8" style="transition: height 300ms ease;">

    <!-- Logo + Wordmark -->
    <a href={withBase('/')} aria-label="Indvaltech home" class="flex items-center gap-3 shrink-0">
      <img id="header-logo" src={withBase('/images/logo.png')} alt="Indvaltech" class="h-9 w-auto" style="transition: height 300ms ease;" />
      <span id="header-divider" class="w-px bg-slate-300/60 shrink-0" style="height: 2rem; transition: height 300ms ease;"></span>
      <span id="header-wordmark" class="font-label tracking-tight leading-none flex flex-col">
        <span id="header-wordmark-title" class="font-bold" style="transition: font-size 300ms ease, letter-spacing 300ms ease;"><span class="text-secondary">INDVAL</span><span class="text-primary">TECH</span></span>
        <span id="header-wordmark-sub" class="font-medium text-slate-500 uppercase mt-0.5" style="transition: font-size 300ms ease, letter-spacing 300ms ease;">Engineering Excellence</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex flex-1 justify-center">
      <Navigation />
    </div>

    <!-- Desktop: Language Switcher + CTA -->
    <div class="hidden md:flex items-center gap-3 shrink-0">
      <LanguageSwitcher client:load />
      <a
        href={withBase('/404')}
        class="inline-flex items-center px-6 py-2.5 rounded-xl font-label text-sm font-bold uppercase tracking-widest text-white
               bg-gradient-to-r from-primary to-primary-container
               hover:shadow-ambient-lg active:scale-95 transition-all duration-200"
        data-i18n="nav.cta"
      >
        {en.nav.cta}
      </a>
    </div>

    <!-- Hamburger (mobile) -->
    <button
      id="hamburger-btn"
      aria-label={en.nav.hamburgerOpen}
      data-i18n-attr="aria-label:nav.hamburgerOpen"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-primary"
    >
      <span id="hamburger-icon" class="material-symbols-outlined text-2xl">menu</span>
    </button>
  </div>
</header>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  class="fixed inset-0 z-40 md:hidden pointer-events-none"
>
  <!-- Backdrop -->
  <div
    id="drawer-backdrop"
    class="absolute inset-0 bg-on-surface/40 opacity-0 transition-opacity duration-300"
  ></div>

  <!-- Panel -->
  <div
    id="drawer-panel"
    class="absolute top-0 right-0 h-full w-72 bg-surface-container-lowest shadow-ambient-lg
           translate-x-full transition-transform duration-300 ease-in-out flex flex-col pt-20 pb-8 px-6"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1 list-none m-0 p-0">

        <!-- Home -->
        <li>
          <a
            href={withBase('/')}
            data-i18n="nav.home"
            class="block px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
          >
            {en.nav.home}
          </a>
        </li>

        <!-- Company accordion -->
        <li>
          <button
            id="mobile-company-trigger"
            aria-expanded="false"
            class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
          >
            <span data-i18n="nav.company">{en.nav.company}</span>
            <span
              id="mobile-company-chevron"
              class="material-symbols-outlined text-base leading-none transition-transform duration-200"
              aria-hidden="true"
            >expand_more</span>
          </button>
          <div
            id="mobile-company-submenu"
            class="overflow-hidden transition-all duration-300 ease-in-out"
            style="max-height: 0;"
          >
            <ul class="flex flex-col gap-0.5 mt-1 ml-3 pl-3 border-l-2 border-outline-variant/30 list-none m-0 p-0">
              <li>
                <a
                  href={withBase('/about')}
                  class="flex items-center gap-2.5 px-3 py-2 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
                >
                  <span class="material-symbols-outlined text-base leading-none shrink-0 text-secondary" aria-hidden="true">corporate_fare</span>
                  <span data-i18n="nav.aboutUs">{en.nav.aboutUs}</span>
                </a>
              </li>
              <li>
                <a
                  href={withBase('/life')}
                  class="flex items-center gap-2.5 px-3 py-2 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
                >
                  <span class="material-symbols-outlined text-base leading-none shrink-0 text-secondary" aria-hidden="true">people</span>
                  <span data-i18n="nav.lifeAtIndvaltech">{en.nav.lifeAtIndvaltech}</span>
                </a>
              </li>
            </ul>
          </div>
        </li>

        <!-- Industries accordion -->
        <li>
          <button
            id="mobile-industries-trigger"
            aria-expanded="false"
            class="w-full flex items-center justify-between px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
          >
            <span data-i18n="nav.industries">{en.nav.industries}</span>
            <span
              id="mobile-industries-chevron"
              class="material-symbols-outlined text-base leading-none transition-transform duration-200"
              aria-hidden="true"
            >expand_more</span>
          </button>
          <div
            id="mobile-industries-submenu"
            class="overflow-hidden transition-all duration-300 ease-in-out"
            style="max-height: 0;"
          >
            <ul class="flex flex-col gap-0.5 mt-1 ml-3 pl-3 border-l-2 border-outline-variant/30 list-none m-0 p-0">
              {mobileIndustriesItems.map(({ label, href, i18nKey, icon }) => (
                <li>
                  <a
                    href={withBase(href)}
                    class="flex items-center gap-2.5 px-3 py-2 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
                  >
                    <span class="material-symbols-outlined text-base leading-none shrink-0 text-secondary" style="font-variation-settings: 'FILL' 1" aria-hidden="true">{icon}</span>
                    <span data-i18n={i18nKey}>{label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <!-- Remaining links -->
        {mobileNavLinks.slice(1).map(({ label, href, i18nKey }) => (
          <li>
            <a
              href={withBase(href)}
              data-i18n={i18nKey}
              class="block px-3 py-2.5 rounded-lg font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary hover:bg-surface-container-low transition-colors duration-200"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Language Switcher in drawer -->
    <div class="mt-6">
      <LanguageSwitcher client:load />
    </div>

    <div class="mt-4">
      <a
        href={withBase('/404')}
        data-i18n="nav.cta"
        class="block w-full text-center px-6 py-3 rounded-xl font-label text-sm font-bold uppercase tracking-widest text-white
               bg-gradient-to-r from-primary to-primary-container"
      >
        {en.nav.cta}
      </a>
    </div>
  </div>
</div>

<!-- Spacer -->
<div class="h-16"></div>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('hamburger-btn')!;
  const icon = document.getElementById('hamburger-icon')!;
  const drawer = document.getElementById('mobile-drawer')!;
  const backdrop = document.getElementById('drawer-backdrop')!;
  const panel = document.getElementById('drawer-panel')!;
  const barEl = document.getElementById('header-bar')!;
  const logoEl = document.getElementById('header-logo')!;
  const dividerEl = document.getElementById('header-divider')!;
  const titleEl = document.getElementById('header-wordmark-title')!;
  const subEl = document.getElementById('header-wordmark-sub')!;

  const DESKTOP_BP = 768;

  function applyScrollState(scrolled: boolean) {
    header.classList.toggle('shadow-ambient-lg', scrolled);
    if (window.innerWidth >= DESKTOP_BP) {
      barEl.style.height = scrolled ? '4rem' : '6rem';
      logoEl.style.height = scrolled ? '2.25rem' : '4rem';
      dividerEl.style.height = scrolled ? '2rem' : '3.25rem';
      titleEl.style.fontSize = scrolled ? '1.2rem' : '1.85rem';
      titleEl.style.letterSpacing = scrolled ? '0.04em' : 'normal';
      subEl.style.fontSize = scrolled ? '0.52rem' : '0.65rem';
      subEl.style.letterSpacing = scrolled ? '0.08em' : '0.18em';
    }
  }

  applyScrollState(window.scrollY > 10);

  window.addEventListener('scroll', () => applyScrollState(window.scrollY > 10), { passive: true });
  window.addEventListener('resize', () => applyScrollState(window.scrollY > 10), { passive: true });

  function openDrawer() {
    drawer.classList.remove('pointer-events-none');
    backdrop.classList.remove('opacity-0');
    panel.classList.remove('translate-x-full');
    btn.setAttribute('aria-expanded', 'true');
    icon.textContent = 'close';
    document.body.style.overflow = 'hidden';
  }

  const mobileCompanyTrigger = document.getElementById('mobile-company-trigger')!;
  const mobileCompanySubmenu = document.getElementById('mobile-company-submenu')!;
  const mobileCompanyChevron = document.getElementById('mobile-company-chevron')!;

  mobileCompanyTrigger.addEventListener('click', () => {
    const isOpen = mobileCompanyTrigger.getAttribute('aria-expanded') === 'true';
    mobileCompanySubmenu.style.maxHeight = isOpen ? '0' : mobileCompanySubmenu.scrollHeight + 'px';
    mobileCompanyTrigger.setAttribute('aria-expanded', String(!isOpen));
    mobileCompanyChevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });

  const mobileIndustriesTrigger = document.getElementById('mobile-industries-trigger')!;
  const mobileIndustriesSubmenu = document.getElementById('mobile-industries-submenu')!;
  const mobileIndustriesChevron = document.getElementById('mobile-industries-chevron')!;

  mobileIndustriesTrigger.addEventListener('click', () => {
    const isOpen = mobileIndustriesTrigger.getAttribute('aria-expanded') === 'true';
    mobileIndustriesSubmenu.style.maxHeight = isOpen ? '0' : mobileIndustriesSubmenu.scrollHeight + 'px';
    mobileIndustriesTrigger.setAttribute('aria-expanded', String(!isOpen));
    mobileIndustriesChevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });

  function closeDrawer() {
    backdrop.classList.add('opacity-0');
    panel.classList.add('translate-x-full');
    btn.setAttribute('aria-expanded', 'false');
    icon.textContent = 'menu';
    document.body.style.overflow = '';
    drawer.classList.add('pointer-events-none');
    // Reset Company accordion
    mobileCompanySubmenu.style.maxHeight = '0';
    mobileCompanyTrigger.setAttribute('aria-expanded', 'false');
    mobileCompanyChevron.style.transform = '';
    // Reset Industries accordion
    mobileIndustriesSubmenu.style.maxHeight = '0';
    mobileIndustriesTrigger.setAttribute('aria-expanded', 'false');
    mobileIndustriesChevron.style.transform = '';
  }

  btn.addEventListener('click', () => {
    btn.getAttribute('aria-expanded') === 'true' ? closeDrawer() : openDrawer();
  });

  backdrop.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDrawer();
  });

  drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));
</script>
