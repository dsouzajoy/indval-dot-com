---
const solutions = [
  { label: 'Aerospace & Defense',   href: '/404' },
  { label: 'Automotive Systems',    href: '/404' },
  { label: 'Industrial Automation', href: '/404' },
  { label: 'Quality Assurance',     href: '/404' },
];

const company = [
  { label: 'Our Pedigree',    href: '/404' },
  { label: 'Technical Papers', href: '/404' },
  { label: 'Privacy Policy',  href: '/404' },
  { label: 'Terms of Service', href: '/404' },
];

const year = new Date().getFullYear();
---
<footer role="contentinfo" class="bg-primary text-white">

  <!-- Main grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="text-2xl font-black text-white mb-4">INDVALTECH</div>
        <p class="text-slate-400 text-sm leading-relaxed max-w-xs">
          Specialized engineering partners providing precision technical solutions for the world's most demanding industries.
        </p>
      </div>

      <!-- Solutions -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5">Solutions</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {solutions.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5">Company</h3>
        <ul class="flex flex-col gap-3 list-none m-0 p-0">
          {company.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-slate-300 hover:text-white hover:translate-x-1 transition-all duration-200 block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-label text-xs font-bold uppercase tracking-widest text-secondary mb-5">Newsletter</h3>
        <p class="text-sm text-slate-400 mb-4 leading-relaxed">Technical insights delivered quarterly.</p>
        <form onsubmit="return false;">
          <!-- TODO: wire to email service (Formspree / ConvertKit / etc.) -->
          <div class="flex">
            <input
              type="email"
              placeholder="Work email"
              autocomplete="email"
              class="flex-1 min-w-0 px-4 py-3 text-sm bg-white/10 text-white placeholder-white/40
                     border-0 rounded-l-xl focus:outline-none focus:ring-1 focus:ring-secondary/60
                     transition-colors duration-200"
            />
            <button
              type="submit"
              class="px-4 py-3 bg-secondary rounded-r-xl hover:bg-secondary/90 active:scale-95 transition-all duration-200"
              aria-label="Subscribe"
            >
              <span class="material-symbols-outlined text-white text-xl">send</span>
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-label text-[10px] uppercase tracking-widest text-slate-400">
        © {year} Indvaltech Engineering. Precision Guaranteed.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" aria-label="Share" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">share</span>
        </a>
        <a href="#" aria-label="LinkedIn" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">hub</span>
        </a>
        <a href="#" aria-label="Website" class="text-slate-400 hover:text-white transition-colors duration-200">
          <span class="material-symbols-outlined text-lg">public</span>
        </a>
      </div>
    </div>
  </div>

</footer>
