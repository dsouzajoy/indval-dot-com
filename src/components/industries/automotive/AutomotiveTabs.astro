---
import { withBase } from '@/lib/utils';

const tabs = [
  {
    label: 'Cockpit',
    heading: 'Cockpit',
    bullets: [
      'Instrument panel assembly',
      'Cross car beam',
      'Floor console',
      'Glove box assembly',
    ],
  },
  {
    label: 'HVAC System',
    heading: 'HVAC System',
    bullets: [
      'Condenser module',
      'Control panel',
      'Compressor',
      'AC piping',
      'Duct design',
      'Air vent',
    ],
  },
  {
    label: 'Seating System',
    heading: 'Seating System',
    bullets: [
      'Front & rear seats with headrest',
      'Seat belts',
      'Seating structure',
      'Seating trims',
    ],
  },
  {
    label: 'Soft Trims',
    heading: 'Soft Trims',
    bullets: [
      'Headliners',
      'Carpet & insulation',
    ],
  },
  {
    label: 'Door Trim / Pillar Trim',
    heading: 'Door Trim / Pillar Trim',
    bullets: [
      'Front & rear door trims',
      'All pillar trims',
      'Sunroof trims',
      'Scuff plate',
    ],
  },
  {
    label: 'Exterior',
    heading: 'Exterior',
    bullets: [
      'Front & rear bumper systems',
      'Wheel arm',
      'Fenders LH/RH',
      'Rocker panels',
      'ORVM',
      'Tailgate',
      'Rear quarter trims',
      'Wiper systems',
      'Windshield & glasses with sealing',
    ],
  },
];
---

<section id="auto-capabilities" class="py-12 px-8">
  <div class="max-w-7xl mx-auto">

    <h2 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-10">
      Our Services
    </h2>

    <div class="bg-white rounded-lg overflow-hidden">

    <!-- Desktop: vertical tabs left + panel right -->
    <div class="hidden lg:flex gap-0 items-start">

      <!-- Left: vertical tab list -->
      <div class="shrink-0 w-56 flex flex-col border-r border-outline-variant py-4">
        {tabs.map((tab, i) => (
          <button
            data-auto-tab={i}
            class={`auto-tab-btn text-left font-label text-sm uppercase tracking-wider py-4 px-6 border-l-2 transition-colors duration-200 cursor-pointer ${
              i === 0
                ? 'border-secondary text-primary font-bold'
                : 'border-transparent text-on-surface-variant hover:text-primary'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Right: tab panels -->
      <div class="relative flex-1 min-h-[320px] p-10">
        {tabs.map((tab, i) => (
          <div
            data-auto-panel={i}
            class={`auto-tab-panel ${
              i === 0 ? 'relative pointer-events-auto' : 'absolute top-0 left-0 right-0 opacity-0 pointer-events-none'
            }`}
          >
            <h2 class="font-headline font-bold text-3xl text-on-surface mb-8">{tab.heading}</h2>
            <ul class={tab.label === 'Exterior' || tab.label === 'HVAC System' ? 'grid grid-cols-2 gap-x-8 gap-y-4' : 'space-y-4'}>
              {tab.bullets.map((bullet) => (
                <li class="flex gap-3 items-start">
                  <span
                    class="material-symbols-outlined text-secondary shrink-0 text-xl leading-relaxed"
                    style="font-variation-settings: 'FILL' 1"
                    aria-hidden="true"
                  >check_circle</span>
                  <span class="text-on-surface-variant leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>

    <!-- Mobile: horizontal scrolling tabs + panel below -->
    <div class="lg:hidden p-6">

      <!-- Tab bar -->
      <div class="relative">
        <div class="absolute right-0 top-0 h-full w-16 bg-gradient-to-l from-white to-transparent pointer-events-none z-10"></div>
        <div id="auto-tab-scroll-container" class="flex border-b border-outline-variant overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
          {tabs.map((tab, i) => (
            <button
              data-auto-tab-mobile={i}
              class={`auto-tab-btn-mobile font-label text-sm uppercase tracking-wider py-3 px-5 border-b-2 whitespace-nowrap transition-colors duration-200 shrink-0 cursor-pointer ${
                i === 0
                  ? 'border-secondary text-primary font-bold'
                  : 'border-transparent text-on-surface-variant hover:text-primary'
              }`}
            >
              {tab.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Mobile panels -->
      <div class="relative mt-10 min-h-[280px]">
        {tabs.map((tab, i) => (
          <div
            data-auto-panel-mobile={i}
            class={`auto-tab-panel-mobile ${
              i === 0 ? 'relative pointer-events-auto' : 'absolute top-0 left-0 right-0 opacity-0 pointer-events-none'
            }`}
          >
            <h2 class="font-headline font-bold text-2xl text-on-surface mb-6">{tab.heading}</h2>
            <ul class="space-y-4">
              {tab.bullets.map((bullet) => (
                <li class="flex gap-3 items-start">
                  <span
                    class="material-symbols-outlined text-secondary shrink-0 text-xl leading-relaxed"
                    style="font-variation-settings: 'FILL' 1"
                    aria-hidden="true"
                  >check_circle</span>
                  <span class="text-on-surface-variant leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

    </div>

    </div> <!-- end white container -->

  </div>
</section>

<script>
  // Desktop vertical tabs
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.auto-tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.auto-tab-panel');

  function activateTab(index: number) {
    tabBtns.forEach((btn) => {
      const isActive = Number(btn.dataset.autoTab) === index;
      btn.classList.toggle('border-secondary', isActive);
      btn.classList.toggle('text-primary', isActive);
      btn.classList.toggle('font-bold', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-on-surface-variant', !isActive);
    });

    tabPanels.forEach((panel, i) => {
      const isActive = i === index;
      panel.classList.toggle('relative', isActive);
      panel.classList.toggle('opacity-100', isActive);
      panel.classList.toggle('pointer-events-auto', isActive);
      panel.classList.toggle('absolute', !isActive);
      panel.classList.toggle('top-0', !isActive);
      panel.classList.toggle('left-0', !isActive);
      panel.classList.toggle('right-0', !isActive);
      panel.classList.toggle('opacity-0', !isActive);
      panel.classList.toggle('pointer-events-none', !isActive);
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => activateTab(Number(btn.dataset.autoTab)));
  });

  // Mobile horizontal tabs
  const mobileTabBtns = document.querySelectorAll<HTMLButtonElement>('.auto-tab-btn-mobile');
  const mobilePanels = document.querySelectorAll<HTMLElement>('.auto-tab-panel-mobile');

  function activateMobileTab(index: number) {
    mobileTabBtns.forEach((btn) => {
      const isActive = Number(btn.dataset.autoTabMobile) === index;
      btn.classList.toggle('border-secondary', isActive);
      btn.classList.toggle('text-primary', isActive);
      btn.classList.toggle('font-bold', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-on-surface-variant', !isActive);
    });

    mobilePanels.forEach((panel, i) => {
      const isActive = i === index;
      panel.classList.toggle('relative', isActive);
      panel.classList.toggle('opacity-100', isActive);
      panel.classList.toggle('pointer-events-auto', isActive);
      panel.classList.toggle('absolute', !isActive);
      panel.classList.toggle('top-0', !isActive);
      panel.classList.toggle('left-0', !isActive);
      panel.classList.toggle('right-0', !isActive);
      panel.classList.toggle('opacity-0', !isActive);
      panel.classList.toggle('pointer-events-none', !isActive);
    });
  }

  mobileTabBtns.forEach((btn) => {
    btn.addEventListener('click', () => activateMobileTab(Number(btn.dataset.autoTabMobile)));
  });

  // Scroll hint on first intersection (mobile)
  const tabScrollContainer = document.getElementById('auto-tab-scroll-container');
  if (tabScrollContainer) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          observer.disconnect();
          setTimeout(() => {
            tabScrollContainer.scrollTo({ left: tabScrollContainer.scrollWidth, behavior: 'smooth' });
            setTimeout(() => {
              tabScrollContainer.scrollTo({ left: 0, behavior: 'smooth' });
            }, 900);
          }, 400);
        }
      });
    }, { threshold: 0.3 });

    const section = document.getElementById('auto-capabilities');
    if (section) observer.observe(section);
  }
</script>

<!-- CTA Banner -->
<section class="bg-on-surface py-20">
  <div class="max-w-7xl mx-auto px-8 lg:px-16 text-center">
    <h2 class="font-headline text-3xl lg:text-4xl font-bold text-white mb-4">
      Drive Your Automotive Program Forward
    </h2>
    <p class="text-white/80 text-base mb-10 max-w-xl mx-auto leading-relaxed">
      Talk to our automotive engineering specialists about BIW, chassis, powertrain, or manufacturing support for your next vehicle program.
    </p>
    <a
      href={withBase('/contact#contact-form')}
      class="inline-flex items-center justify-center gap-2 bg-secondary text-white px-8 py-4 rounded font-label text-sm font-bold uppercase tracking-wider cursor-pointer hover:bg-secondary/90 btn-press"
    >
      Get In Touch
    </a>
  </div>
</section>
