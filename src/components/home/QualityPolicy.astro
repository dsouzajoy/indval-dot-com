---
import { Image } from 'astro:assets';
import { en } from '@/i18n/locales/en';
import manufacturingHeroImg from '@/assets/images/manufacturing-hero.jpg';
---
<section class="relative bg-primary blueprint-bg overflow-hidden py-20 md:py-24 xl:py-32 px-4 sm:px-6 lg:px-8" aria-label="Quality policy">
  <div class="absolute inset-0 opacity-[0.15] pointer-events-none">
    <Image
      src={manufacturingHeroImg}
      alt=""
      aria-hidden="true"
      format="avif"
      quality={60}
      width={1920}
      loading="lazy"
      class="w-full h-full object-cover grayscale mix-blend-overlay"
    />
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">

      <!-- Left: label + heading -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-4 mb-6">
          <div class="h-px w-12 bg-secondary shrink-0"></div>
          <span
            class="font-label text-sm uppercase tracking-[0.4em] text-secondary font-bold"
            data-i18n="qualityPolicy.eyebrow"
          >
            {en.qualityPolicy.eyebrow}
          </span>
        </div>
        <h2
          class="font-sans font-black text-5xl lg:text-6xl text-white leading-[1.1]"
          data-i18n="qualityPolicy.heading"
        >
          {en.qualityPolicy.heading}
        </h2>
      </div>

      <!-- Right: glassmorphism quote card -->
      <div class="lg:col-span-7 bg-white/5 backdrop-blur-md border border-white/10 p-10 lg:p-16 rounded-[4px] shadow-2xl">
        <div class="relative pt-4 pl-4">
          <span
            class="material-symbols-outlined text-secondary absolute -top-4 -left-4 opacity-20"
            style="font-size: 4rem;"
          >
            format_quote
          </span>
          <p
            class="font-sans text-white text-xl lg:text-2xl leading-relaxed italic"
            data-i18n="qualityPolicy.quote"
          >
            {en.qualityPolicy.quote}
          </p>
          <div class="mt-10 flex items-center gap-6">
            <div class="p-3 bg-secondary/10 rounded-[4px] shrink-0">
              <span
                class="material-symbols-outlined text-secondary"
                style="font-size: 1.75rem; font-variation-settings: 'FILL' 1;"
              >
                verified
              </span>
            </div>
            <div>
              <p
                class="font-label font-bold text-white uppercase tracking-widest text-sm"
                data-i18n="qualityPolicy.badgeTitle"
              >
                {en.qualityPolicy.badgeTitle}
              </p>
              <p
                class="text-white/50 text-xs font-label mt-0.5"
                data-i18n="qualityPolicy.badgeSubtitle"
              >
                {en.qualityPolicy.badgeSubtitle}
              </p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
