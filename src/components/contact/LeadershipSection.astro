---
import { en } from '@/i18n/locales/en';

const { leadership } = en.contact;

const executives = [
  {
    name: 'Dr Muralidhar Honnagirigowda',
    category: 'Executive Council',
    title: 'Chief Executive Officer',
    email: 'muralidhara.h@indvaltech.com',
    linkedin: 'https://www.linkedin.com/in/muralidhara-honnagirigowda/',
  },
  {
    name: 'Gagan G Amin',
    category: 'Strategy & Growth',
    title: 'Business Development',
    email: 'gagan.g@indvaltech.com',
    linkedin: 'https://www.linkedin.com/in/gagan-g-amin/',
  },
  {
    name: 'Harsha Vardhana',
    category: 'Operations',
    title: 'Head of Operation - GM',
    email: 'harsha@indvaltech.com',
    linkedin: 'https://www.linkedin.com/in/vardhana-m/',
  },
];
---

<section class="pb-24 px-8 max-w-7xl mx-auto" aria-label="Executive leadership">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    {executives.map(({ name, category, title, email, linkedin }) => (
      <div class="btn-press-card relative bg-primary overflow-hidden shadow-[0px_12px_32px_rgba(11,28,48,0.22)] border-t-2 border-secondary/80 flex flex-col aspect-[1.6/1]">

        <div class="flex flex-col justify-between p-6 flex-1 min-w-0">

          <!-- Top: category + name + title -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="h-px w-6 bg-secondary shrink-0"></div>
              <span class="text-secondary font-label text-[10px] tracking-widest uppercase font-bold">{category}</span>
            </div>
            <h3 class="text-white font-headline font-bold text-xl leading-snug mb-1 break-words">{name}</h3>
            <p class="text-white/70 font-label text-xs tracking-wide uppercase leading-relaxed">{title}</p>
          </div>

          <!-- Divider + contact info -->
          <div class="border-t border-white/15 pt-3 flex flex-col gap-0">
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-2 text-white/65 hover:text-secondary transition-colors duration-200 min-w-0 py-1.5 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-secondary/60 focus-visible:rounded-sm"
            >
              <span class="material-symbols-outlined shrink-0" style="font-size: 1rem;">mail</span>
              <span class="font-label text-xs truncate">{email}</span>
            </a>
            <a
              href={linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-white/65 hover:text-secondary transition-colors duration-200 py-1.5 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-secondary/60 focus-visible:rounded-sm"
            >
              <svg class="w-[1rem] h-[1rem] fill-current shrink-0" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span
                class="font-label text-xs"
                data-i18n="contact.leadership.linkedinLabel"
              >{leadership.linkedinLabel}</span>
            </a>
          </div>

        </div>
      </div>
    ))}
  </div>
</section>
