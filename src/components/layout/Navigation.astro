---
import { en } from '@/i18n/locales/en';
import { withBase } from '@/lib/utils';

const beforeCompany = [
  { label: en.nav.home, href: '/', i18nKey: 'nav.home' },
];

const afterCompany = [
  { label: en.nav.career,   href: '/careers', i18nKey: 'nav.career'   },
  { label: en.nav.contact,  href: '/contact', i18nKey: 'nav.contact'  },
];

const industriesItems = [
  { label: en.industries.aerospace.title,  href: '/industries/aerospace',   i18nKey: 'industries.aerospace.title',  icon: 'flight' },
  { label: en.industries.automotive.title, href: '/industries/automotive',  i18nKey: 'industries.automotive.title', icon: 'directions_car' },
  { label: en.industries.locomotive.title, href: '/coming-soon',            i18nKey: 'industries.locomotive.title', icon: 'train'          },
  { label: en.industries.offHighway.title, href: '/coming-soon',            i18nKey: 'industries.offHighway.title', icon: 'agriculture'    },
  { label: en.industries.general.title,    href: '/coming-soon',            i18nKey: 'industries.general.title',    icon: 'precision_manufacturing'          },
];
---
<nav aria-label="Main navigation">
  <ul class="flex gap-8 list-none m-0 p-0 items-center">

    {beforeCompany.map(({ label, href, i18nKey }) => (
      <li>
        <a
          href={withBase(href)}
          data-i18n={i18nKey}
          class="font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300"
        >
          {label}
        </a>
      </li>
    ))}

    <!-- Industries dropdown -->
    <li id="industries-nav-item">
      <button
        id="industries-trigger"
        aria-haspopup="true"
        aria-expanded="false"
        class="flex items-center gap-0.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300 cursor-pointer"
      >
        <span data-i18n="nav.industries">{en.nav.industries}</span>
        <span
          id="industries-chevron"
          class="material-symbols-outlined text-base leading-none transition-transform duration-200"
          aria-hidden="true"
        >expand_more</span>
      </button>
    </li>

    <!-- Company dropdown -->
    <li id="company-nav-item">
      <button
        id="company-trigger"
        aria-haspopup="true"
        aria-expanded="false"
        class="flex items-center gap-0.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300 cursor-pointer"
      >
        <span data-i18n="nav.company">{en.nav.company}</span>
        <span
          id="company-chevron"
          class="material-symbols-outlined text-base leading-none transition-transform duration-200"
          aria-hidden="true"
        >expand_more</span>
      </button>
    </li>

    <!-- Capabilities mega menu -->
    <li id="capabilities-nav-item">
      <button
        id="capabilities-trigger"
        aria-haspopup="true"
        aria-expanded="false"
        class="flex items-center gap-0.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300 cursor-pointer"
      >
        <span data-i18n="capabilities.label">{en.capabilities.label}</span>
        <span
          id="capabilities-chevron"
          class="material-symbols-outlined text-base leading-none transition-transform duration-200"
          aria-hidden="true"
        >expand_more</span>
      </button>
    </li>

    {afterCompany.map(({ label, href, i18nKey }) => (
      <li>
        <a
          href={withBase(href)}
          data-i18n={i18nKey}
          class="font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-300"
        >
          {label}
        </a>
      </li>
    ))}

  </ul>
</nav>

<!-- Industries dropdown: fixed below header -->
<div
  id="industries-dropdown"
  role="menu"
  aria-label="Industries menu"
  class="fixed -translate-x-1/2 w-64 opacity-0 pointer-events-none translate-y-1 transition-all duration-200 ease-out z-50"
>
  <div class="bg-surface shadow-ambient-lg py-2">
    {industriesItems.map(({ label, href, i18nKey, icon }) => (
      <a
        href={withBase(href)}
        role="menuitem"
        class="group flex items-center gap-3 px-4 py-2.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-150"
      >
        <span class="material-symbols-outlined text-base leading-none shrink-0 text-on-surface-variant group-hover:text-secondary transition-colors duration-150" style="font-variation-settings: 'FILL' 0" aria-hidden="true">{icon}</span>
        <span data-i18n={i18nKey}>{label}</span>
      </a>
    ))}
  </div>
</div>

<!-- Company dropdown: fixed below header -->
<div
  id="company-dropdown"
  role="menu"
  aria-label="Company menu"
  class="fixed -translate-x-1/2 w-56 opacity-0 pointer-events-none translate-y-1 transition-all duration-200 ease-out z-50"
>
  <div class="bg-surface shadow-ambient-lg py-2">
    <a
      href={withBase('/about')}
      role="menuitem"
      class="group flex items-center gap-3 px-4 py-2.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-150"
    >
      <span class="material-symbols-outlined text-base leading-none shrink-0 text-on-surface-variant group-hover:text-secondary transition-colors duration-150" aria-hidden="true">corporate_fare</span>
      <span data-i18n="nav.aboutUs">{en.nav.aboutUs}</span>
    </a>
    <a
      href={withBase('/life')}
      role="menuitem"
      class="group flex items-center gap-3 px-4 py-2.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-150"
    >
      <span class="material-symbols-outlined text-base leading-none shrink-0 text-on-surface-variant group-hover:text-secondary transition-colors duration-150" aria-hidden="true">people</span>
      <span data-i18n="nav.lifeAtIndvaltech">{en.nav.lifeAtIndvaltech}</span>
    </a>
    <a
      href={withBase('/business-model')}
      role="menuitem"
      class="group flex items-center gap-3 px-4 py-2.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-150"
    >
      <span class="material-symbols-outlined text-base leading-none shrink-0 text-on-surface-variant group-hover:text-secondary transition-colors duration-150" aria-hidden="true">business_center</span>
      <span>Business Model</span>
    </a>
    <a
      href={withBase('/academia')}
      role="menuitem"
      class="group flex items-center gap-3 px-4 py-2.5 font-label text-sm uppercase tracking-wider text-on-surface-variant hover:text-secondary transition-colors duration-150"
    >
      <span class="material-symbols-outlined text-base leading-none shrink-0 text-on-surface-variant group-hover:text-secondary transition-colors duration-150" aria-hidden="true">school</span>
      <span data-i18n="nav.academia">{en.nav.academia}</span>
    </a>
  </div>
</div>

<!-- Capabilities mega menu: full-width, fixed below header -->
<div
  id="capabilities-dropdown"
  role="menu"
  aria-label="Capabilities menu"
  class="fixed left-0 right-0 opacity-0 pointer-events-none -translate-y-2 transition-all duration-200 ease-out z-40 bg-surface shadow-ambient-lg"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 flex gap-28 items-start">

    <!-- Left: Our Services -->
    <div class="shrink-0 w-44 pt-1">
      <p
        class="text-5xl font-bold text-slate-500 leading-tight"
        data-i18n="capabilities.ourServices"
      >{en.capabilities.ourServices}</p>
    </div>

    <!-- Right: 3 independent flex columns (masonry) -->
    <div class="flex-1 flex items-start gap-x-10">

      <!-- Column 1: Engineering Analysis + Mechanical Design -->
      <div class="flex-1 flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <span
            class="font-label text-sm uppercase tracking-wider font-bold text-on-surface cursor-default select-none"
            data-i18n="capabilities.engineeringAnalysis.heading"
          >{en.capabilities.engineeringAnalysis.heading}</span>
          <div class="flex flex-col gap-4">
            <a href={withBase('/capabilities/fea')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150" data-i18n="capabilities.engineeringAnalysis.fea">{en.capabilities.engineeringAnalysis.fea}</a>
            <a href={withBase('/capabilities/cfd')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150" data-i18n="capabilities.engineeringAnalysis.cfd">{en.capabilities.engineeringAnalysis.cfd}</a>
          </div>
        </div>
        <div class="flex flex-col gap-3">
          <span
            class="font-label text-sm uppercase tracking-wider font-bold text-on-surface cursor-default select-none"
            data-i18n="capabilities.mechanicalDesign.heading"
          >{en.capabilities.mechanicalDesign.heading}</span>
          <div class="flex flex-col gap-4">
            <a href={withBase('/capabilities/press-tool-design')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150" data-i18n="capabilities.mechanicalDesign.pressToolDesign">{en.capabilities.mechanicalDesign.pressToolDesign}</a>
            <a href={withBase('/coming-soon')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Tooling Design</a>
            <a href={withBase('/capabilities/composite-design')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Composite Design Solution</a>
            <a href={withBase('/capabilities/special-machine-design')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150" data-i18n="capabilities.mechanicalDesign.specialMachineDesign">{en.capabilities.mechanicalDesign.specialMachineDesign}</a>
            <a href={withBase('/coming-soon')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Product Development</a>
          </div>
        </div>
      </div>

      <!-- Column 2: Manufacturing + Technical Publication -->
      <div class="flex-1 flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/manufacturing')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.manufacturing.heading">{en.capabilities.manufacturing.heading}</a>
          <div class="flex flex-col gap-4">
            <a href={withBase('/capabilities/cnc-machining')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Machining</a>
            <a href={withBase('/capabilities/casting')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Castings</a>
            <a href={withBase('/capabilities/sheet-metal')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Sheet Metal</a>
            <a href={withBase('/capabilities/kitting-and-assembly')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Kitting and Assemblies</a>
            <a href={withBase('/capabilities/manufacturing#assembly-tooling')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Assembly Tooling</a>
            <a href={withBase('/capabilities/manufacturing#rapid-prototyping')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Rapid Prototyping</a>
            <a href={withBase('/capabilities/reverse-engineering')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150" data-i18n="capabilities.reverseEngineering.heading">{en.capabilities.reverseEngineering.heading}</a>
          </div>
        </div>
      </div>

      <!-- Column 3: BIW Turnkey Solutions -->
      <div class="flex-1 flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.biwTurnkey.heading">{en.capabilities.biwTurnkey.heading}</a>
          <div class="flex flex-col gap-4">
            <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">System Layout 2D</a>
            <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Process Planning &amp; Feasibility</a>
            <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Mechanical Design (3D/2D)</a>
            <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Robotic Simulation</a>
            <a href={withBase('/capabilities/biw-turnkey-solutions')} role="menuitem" class="font-label text-sm text-on-surface-variant hover:text-secondary transition-colors duration-150">Offline Programming (OLP)</a>
          </div>
        </div>
      </div>

      <!-- Column 4: Emerging Capabilities -->
      <div class="flex-1 flex flex-col gap-8">
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/cabin-interior')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.cabinInterior.heading">{en.capabilities.cabinInterior.heading}</a>
        </div>
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/mro-services')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.mroServices.heading">{en.capabilities.mroServices.heading}</a>
        </div>
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/electrical-harness-design')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.electricalHarnessDesign.heading">{en.capabilities.electricalHarnessDesign.heading}</a>
        </div>
        <div class="flex flex-col gap-3">
          <a href={withBase('/capabilities/technical-publication')} role="menuitem" class="font-label text-sm uppercase tracking-wider font-bold text-on-surface hover:text-secondary cursor-pointer transition-colors duration-150" data-i18n="capabilities.technicalPublication.heading">{en.capabilities.technicalPublication.heading}</a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const siteHeader = document.getElementById('site-header')!;

  // Industries dropdown
  const industriesNavItem = document.getElementById('industries-nav-item')!;
  const industriesTrigger = document.getElementById('industries-trigger')!;
  const industriesDropdown = document.getElementById('industries-dropdown')!;
  const industriesChevron = document.getElementById('industries-chevron')!;

  let indOpenTimer: ReturnType<typeof setTimeout>;
  let indCloseTimer: ReturnType<typeof setTimeout>;

  function showIndustries() {
    clearTimeout(indCloseTimer);
    const rect = industriesTrigger.getBoundingClientRect();
    industriesDropdown.style.top = siteHeader.getBoundingClientRect().bottom + 'px';
    industriesDropdown.style.left = (rect.left + rect.width / 2) + 'px';
    industriesDropdown.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-1');
    industriesDropdown.classList.add('opacity-100', 'translate-y-0');
    industriesTrigger.setAttribute('aria-expanded', 'true');
    industriesChevron.style.transform = 'rotate(180deg)';
    siteHeader.classList.remove('bg-surface/80', 'glass-nav');
    siteHeader.classList.add('bg-surface');
  }

  function hideIndustries() {
    clearTimeout(indOpenTimer);
    industriesDropdown.classList.add('opacity-0', 'pointer-events-none', 'translate-y-1');
    industriesDropdown.classList.remove('opacity-100', 'translate-y-0');
    industriesTrigger.setAttribute('aria-expanded', 'false');
    industriesChevron.style.transform = '';
    siteHeader.classList.remove('bg-surface');
    siteHeader.classList.add('bg-surface/80', 'glass-nav');
  }

  industriesNavItem.addEventListener('mouseenter', () => {
    clearTimeout(indCloseTimer);
    indOpenTimer = setTimeout(showIndustries, 150);
  });

  industriesNavItem.addEventListener('mouseleave', () => {
    clearTimeout(indOpenTimer);
    indCloseTimer = setTimeout(hideIndustries, 100);
  });

  industriesTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      industriesTrigger.getAttribute('aria-expanded') === 'true' ? hideIndustries() : showIndustries();
    }
    if (e.key === 'Escape') hideIndustries();
  });

  industriesDropdown.addEventListener('mouseenter', () => clearTimeout(indCloseTimer));
  industriesDropdown.addEventListener('mouseleave', () => { indCloseTimer = setTimeout(hideIndustries, 100); });

  document.addEventListener('click', (e) => {
    if (!industriesNavItem.contains(e.target as Node) && !industriesDropdown.contains(e.target as Node)) hideIndustries();
  });

  // Company dropdown
  const navItem = document.getElementById('company-nav-item')!;
  const trigger = document.getElementById('company-trigger')!;
  const dropdown = document.getElementById('company-dropdown')!;
  const chevron = document.getElementById('company-chevron')!;

  let openTimer: ReturnType<typeof setTimeout>;
  let closeTimer: ReturnType<typeof setTimeout>;

  function show() {
    clearTimeout(closeTimer);
    const rect = trigger.getBoundingClientRect();
    dropdown.style.top = siteHeader.getBoundingClientRect().bottom + 'px';
    dropdown.style.left = (rect.left + rect.width / 2) + 'px';
    dropdown.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-1');
    dropdown.classList.add('opacity-100', 'translate-y-0');
    trigger.setAttribute('aria-expanded', 'true');
    chevron.style.transform = 'rotate(180deg)';
    siteHeader.classList.remove('bg-surface/80', 'glass-nav');
    siteHeader.classList.add('bg-surface');
  }

  function hide() {
    clearTimeout(openTimer);
    dropdown.classList.add('opacity-0', 'pointer-events-none', 'translate-y-1');
    dropdown.classList.remove('opacity-100', 'translate-y-0');
    trigger.setAttribute('aria-expanded', 'false');
    chevron.style.transform = '';
    siteHeader.classList.remove('bg-surface');
    siteHeader.classList.add('bg-surface/80', 'glass-nav');
  }

  navItem.addEventListener('mouseenter', () => {
    clearTimeout(closeTimer);
    openTimer = setTimeout(show, 150);
  });

  navItem.addEventListener('mouseleave', () => {
    clearTimeout(openTimer);
    closeTimer = setTimeout(hide, 100);
  });

  trigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      trigger.getAttribute('aria-expanded') === 'true' ? hide() : show();
    }
    if (e.key === 'Escape') hide();
  });

  dropdown.addEventListener('mouseenter', () => clearTimeout(closeTimer));
  dropdown.addEventListener('mouseleave', () => { closeTimer = setTimeout(hide, 100); });

  document.addEventListener('click', (e) => {
    if (!navItem.contains(e.target as Node) && !dropdown.contains(e.target as Node)) hide();
  });

  // Capabilities mega menu
  const capNavItem = document.getElementById('capabilities-nav-item')!;
  const capTrigger = document.getElementById('capabilities-trigger')!;
  const capDropdown = document.getElementById('capabilities-dropdown')!;
  const capChevron = document.getElementById('capabilities-chevron')!;

  let capOpenTimer: ReturnType<typeof setTimeout>;
  let capCloseTimer: ReturnType<typeof setTimeout>;

  function showCap() {
    clearTimeout(capCloseTimer);
    capDropdown.style.top = siteHeader.getBoundingClientRect().bottom + 'px';
    capDropdown.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-2');
    capDropdown.classList.add('opacity-100', 'translate-y-0');
    capTrigger.setAttribute('aria-expanded', 'true');
    capChevron.style.transform = 'rotate(180deg)';
    siteHeader.classList.remove('bg-surface/80', 'glass-nav');
    siteHeader.classList.add('bg-surface');
  }

  function hideCap() {
    clearTimeout(capOpenTimer);
    capDropdown.classList.add('opacity-0', 'pointer-events-none', '-translate-y-2');
    capDropdown.classList.remove('opacity-100', 'translate-y-0');
    capTrigger.setAttribute('aria-expanded', 'false');
    capChevron.style.transform = '';
    siteHeader.classList.remove('bg-surface');
    siteHeader.classList.add('bg-surface/80', 'glass-nav');
  }

  capNavItem.addEventListener('mouseenter', () => {
    clearTimeout(capCloseTimer);
    capOpenTimer = setTimeout(showCap, 150);
  });

  capNavItem.addEventListener('mouseleave', () => {
    clearTimeout(capOpenTimer);
    capCloseTimer = setTimeout(hideCap, 150);
  });

  // Bridge: keep menu open when mouse travels from nav item to fixed dropdown
  capDropdown.addEventListener('mouseenter', () => clearTimeout(capCloseTimer));
  capDropdown.addEventListener('mouseleave', () => {
    capCloseTimer = setTimeout(hideCap, 100);
  });

  capTrigger.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      capTrigger.getAttribute('aria-expanded') === 'true' ? hideCap() : showCap();
    }
    if (e.key === 'Escape') hideCap();
  });

  document.addEventListener('click', (e) => {
    if (!capNavItem.contains(e.target as Node) && !capDropdown.contains(e.target as Node)) hideCap();
  });
</script>
