---
import { Image, getImage } from 'astro:assets';
import CompositeDesignLightbox from './CompositeDesignLightbox.astro';
import typicalPlugDetailsRaw from '@/assets/images/typical-plug-details.png';
import sectionViewPlugMouldRaw from '@/assets/images/section-view-plug-mould.png';
import partingLineAndSplitRaw from '@/assets/images/parting-line-and-split.png';
import mouldDetailsTypicalRaw from '@/assets/images/mould-details-typical.png';
import mouldBaseSupportStructureRaw from '@/assets/images/mould-base-support-structure.png';

const [
  typicalPlugDetails,
  sectionViewPlugMould,
  partingLineAndSplit,
  mouldDetailsTypical,
  mouldBaseSupportStructure,
] = await Promise.all([
  getImage({ src: typicalPlugDetailsRaw, format: 'avif' }),
  getImage({ src: sectionViewPlugMouldRaw, format: 'avif' }),
  getImage({ src: partingLineAndSplitRaw, format: 'avif' }),
  getImage({ src: mouldDetailsTypicalRaw, format: 'avif' }),
  getImage({ src: mouldBaseSupportStructureRaw, format: 'avif' }),
]);

const diagrams = [
  { image: typicalPlugDetailsRaw,        optimized: typicalPlugDetails,        title: 'Typical Plug Details' },
  { image: sectionViewPlugMouldRaw,      optimized: sectionViewPlugMould,      title: 'Section View (Plug & Mould)' },
  { image: partingLineAndSplitRaw,       optimized: partingLineAndSplit,       title: 'Parting Line & Split' },
  { image: mouldDetailsTypicalRaw,       optimized: mouldDetailsTypical,       title: 'Mould Details (Typical)' },
  { image: mouldBaseSupportStructureRaw, optimized: mouldBaseSupportStructure, title: 'Mould Base / Support Structure' },
];

const allSrcs = diagrams.map(d => ({ src: d.optimized.src, title: d.title }));
---

<section class="bg-surface-container-low">
  <div class="max-w-5xl mx-auto px-8 lg:px-16 py-20">

    <span class="font-label text-sm font-bold uppercase tracking-widest text-secondary">Reference detail</span>
    <h2 class="font-headline text-4xl lg:text-5xl font-extrabold tracking-tighter text-primary mt-3 mb-12">
      Plug &amp; mould engineering, in detail
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 items-stretch">
      {diagrams.map(({ image, title }, i) => {
        const rotated = [...allSrcs.slice(i), ...allSrcs.slice(0, i)];
        return (
          <div
            class="flex flex-col border border-outline-variant rounded-md overflow-hidden shadow-sm cursor-pointer btn-press-card focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary"
            data-diagram-index={i}
            data-diagram-title={title}
            data-diagram-icon="deployed_code"
            data-images={JSON.stringify(rotated)}
            role="button"
            tabindex="0"
            aria-label={`View ${title}`}
          >
            <div class="flex-1 min-h-[13rem] overflow-hidden bg-white flex items-center justify-center p-6">
              <Image
                src={image}
                alt={title}
                class="w-auto h-40"
              />
            </div>
            <div class="px-5 py-4 bg-primary shrink-0 flex items-center justify-between gap-3">
              <h3 class="font-label text-sm text-white">{title}</h3>
              <span class="material-symbols-outlined text-white/30 shrink-0" style="font-size: 1.1rem;" aria-hidden="true">open_in_full</span>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<CompositeDesignLightbox />
