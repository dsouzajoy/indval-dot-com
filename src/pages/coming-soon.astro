---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { withBase } from '@/lib/utils';
---

<BaseLayout
  title="Coming Soon | Indvaltech Engineering Services"
  description="This page is currently under construction. We're working hard to bring you this content soon."
  showSplash={false}
  noindex={true}
>
  <section class="min-h-[calc(100vh-4rem)] bg-surface flex items-center justify-center px-8 py-24">
    <div class="max-w-2xl mx-auto text-center">

      <!-- Icon -->
      <div class="flex justify-center mb-8">
        <div class="bg-primary/10 rounded-full p-8">
          <span
            class="material-symbols-outlined text-primary"
            style="font-size: 5rem; font-variation-settings: 'FILL' 1;"
            aria-hidden="true"
          >construction</span>
        </div>
      </div>

      <!-- Label -->
      <p class="font-label text-sm uppercase tracking-widest text-secondary mb-4">Coming Soon</p>

      <!-- Title -->
      <h1 class="font-headline text-4xl lg:text-5xl font-bold text-on-surface mb-6 leading-tight">
        We're Building Something Great
      </h1>

      <!-- Body -->
      <p class="text-on-surface-variant text-base leading-relaxed mb-4 max-w-lg mx-auto">
        This section of our website is being crafted with care. Our team is working to bring you detailed information about this capability very soon.
      </p>
      <p class="text-on-surface-variant text-base leading-relaxed mb-12 max-w-lg mx-auto">
        In the meantime, we'd love to hear from you. Tell us what you're looking for and we'll connect you with the right people on our team.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <Button href="/" variant="primary">Back to Home</Button>
        <Button href={withBase('/contact#contact-form')} variant="ghost">Get In Touch</Button>
      </div>

    </div>
  </section>
</BaseLayout>
