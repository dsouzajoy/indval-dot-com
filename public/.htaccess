# Security Headers
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# Caching Strategy
<FilesMatch "\.(woff2|jpg|jpeg|png|webp|gif|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(css|js)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(html)$">
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# 301 Redirects
RewriteEngine On

# Canonical domain: redirect non-www to www
RewriteCond %{HTTP_HOST} ^indvaltech\.com$ [NC]
RewriteRule ^(.*)$ https://www.indvaltech.com/$1 [R=301,L]
RewriteCond %{QUERY_STRING} ^page_id=146$
RewriteRule ^$ /contact/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=199$
RewriteRule ^$ /industries/automotive/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=2077$
RewriteRule ^$ /industries/aerospace/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=2085$
RewriteRule ^$ /capabilities/fea/? [R=301,L]

RewriteCond %{QUERY_STRING} ^page_id=203$
RewriteRule ^$ /? [R=301,L]

# Custom 404
ErrorDocument 404 /404.html
