---
import BaseLayout from '../layouts/BaseLayout.astro';
import AcademiaHero from '../components/academia/AcademiaHero.astro';
import PhilosophySection from '../components/academia/PhilosophySection.astro';
import ProgramPipelineSection from '../components/academia/ProgramPipelineSection.astro';
import CompetencyCentersSection from '../components/academia/CompetencyCentersSection.astro';
import OutcomesSection from '../components/academia/OutcomesSection.astro';
import { withBase } from '../lib/utils';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="Indval Academia | Training & Competency Development | Indvaltech"
  description="Indval Academia bridges the gap between university graduates and industry-ready engineers through structured 3-month programs in Aerospace and Automotive competency development."
  showSplash={false}
>
  <AcademiaHero />
  <PhilosophySection />
  <ProgramPipelineSection />
  <CompetencyCentersSection />
  <OutcomesSection />

  <!-- CTA Banner -->
  <section class="bg-on-surface py-20 px-8">
    <div class="container mx-auto text-center max-w-3xl">
      <h2 class="font-headline font-black text-4xl md:text-5xl text-white leading-[0.9] tracking-tight mb-4">
        Ready to Join Indval Academia?
      </h2>
      <p class="text-white/80 text-lg leading-relaxed mb-10">
        Connect with our team to learn more about program eligibility, upcoming batches, and enrollment.
      </p>
      <Button href={withBase('/contact')} variant="secondary">Get In Touch</Button>
    </div>
  </section>
</BaseLayout>
